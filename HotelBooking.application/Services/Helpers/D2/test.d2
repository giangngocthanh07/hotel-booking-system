# 1. Cấu hình chung
direction: right # Hướng vẽ từ trái sang phải
classes: {
  # Định nghĩa style chung cho các node quan trọng
  database: {shape: cylinder; style.multiple: true}
}

# 2. Định nghĩa các thành phần (User)
User: {
  shape: person
}

# 3. Định nghĩa cụm hệ thống (Nesting - Điểm mạnh của D2)
System Cloud: {
  style: {
    stroke-dash: 3
    fill: "#f2f4f8"
  }

  # Load Balancer
  Nginx: {
    shape: parallelogram
  }

  # Backend Service Cluster
  Core Services: {
    API Service
    Auth Service
  }

  # Data Layer
  Data: {
    Postgres: {
      class: database
    }
    Redis Cache: {
      shape: queue
    }
  }
}

# 4. Định nghĩa các đường nối (Connections)
User -> System Cloud.Nginx: HTTPS
System Cloud.Nginx -> System Cloud.Core Services.API Service
System Cloud.Nginx -> System Cloud.Core Services.Auth Service

System Cloud.Core Services.API Service -> System Cloud.Data.Postgres: Read/Write
System Cloud.Core Services.API Service -> System Cloud.Data.Redis Cache: Get/Set
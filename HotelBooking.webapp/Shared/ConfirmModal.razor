@if (_isVisible)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content shadow-lg border-0">

                @* HEADER *@
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i> @Title
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Hide"></button>
                </div>

                @* BODY *@
                <div class="modal-body py-4">
                    <p class="fw-bold fs-5">@Message</p>
                    <p class="text-danger small mb-0">
                        <i class="fa-solid fa-circle-info me-1"></i> This action cannot be undone.
                    </p>
                </div>

                @* FOOTER *@
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary px-4" @onclick="Hide">
                        <i class="fa-solid fa-xmark me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-danger px-4 shadow-sm" @onclick="OnConfirmClicked">
                        <i class="fa-solid fa-trash me-1"></i> Confirm Delete
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    // --- 1. PARAMETERS (Content Configuration) ---
    [Parameter] public string Title { get; set; } = "Confirm Delete";
    [Parameter] public string Message { get; set; } = "Are you sure you want to delete this item?";

    // Event callback to notify the parent component when "Confirm" is clicked
    [Parameter] public EventCallback OnConfirm { get; set; }

    // --- 2. STATE ---
    private bool _isVisible = false;

    // --- 3. PUBLIC METHODS (Invoked by Parent) ---

    /// <summary>
    /// Opens the confirmation modal.
    /// </summary>
    public void Show()
    {
        _isVisible = true;
        StateHasChanged();
    }

    /// <summary>
    /// Closes the confirmation modal.
    /// </summary>
    public void Hide()
    {
        _isVisible = false;
        StateHasChanged();
    }

    // --- 4. INTERNAL LOGIC ---
    private async Task OnConfirmClicked()
    {
        // 1. Invoke the parent event
        await OnConfirm.InvokeAsync();

        // 2. Automatically close the modal
        Hide();
    }
}
@inherits LayoutComponentBase

<div class="main">
    <header class="navbar navbar-expand-lg position-fixed top-0 start-0 w-100" style="z-index: 1000;">
    <div class="container">
        <!-- Logo on the left -->
        <a class="navbar-brand" href="/">
            <img src="/images/logo.png" alt="Hotel Booking Logo" class="logo" />
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <!-- Navigation links on the right -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <NavMenu />
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link text-white" href="/login">Login</a>
                </li>
            </ul>
        </div>
    </div>
</header>

    <main class="page-content">
        @Body
    </main>

    <footer class="footer text-white py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4 mb-md-0">
                    <h5 class="fw-bold">Hotel Booking</h5>
                    <p>Đặt phòng khách sạn dễ dàng, nhanh chóng với trải nghiệm tuyệt vời.</p>
                </div>
                <div class="col-md-4 mb-4 mb-md-0">
                    <h5 class="fw-bold">Liên hệ</h5>
                    <p>Email: <a href="mailto:support@hotelbooking.com">support@hotelbooking.com</a></p>
                    <p>Hotline: <a href="tel:19001234">1900 1234</a></p>
                </div>
                <div class="col-md-4">
                    <h5 class="fw-bold">Theo dõi chúng tôi</h5>
                    <div class="social-icons">
                        <a href="#" class="text-warning"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-warning"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-warning"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
            <p class="text-center mt-4 mb-0">&copy; 2025 Hotel Booking. All rights reserved.</p>
        </div>
    </footer>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

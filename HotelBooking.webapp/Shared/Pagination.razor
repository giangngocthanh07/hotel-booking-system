@* Reusable Pagination Component
    Usage: <Pagination CurrentPage="@currentPage" TotalPages="@totalPages" 
                       TotalCount="@totalCount" OnPageChange="GoToPage" />
*@

@if (TotalPages > 1)
{
    <div class="@ContainerClass">
        <nav aria-label="Page navigation">
            <ul class="pagination @PaginationClass">
                @* Previous Button *@
                <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="GoToPrevious" disabled="@IsLoading" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </button>
                </li>

                @* Dynamic Page Numbers *@
                @foreach (var pageNumber in GetPageNumbers())
                {
                    <li class="page-item @(pageNumber == CurrentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNumber)" disabled="@IsLoading">
                            @pageNumber
                        </button>
                    </li>
                }

                @* Next Button *@
                <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="GoToNext" disabled="@IsLoading" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </button>
                </li>
            </ul>
        </nav>
    </div>

    @if (ShowInfo)
    {
        <div class="text-center text-muted">
            <small>Page @CurrentPage of @TotalPages @(TotalCount > 0 ? $"(Total: {TotalCount} items)" : "")</small>
        </div>
    }
}

@code {
    /// <summary>
    /// Current active page (1-indexed)
    /// </summary>
    [Parameter] public int CurrentPage { get; set; } = 1;

    /// <summary>
    /// Total number of pages
    /// </summary>
    [Parameter] public int TotalPages { get; set; }

    /// <summary>
    /// Total number of items (optional, used for informational display)
    /// </summary>
    [Parameter] public int TotalCount { get; set; }

    /// <summary>
    /// Loading state flag to disable interactions
    /// </summary>
    [Parameter] public bool IsLoading { get; set; }

    /// <summary>
    /// Whether to display the "Page x of y" info text
    /// </summary>
    [Parameter] public bool ShowInfo { get; set; } = true;

    /// <summary>
    /// Number of pages to show on each side of the current page
    /// E.g., CurrentPage=5, Spread=2 -> shows [3,4,5,6,7]
    /// </summary>
    [Parameter] public int Spread { get; set; } = 2;

    /// <summary>
    /// CSS class for the container div (Default: d-flex justify-content-center mt-4)
    /// </summary>
    [Parameter] public string ContainerClass { get; set; } = "d-flex justify-content-center mt-4";

    /// <summary>
    /// Additional CSS classes for the ul.pagination element
    /// </summary>
    [Parameter] public string PaginationClass { get; set; } = "";

    /// <summary>
    /// Event callback triggered when a user navigates to a different page
    /// </summary>
    [Parameter] public EventCallback<int> OnPageChange { get; set; }

    /// <summary>
    /// Calculates the range of page numbers to display based on the spread parameter.
    /// </summary>
    private IEnumerable<int> GetPageNumbers()
    {
        var start = Math.Max(1, CurrentPage - Spread);
        var end = Math.Min(TotalPages, CurrentPage + Spread);
        return Enumerable.Range(start, end - start + 1);
    }

    private async Task GoToPage(int page)
    {
        // Guard clause: Prevent unnecessary or invalid calls
        if (page >= 1 && page <= TotalPages && page != CurrentPage && !IsLoading)
        {
            await OnPageChange.InvokeAsync(page);
        }
    }

    private async Task GoToPrevious()
    {
        if (CurrentPage > 1)
            await GoToPage(CurrentPage - 1);
    }

    private async Task GoToNext()
    {
        if (CurrentPage < TotalPages)
            await GoToPage(CurrentPage + 1);
    }
}
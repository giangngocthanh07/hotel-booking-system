@using System.Security.Claims
@using HotelBooking.Client
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<header class="navbar navbar-expand-lg position-fixed top-0 start-0 w-100 shadow-sm" style="z-index: 1000;">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center fw-bold fs-4 text-primary" href="/">
            <img src="/images/logo.png" alt="Hotel Booking Logo" class="logo me-2" style="height:45px;" />
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto gap-lg-5 fw-semibold fs-5">
                <li class="nav-item">
                    <NavLink class="nav-link custom-nav" href="/" Match="NavLinkMatch.All">Home</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link custom-nav" href="/Hotels">Hotels</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link custom-nav" href="/about">About Us</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link custom-nav" href="/contact">Support</NavLink>
                </li>
            </ul>

            <div class="d-flex navbar-actions align-items-center">
                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <a class="d-flex align-items-center text-decoration-none dropdown-toggle" href="#" id="userDropdown"
                           role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            
                            @if (!string.IsNullOrEmpty(userAvatar) && userAvatar.StartsWith("http"))
                            {
                                <img src="@userAvatar" alt="avatar" class="rounded-circle me-2"
                                     style="width:40px; height:40px;" />
                            }
                            else
                            {
                                <div class="rounded-circle me-2 d-flex align-items-center justify-content-center text-white"
                                     style="width:40px; height:40px; background-color: #007bff; font-size: 18px; font-weight: bold;">
                                    @GetFirstLetter(userFullName)
                                </div>
                            }
                            <span class="fw-semibold text-dark">@userFullName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                            <li>
                                <a class="dropdown-item" href="/profile">
                                    <i class="bi bi-person me-2"></i> My Profile
                                </a>
                            </li>
                            @if (userRoles.Contains("Owner"))
                            {
                                <li>
                                    <a class="dropdown-item" href="/owner-dashboard">
                                        <i class="bi bi-building me-2"></i> Property Management
                                    </a>
                                </li>
                            }
                            @if (userRoles.Contains("Customer") && !userRoles.Contains("Owner"))
                            {
                                <li>
                                    <a class="dropdown-item" href="/upgrade-owner">
                                        <i class="bi bi-pen me-2"></i> Become a Partner
                                    </a>
                                </li>
                            }
                            @if (userRoles.Contains("Admin"))
                            {
                                <li>
                                    <a class="dropdown-item" href="/admin">
                                        <i class="bi bi-gear me-2"></i> Admin Panel
                                    </a>
                                </li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <a class="dropdown-item text-danger" style="cursor:pointer" @onclick="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="btn btn-outline-light me-2" href="/customer-register">Register</a>
                    <a class="btn btn-light" href="/customer-login">Login</a>
                }
            </div>
        </div>
    </div>
</header>

@code {
    private bool isAuthenticated = false;
    private List<string> userRoles = new();
    private string userFullName = "Guest";
    private string userAvatar = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += async (task) =>
        {
            var authState = await task;
            await UpdateUserInfo(authState);
            StateHasChanged();
        };

        await UpdateUserInfo(await AuthStateProvider.GetAuthenticationStateAsync());
    }

    private async Task UpdateUserInfo(AuthenticationState authState)
    {
        var user = authState.User;
        isAuthenticated = user.Identity?.IsAuthenticated ?? false;

        if (isAuthenticated)
        {
            userFullName = user.FindFirst("FullName")?.Value ?? "User";
            userAvatar = user.FindFirst("Avatar")?.Value ?? string.Empty;
            userRoles = user.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
        }
        else
        {
            userFullName = "Guest";
            userAvatar = string.Empty;
            userRoles.Clear();
        }
    }

    private string GetFirstLetter(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var names = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var lastName = names[^1]; 
        return lastName.Length > 0 ? lastName[0].ToString().ToUpper() : "?";
    }

    private async Task Logout()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            await customAuth.MarkUserAsLoggedOut();
        }
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
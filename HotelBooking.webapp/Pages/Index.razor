@page "/"
@layout MainLayout
@inject IJSRuntime JS
@* trang chủ chứa nội dung tổng quan về dịch vụ của website *@

<!-- Hero Carousel -->
<div id="heroCarousel" class="carousel slide carousel-fade position-relative" data-bs-ride="carousel">
  <div class="carousel-inner">
    <div class="carousel-item active vh-100 bg-cover"
      style="background-image: url('https://source.unsplash.com/1600x900/?hotel');"></div>
    <div class="carousel-item vh-100 bg-cover"
      style="background-image: url('https://source.unsplash.com/1600x900/?resort');"></div>
    <div class="carousel-item vh-100 bg-cover"
      style="background-image: url('https://source.unsplash.com/1600x900/?beach,hotel');"></div>
  </div>

  <!-- Nút điều hướng trái/phải -->
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

  <!-- Overlay mờ để chữ nổi bật -->
  <div class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-25"></div>

  <!-- Text Caption -->
  <div class="carousel-caption d-flex flex-column justify-content-center h-100">
    <h1 class="fw-bold display-4">Enjoy Your Stay</h1>
    <p class="lead">Find the best deals for your perfect vacation</p>
  </div>

  <!-- Search Form -->
  <div class="hero-search position-absolute bottom-0 start-50 translate-middle-x w-100 mb-4"
    style="z-index: 3; max-width: 960px;">
    <div class="card shadow-sm mx-auto">
      <div class="card-body">
        <form class="row g-2 align-items-end">
          <div class="col-12 col-md-4">
            <label class="form-label small mb-1">Điểm đến</label>
            <input type="text" class="form-control form-control-sm" placeholder="Thành phố, khách sạn hoặc địa điểm" />
          </div>
          <div class="col-6 col-md-2">
            <label class="form-label small mb-1">Nhận</label>
            <input type="date" class="form-control form-control-sm" />
          </div>
          <div class="col-6 col-md-2">
            <label class="form-label small mb-1">Trả</label>
            <input type="date" class="form-control form-control-sm" />
          </div>
          <div class="col-6 col-md-2">
            <label class="form-label small mb-1">Người</label>
            <select class="form-select form-select-sm">
              <option>2</option>
              <option>1</option>
              <option>3</option>
            </select>
          </div>
          <div class="col-6 col-md-2 d-grid">
            <button type="button" class="btn btn-primary btn-sm w-100">
              <i class="bi bi-search me-1"></i> Tìm
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- địa điểm du lịch để booking-->

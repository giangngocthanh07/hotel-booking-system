@code {
  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      // Call JS to initialize the multi-card carousel after first render
      await JS.InvokeVoidAsync("initMultiCardCarousel");
    }
  }
}
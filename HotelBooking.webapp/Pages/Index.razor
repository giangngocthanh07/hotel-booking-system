@page "/"
@layout MainLayout
@inject IJSRuntime JS
@* trang chủ chứa nội dung tổng quan về dịch vụ của website *@

<!-- Hero Carousel -->
<div id="heroCarousel" class="carousel slide carousel-fade position-relative" data-bs-ride="carousel">
  <div class="carousel-inner">
    <div class="carousel-item active vh-100 bg-cover"
      style="background-image: url('https://source.unsplash.com/1600x900/?hotel');"></div>
    <div class="carousel-item vh-100 bg-cover"
      style="background-image: url('https://source.unsplash.com/1600x900/?resort');"></div>
    <div class="carousel-item vh-100 bg-cover"
      style="background-image: url('https://source.unsplash.com/1600x900/?beach,hotel');"></div>
  </div>

  <!-- Nút điều hướng trái/phải -->
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

  <!-- Overlay mờ để chữ nổi bật -->
  <div class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-25"></div>

  <!-- Text Caption -->
  <div class="carousel-caption d-flex flex-column justify-content-center h-100">
    <h1 class="fw-bold display-4">Enjoy Your Stay</h1>
    <p class="lead">Find the best deals for your perfect vacation</p>
  </div>

  <!-- Search Form -->
  <div class="hero-search position-absolute bottom-0 start-50 translate-middle-x w-100 mb-4"
    style="z-index: 3; max-width: 960px;">
    <div class="search-form container p-3 bg-white rounded-3 shadow">
      <form class="row g-2 align-items-stretch">

        <!-- Điểm đến -->
        <div class="col-12 col-md-4">
          <label class="form-label small mb-1">Bạn muốn đến đâu?</label>
          <div class="input-group h-100">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Thành phố, khách sạn hoặc địa điểm"
              @bind="Destination" />
          </div>
        </div>

        <!-- Ngày nhận - trả -->
        <div class="col-12 col-md-4">
          <label class="form-label small mb-1">Ngày nhận - trả phòng</label>
          <div class="input-group h-100">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-event"></i></span>
            <input id="dateRange" type="text" class="form-control border-start-0" placeholder="Chọn ngày" readonly />
          </div>
        </div>

        <!-- Khách & phòng -->
        <div class="col-6 col-md-2">
          <label class="form-label small mb-1">Khách & Phòng</label>
          <div class="dropdown h-100">
            <button
              class="btn btn-outline-secondary w-100 rounded-pill d-flex justify-content-between align-items-center"
              type="button" id="dropdownGuests" data-bs-toggle="dropdown" aria-expanded="false">
              @Guests người · @Rooms phòng
            </button>
            <ul class="dropdown-menu p-3" aria-labelledby="dropdownGuests" style="min-width: 250px;">
              <li class="d-flex justify-content-between align-items-center mb-2">
                <span>Người lớn</span>
                <div>
                  <button type="button" class="btn btn-sm btn-outline-secondary"
                    @onclick="() => ChangeGuests(-1)">-</button>
                  <span class="mx-2">@Guests</span>
                  <button type="button" class="btn btn-sm btn-outline-secondary"
                    @onclick="() => ChangeGuests(1)">+</button>
                </div>
              </li>
              <li class="d-flex justify-content-between align-items-center">
                <span>Phòng</span>
                <div>
                  <button type="button" class="btn btn-sm btn-outline-secondary"
                    @onclick="() => ChangeRooms(-1)">-</button>
                  <span class="mx-2">@Rooms</span>
                  <button type="button" class="btn btn-sm btn-outline-secondary"
                    @onclick="() => ChangeRooms(1)">+</button>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- Nút tìm -->
        <div class="col-6 col-md-2 d-grid">
          <button type="button" class="btn btn-primary w-100 rounded-pill h-100" @onclick="SearchHotels">
            <i class="bi bi-search me-1"></i> Tìm
          </button>
        </div>
      </form>
    </div>

    @code {
      private string Destination { get; set; } = "";
      private int Guests { get; set; } = 2;
      private int Rooms { get; set; } = 1;

      private void ChangeGuests(int value)
      {
        Guests = Math.Max(1, Guests + value);
      }

      private void ChangeRooms(int value)
      {
        Rooms = Math.Max(1, Rooms + value);
      }

      private void SearchHotels()
      {
        // TODO: Gọi API hoặc điều hướng sang trang kết quả tìm kiếm
        Console.WriteLine($"Search: {Destination}, Guests={Guests}, Rooms={Rooms}");
      }
    }

  </div>

</div>



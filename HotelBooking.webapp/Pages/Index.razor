    </div>
  </div>
</div>


@* thêm ý tưởng cho web hotel booking *@
<!-- Các tính năng khác -->
<div class="container mt-5">
  <h2 class="mb-4 text-center">Tại sao chọn chúng tôi?</h2>
  <div class="row">
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body text-center">
          <i class="bi bi-house fs-1 text-primary mb-3"></i>
          <h5 class="card-title">Đa dạng lựa chọn</h5>
          <p class="card-text">Khám phá hàng ngàn khách sạn, nhà nghỉ và căn hộ trên khắp thế giới.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body text-center">
          <i class="bi bi-percent fs-1 text-primary mb-3"></i>
          <h5 class="card-title">Giá tốt nhất</h5>
          <p class="card-text">Chúng tôi cam kết cung cấp giá cạnh tranh nhất trên thị trường.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body text-center">
          <i class="bi bi-shield-check fs-1 text-primary mb-3"></i>
          <h5 class="card-title">An toàn & Bảo mật</h5>
          <p class="card-text">Đặt phòng an toàn và bảo mật với hệ thống thanh toán đáng tin cậy.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Đăng ký đối tác -->
<div class="container mt-5">
  <div class="card bg-light text-center py-5">
    <div class="card-body">
      <h2 class="card-title mb-4">Bạn là chủ khách sạn?</h2>
      <p class="card-text mb-4">Đăng ký ngay để quảng bá khách sạn của bạn và tiếp cận hàng triệu khách hàng.</p>
      <a href="#" class="btn btn-primary">Đăng ký đối tác</a>
    </div>
  </div>
</div>

@code {
  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    <!-- địa điểm du lịch -->
    if (firstRender)
    {
      await JS.InvokeVoidAsync("initMultiCardCarousel");
    }
  }


}
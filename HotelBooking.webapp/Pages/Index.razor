      <div id="multiCardCarousel" class="d-flex" style="gap:1rem; transition: transform 0.5s ease;">
        <!-- Card items -->
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội 2</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội 3</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội4</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội5</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội6</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội7</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội8</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội9</h5>
          </div>
        </div>
        <div class="card flex-shrink-0 destination-card">
          <img src="https://source.unsplash.com/400x300/?city,travel" class="card-img-top">
          <div class="card-body text-center">
            <h5 class="card-title">Hà Nội0</h5>
          </div>
        </div>
      </div>
    </div>

    <!-- Prev/Next buttons -->
    <button class="carousel-btn prev-btn" id="prevBtn">&#10094;</button>
    <button class="carousel-btn next-btn" id="nextBtn">&#10095;</button>
  </div>
</div>

<!-- loại chỗ ở -->
<div class="container mt-5">
  <h2>Loại chỗ ở</h2>
  <div class="accommodation-grid">
    <div class="accommodation-card">
      <span class="title-accommodation">Khách sạn</span>
      <img src="https://picsum.photos/200/150?random=1" alt="">
    </div>
    <div class="accommodation-card">
      <span class="title-accommodation">Căn hộ</span>
      <img src="https://picsum.photos/200/150?random=2" alt="">
    </div>
    <div class="accommodation-card">
      <span class="title-accommodation">Resort</span>
      <img src="https://picsum.photos/200/150?random=3" alt="">
    </div>
    <div class="accommodation-card">
      <span class="title-accommodation">Homestay</span>
      <img src="https://picsum.photos/200/150?random=4" alt="">
    </div>
    <div class="accommodation-card">
      <span class="title-accommodation">Biệt thự</span>
      <img src="https://picsum.photos/200/150?random=5" alt="">
    </div>
    <div class="accommodation-card">
      <span class="title-accommodation">Lều trại sang trọng</span>
      <img src="https://picsum.photos/200/150?random=6" alt="">
    </div>
    <div class="accommodation-card">
      <span class="title-accommodation">Nhà trọ</span>

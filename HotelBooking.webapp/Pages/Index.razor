<!-- Top-rated accommodations -->
<div class="container mt-5">
  <h2 class="mb-4 text-center">Top-Rated Accommodations</h2>
  <div class="row">
    @foreach (var hotel in Hotels)
    {
        <div class="col-sm-6 col-md-3 mb-4">
          <div class="card h-100 shadow-sm position-relative">

            <!-- Carousel -->
          <div id="@($"hotelCarousel{hotel.Id}")" class="carousel slide" data-bs-ride="carousel">
              <div class="carousel-inner">
              @for (int i = 0; i < hotel.Images.Count; i++)
              {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                      <img src="@hotel.Images[i]" class="d-block w-100" style="height: 200px; object-fit: cover;"
                    alt="Hotel Image">
                    </div>
              }
              </div>

              <!-- Prev -->
            <button class="carousel-control-prev" type="button" data-bs-target="@($"#hotelCarousel{hotel.Id}")"
              data-bs-slide="prev" @onclick:stopPropagation="true"
              style="position: absolute; top: 50%; transform: translateY(-50%);">
                <span class="carousel-control-prev-icon"></span>
              </button>

              <!-- Next -->
            <button class="carousel-control-next" type="button" data-bs-target="@($"#hotelCarousel{hotel.Id}")"
              data-bs-slide="next" @onclick:stopPropagation="true"
              style="position: absolute; top: 50%; transform: translateY(-50%);">
                <span class="carousel-control-next-icon"></span>
              </button>
            </div>
            <!-- Wishlist Button (placed last so it always appears on top) -->
          <button class="wishlist-btn position-absolute top-0 end-0 m-2 btn btn-sm" style="z-index: 5;"
            @onclick:stopPropagation="true" @onclick="() => ToggleWishlist(hotel.Id)">
              <i class="bi @(hotel.IsWishlist ? "bi-heart-fill text-danger" : "bi-heart text-dark")"></i>
            </button>

            <!-- Card body -->
          <div class="card-body d-flex flex-column justify-content-between">
              <div>
                <h5 class="card-title">@hotel.Name</h5>
                <small class="text-muted">Location: @hotel.Location</small>
                <p class="card-text">
                @hotel.ReviewText, <span class="text-success">@hotel.Score</span>
                </p>
              </div>
              <div class="mt-2 d-flex justify-content-end">
                Price from: <span class="text-warning">@hotel.Price VND</span>
              </div>
            </div>
          </div>
        </div>
    }
  </div>
</div>



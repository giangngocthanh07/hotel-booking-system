@code {
  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      // Gọi JS init carousel sau khi render xong lần đầu
      await JS.InvokeVoidAsync("initMultiCardCarousel");
    }
  }
}
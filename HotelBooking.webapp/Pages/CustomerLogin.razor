@page "/customer-login"

@inject IHttpClientFactory HttpClientFactory
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<!-- Bootstrap 5 pure HTML login page (no data classes/objects) -->
<div>
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="bg-white border rounded shadow-sm p-4">
                        <h2 class="mb-2">Đăng nhập</h2>

                        <EditForm Model="userLogin" OnValidSubmit="HandleValidSubmit" class="container mt-5">
                            <div class="mb-3">
                                <label for="inputUsernameEmail" class="form-label">Username Or Email:</label>
                                <input @bind="userLogin.UsernameOrEmail" type="text" class="form-control"
                                    id="inputEmail" placeholder="name@example.com" required>
                                <div class="invalid-feedback">
                                    Vui lòng nhập username hoặc email hợp lệ.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="inputPassword" class="form-label">Password</label>
                                <input @bind="userLogin.Password" type="password" class="form-control"
                                    id="inputPassword" placeholder="••••••••" required minlength="6">
                                <div class="invalid-feedback">
                                    Vui lòng nhập mật khẩu (tối thiểu 6 ký tự).
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="rememberCheck">
                                    <label class="form-check-label" for="rememberCheck">
                                        Ghi nhớ đăng nhập
                                    </label>
                                </div>
                                <a href="#" class="small">Quên mật khẩu?</a>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary">Đăng nhập</button>
                            </div>

                            <div class="text-center">
                                <small class="text-muted">Bạn chưa có tài khoản? <a href="/customer-register">Tạo tài
                                        khoản</a></small>
                            </div>
                        </EditForm>
                    </div>
                </div>

                <div class="text-center mt-3 small text-muted">
                    © Your Company
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private UserLoginVM userLogin = new UserLoginVM();
    private HttpClient _httpClient;
    protected override void OnInitialized()
    {
        _httpClient = HttpClientFactory.CreateClient("HotelBookingAPI");
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            // Handle login logic here
            // Call API Login
            var response = await _httpClient.PostAsJsonAsync("Accounts/login", userLogin);

            if (response.IsSuccessStatusCode)
            {
                var token = await response.Content.ReadAsStringAsync();
                // Lưu token vào local storage
                await localStorage.SetItemAsync("accessToken", token);
                // Chuyển hướng hoặc cập nhật giao diện người dùng sau khi đăng nhập thành công
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Login failed: {errorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during login: {ex.Message}");
        }
    }
}
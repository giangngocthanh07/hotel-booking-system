@layout MainLayout
@page "/Hotels"

<section class="hero-section position-relative min-vh-100">
    <div class="hero-bg">
        <img src="https://your-cdn-link/hero-banner.jpg" 
             alt="Hero Background" 
             class="w-100 vh-100 object-fit-cover" />
    </div>

    <div class="hero-overlay"></div>

    <div class="hero-title position-absolute top-50 start-50 translate-middle text-center text-white">
        <h1 class="fw-bold display-5">
            STAY 24-HOURS WITH 24/7 <br /> SELF-SERVICES
        </h1>
    </div>

    <SearchForm />
</section>

<section class="container my-5">
    <h2 class="text-center mb-5">Explore All Locations</h2>
    
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card hotel-card h-100 border-0 shadow-sm">
                <a href="/hotels/saigon-centre" class="text-decoration-none">
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=2070&auto=format&fit=crop"
                        class="card-img-top" alt="Saigon Centre">
                </a>
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <a href="/hotels/saigon-centre" class="text-decoration-none fw-bold text-dark">
                            Saigon Centre
                        </a>
                    </h5>
                    <p class="card-text text-uppercase fw-bold mb-1 small">
                        <i class="fa fa-bed me-1 text-warning"></i>237 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> HCMC
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        Wink Hotel Saigon Centre shares the neighborhood with new beer pubs, fusion restaurants,
                        boutique shops, and coffeehouses. Hip + historic.
                    </p>
                    <a href="/hotels/saigon-centre" class="details-link fw-bold text-decoration-none text-primary">
                        View Details <i class="fa fa-angle-right ms-1 details-icon"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card hotel-card h-100 border-0 shadow-sm">
                <a href="/hotels/danang-centre" class="text-decoration-none">
                    <img src="https://images.unsplash.com/photo-1611892440504-42a792e24d32?q=80&w=2070&auto=format&fit=crop"
                        class="card-img-top" alt="Danang Centre">
                </a>
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <a href="/hotels/danang-centre" class="text-decoration-none fw-bold text-dark">Danang Centre</a>
                    </h5>
                    <p class="card-text text-uppercase fw-bold mb-1 small">
                        <i class="fa fa-bed me-1 text-warning"></i>237 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> Da Nang
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        It’s a neighborhood hub designed for innovation, comfort and function - the perfect launch pad
                        for exploring.
                    </p>
                    <a href="/hotels/danang-centre" class="details-link fw-bold text-decoration-none text-primary">
                        View Details <i class="fa fa-angle-right ms-1 details-icon"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card hotel-card h-100 border-0 shadow-sm">
                <a href="/hotels/danang-riverside" class="text-decoration-none">
                    <img src="https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?q=80&w=2048&auto=format&fit=crop"
                        class="card-img-top" alt="Danang Riverside">
                </a>
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <a href="/hotels/danang-riverside" class="text-decoration-none fw-bold text-dark">Danang Riverside</a>
                    </h5>
                    <p class="card-text text-uppercase fw-bold mb-1 small">
                        <i class="fa fa-bed me-1 text-warning"></i>237 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> Da Nang
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        Wink Icon Danang Riverside is serenely settled into Vietnam's buzzing beach city. My Khe Beach is
                        five minutes away with beach bars, food trucks and vibrant seafood dining.
                    </p>
                    <a href="/hotels/danang-riverside" class="details-link fw-bold text-decoration-none text-primary">
                        View Details <i class="fa fa-angle-right ms-1 details-icon"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card hotel-card h-100 border-0 shadow-sm">
                <a href="/hotels/tuy-hoa-beach" class="text-decoration-none">
                    <img src="https://images.unsplash.com/photo-1445019980597-93fa8acb246c?q=80&w=2074&auto=format&fit=crop"
                        class="card-img-top" alt="Nha Trang">
                </a>
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <a href="/hotels/tuy-hoa-beach" class="text-decoration-none fw-bold text-dark">Nha Trang</a>
                    </h5>
                    <p class="card-text text-uppercase fw-bold mb-1 small">
                        <i class="fa fa-bed me-1 text-warning"></i>237 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> Nha Trang
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        Dive into Tuy Hoa, a coastal city with breathtaking natural beauty. Breathe in this
                        undiscovered destination, nestled between Quy Nhon and Nha Trang.
                    </p>
                    <a href="/hotels/tuy-hoa-beach" class="details-link fw-bold text-decoration-none text-primary">
                        View Details <i class="fa fa-angle-right ms-1 details-icon"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card hotel-card h-100 border-0 shadow-sm">
                <a href="/hotels/can-tho" class="text-decoration-none">
                    <img src="https://images.unsplash.com/photo-1564501046972-82a8e35d691a?q=80&w=2070&auto=format&fit=crop"
                        class="card-img-top" alt="Can Tho">
                </a>
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <a href="/hotels/can-tho" class="text-decoration-none fw-bold text-dark">Can Tho</a>
                    </h5>
                    <p class="card-text text-uppercase fw-bold mb-1 small">
                        <i class="fa fa-bed me-1 text-warning"></i>237 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> Can Tho
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        Can Tho, the lively heart of the Mekong Delta, is on the rise. Wink serves as your 
                        perfect launchpad, just a stone's throw from the lush waterfront landscape.
                    </p>
                    <a href="/hotels/can-tho" class="details-link fw-bold text-decoration-none text-primary">
                        View Details <i class="fa fa-angle-right ms-1 details-icon"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card hotel-card h-100 border-0 shadow-sm">
                <a href="/hotels/hai-phong" class="text-decoration-none">
                    <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?q=80&w=2070&auto=format&fit=crop"
                        class="card-img-top" alt="Hai Phong">
                </a>
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <a href="/hotels/hai-phong" class="text-decoration-none fw-bold text-dark">Hai Phong</a>
                    </h5>
                    <p class="card-text text-uppercase fw-bold mb-1 small">
                        <i class="fa fa-bed me-1 text-warning"></i>237 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> Hai Phong
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        Explore Hai Phong, northern Vietnam's historic port city. Roam the old quarters for vintage charm, 
                        then discover modern districts with sleek hotels and chic cafes.
                    </p>
                    <a href="/hotels/hai-phong" class="details-link fw-bold text-decoration-none text-primary">
                        View Details <i class="fa fa-angle-right ms-1 details-icon"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center my-5">
        <h3 class="fw-bold">COMING SOON</h3>
    </div>
    
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card hotel-card coming-soon border-0 shadow-sm opacity-75">
                <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?q=80&w=2070&auto=format&fit=crop"
                    class="card-img-top" alt="Hanoi">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Hanoi</h5>
                    <p class="card-text text-uppercase fw-bold small">
                        <i class="fa fa-bed me-1 text-warning"></i>400 ROOMS
                        <span class="ms-3">
                            <i class="fa fa-location-dot me-1 text-danger"></i> Hanoi
                        </span>
                    </p>
                    <p class="card-text card-desc text-muted small">
                        Scheduled to open in mid-2026, Wink Hotel Hanoi will introduce a fresh and 
                        dynamic presence to the capital city's hospitality landscape.
                    </p>
                    <span class="badge bg-warning text-dark">Opening Soon</span>
                </div>
            </div>
        </div>
    </div>
</section>
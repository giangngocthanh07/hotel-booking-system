@page "/hotel/register"
@inject NavigationManager NavigationManager

<div class="container mt-4">

    <h3>Register Hotel</h3>

    <!-- Step 1 lớn -->
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5>Step 1: Property details</h5>
                <p>The basics: name, address, amenities, policies, images.</p>
            </div>
            <div>
                @if (propertyCompleted)
                {
                    <span class="badge bg-success me-2">✔ Completed</span>
                }
                <button class="btn btn-primary me-2" @onclick="() => EditBigStep(1)">Edit</button>
                <button class="btn btn-danger">Delete</button>
            </div>
        </div>
    </div>

    <!-- Step 2 lớn -->
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5>Step 2: Rooms</h5>
                <p>Define room types, amenities, images, rooms.</p>
            </div>
            <div>
                @if (roomsCompleted)
                {
                    <span class="badge bg-success me-2">✔ Completed</span>
                }
                <button class="btn btn-primary me-2" @onclick="() => EditBigStep(2)">Edit</button>
                <button class="btn btn-danger">Delete</button>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button class="btn btn-success" disabled="@(propertyCompleted && roomsCompleted ? false : true)">
            Submit Hotel
        </button>
    </div>
</div>

@code {
    bool propertyCompleted = false;
    bool roomsCompleted = false;

    void EditBigStep(int step)
    {
        if (step == 1)
            NavigationManager.NavigateTo("/hotel/property-wizard");
        else
            NavigationManager.NavigateTo("/hotel/rooms-wizard");
    }
}
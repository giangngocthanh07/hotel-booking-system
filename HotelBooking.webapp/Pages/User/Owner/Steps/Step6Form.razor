@code {
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnPrev { get; set; }
}

<div class="card p-3">
    <h5>Step 6: Room Amenities</h5>

    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wifi" />
        <label class="form-check-label" for="wifi">Free WiFi</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="tv" />
        <label class="form-check-label" for="tv">Flat-screen TV</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="ac" />
        <label class="form-check-label" for="ac">Air Conditioning</label>
    </div>

    <div class="d-flex justify-content-between mt-3">
        @if (OnPrev.HasDelegate)
        {
            <button class="btn btn-secondary" @onclick="OnPrev">← Back</button>
        }
        <button class="btn btn-primary" @onclick="OnNext">Next →</button>
    </div>
</div>

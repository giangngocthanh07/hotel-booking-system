@page "/hotel-wizard"
@using HotelBooking.webapp.Services
@inject IHttpClientFactory _httpClientFactory
@inject HotelFormState FormState
@inject ISnackbar Snackbar
@inject Blazored.LocalStorage.ILocalStorageService localStorage

@layout OwnerLayout

<MudPaper Class="pa-4 mt-4" Style="max-width:900px;margin:auto;">
    <MudStepper @bind-ActiveIndex="_activeStep">
        <ChildContent>
            <MudStep Title="Basic Info" SecondaryText="Basic Information" />
            <MudStep Title="Amenities" SecondaryText="Amenities &amp; Facilities" />
            <MudStep Title="Policies" SecondaryText="Hotel Policies" />
            <MudStep Title="Images" SecondaryText="Hotel Photos" />
        </ChildContent>
        <ActionContent Context="stepper">
            <!-- Navigation buttons go here -->
            <!-- Previous button -->
            <!-- Next / Complete button -->
            <!-- Reset button -->
            <!-- Show Reset button on all steps -->
        </ActionContent>
    </MudStepper>

    <EditForm Model="@FormState" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="mt-4">
            @if (_activeStep == 0)
            {
                <StepBasicInfo />
            }
            else if (_activeStep == 1)
            {
                <StepAmenities />
            }
            else if (_activeStep == 2)
            {
                <StepPolicies />
            }
            else if (_activeStep == 3)
            {
                <StepImages />
            }
        </div>

        <!-- Navigation controls -->
        <div class="d-flex justify-content-between mt-4">
            <MudButton Variant="Variant.Outlined" Disabled="@(_activeStep == 0)" OnClick="PrevStep">
                PREVIOUS
            </MudButton>

            <div>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="HandleReset" Class="me-2">
                    <MudIcon Icon="@Icons.Material.Filled.Restore" /> RESET
                </MudButton>

                @if (_activeStep < 3)
                {
                    <MudButton Variant="Variant.Filled" OnClick="NextStep">
                        NEXT
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">
                        COMPLETE
                    </MudButton>
                }
            </div>
        </div>
    </EditForm>
</MudPaper>

@code {
    private MudStepper? _stepper;
    private int _index;
    private int _activeStep = 0;
    HttpClient? _httpClient;

    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");
        // Call API to load the list of amenities
        await FormState.LoadAmenitiesAsync();
        // Only call API if the city list is empty



        // Call API to load all PolicyTypes (Cancellation, Check-in, Check-out)
        
    }

    private void NextStep()
    {
        // Validate each step before proceeding to Next
        bool valid = _activeStep switch
        {
            0 => FormState.ValidateBasicInfo(),
            1 => FormState.ValidateAmenities(),
            2 => FormState.ValidatePolicy(),
            3 => FormState.ValidateImages(),
            _ => true
        };

        if (valid && _activeStep < 3)
        {
            _activeStep++;
            // Console.WriteLine($"CheckInId={FormState.SelectedCheckInId}, CheckOutId={FormState.SelectedCheckOutId}, CancelId={FormState.SelectedCancellationId}"); 
        }
        else
        {
            Snackbar.Add("Please review the information!", Severity.Error);
            // Console.WriteLine($"CheckInId={FormState.SelectedCheckInId}, CheckOutId={FormState.SelectedCheckOutId}, CancelId={FormState.SelectedCancellationId}");
        }
    }

    private void PrevStep()
    {
        if (_activeStep > 0)
            _activeStep--;
    }

    private void HandleReset()
    {
        FormState.Reset();
        _activeStep = 0;
        Snackbar.Add("Form has been reset", Severity.Info);
    }

    private async Task HandleSubmit()
    {
        if (FormState.ValidateAll())
        {
            

            _isSubmitting = true;
            bool success = await FormState.Submit();

            _isSubmitting = false;

            // 
            if (success)
            {
                Snackbar.Add("Submitted successfully!", Severity.Success);
                FormState.Reset();
                _activeStep = 0;
            }
            else
            {
                Snackbar.Add("An error occurred. Please try again!", Severity.Error);
            }
        }
        else
        {
            Snackbar.Add("Please review the information!", Severity.Error);
        }

        
    }
}
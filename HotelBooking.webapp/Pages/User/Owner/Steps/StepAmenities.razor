@using HotelBooking.webapp.Services
@inject HotelFormState FormState

<MudForm @ref="_form" Model="FormState.Amenities" Class="pa-2">
    <MudText Typo="Typo.h6" Class="mb-3">Select amenities for your hotel:</MudText>

    @if (!FormState.Amenities.Any())
    {
        <MudText Color="Color.Warning">No amenities found. Please contact the administrator.</MudText>
    }
    else
    {
        <!-- Display amenities list as checkboxes -->
        @foreach (var amenity in FormState.Amenities)
        {
            <MudCheckBox T="bool" @bind-Value="amenity.IsSelected" Label="@amenity.Name" />
        }
    }

    @if (!FormState.ValidateAmenities())
    {
        <MudText Color="Color.Error">Please select at least 1 amenity</MudText>
    }

</MudForm>

@code {
    public MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        FormState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        FormState.OnChange -= StateHasChanged;
    }

    public class AmenityVM
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";

    // Used for UI selection
        public bool IsSelected { get; set; } = false;
    }
}
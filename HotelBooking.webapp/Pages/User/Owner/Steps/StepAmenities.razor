@using HotelBooking.webapp.Services
@inject HotelFormState FormState

<MudForm @ref="_form" Model="FormState.Amenities" Class="pa-2">
    <MudText Typo="Typo.h6" Class="mb-3">Chọn các tiện ích (Amenities) cho khách sạn của bạn:</MudText>

    @if (!FormState.Amenities.Any())
    {
        <MudText Color="Color.Warning">Không có tiện ích nào. Vui lòng liên hệ quản trị viên.</MudText>
    }
    else
    {
        <!-- Hiển thị danh sách amenities dưới dạng checkbox -->
        @foreach (var amenity in FormState.Amenities)
        {
            <MudCheckBox T="bool" @bind-Value="amenity.IsSelected" Label="@amenity.Name" />
        }
    }

    @if (!FormState.ValidateAmenities())
    {
        <MudText Color="Color.Error">Vui lòng chọn ít nhất 1 tiện ích</MudText>
    }

</MudForm>

@code {
    public MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        FormState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        FormState.OnChange -= StateHasChanged;
    }

    public class AmenityVM
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";

        // Dùng cho UI chọn
        public bool IsSelected { get; set; } = false;
    }
}
@using HotelBooking.webapp.Services
@using ZstdSharp.Unsafe
@inject HotelFormState FormState

<MudForm @ref="_form" Model="FormState.BasicInfo" Class="pa-2">
    <!-- Hotel Name -->
    <MudTextField @bind-Value="FormState.BasicInfo.Name" Label="Hotel Name" For="@(() => FormState.BasicInfo.Name)"
        Required="true" Class="mb-3" />

    <!-- City -->
    <MudSelect T="int" Label="City" Variant="Variant.Outlined" @bind-Value="FormState.BasicInfo.CityId"
        For="@(() => FormState.BasicInfo.CityId)" Required="true" Class="mb-3">

        <MudSelectItem T="int" Value="0">Please select a city</MudSelectItem>

        @foreach (var city in FormState.BasicInfo.Cities)
        {
            <MudSelectItem T="int" Value="city.Id">@city.Name</MudSelectItem>
        }
    </MudSelect>

    <!--- Address: only shown when a City has been selected -->
    @if (FormState.BasicInfo.CityId > 0)
    {
        <MudTextField @bind-Value="FormState.BasicInfo.Address" Label="Address" For="@(() => FormState.BasicInfo.Address)"
            Required="true" Class="mb-3" />
    }

    <!-- Description -->
    <MudTextField @bind-Value="FormState.BasicInfo.Description" Label="Description"
        For="@(() => FormState.BasicInfo.Description)" Lines="3" Class="mb-3" />

    <!-- Cover Image Upload -->

    @if (FormState.BasicInfo.CoverFile == null)
    {
        <MudPaper Class="pa-2 mb-3" Style="background:#FFF3CD; color:#856404; border:1px solid #ffeeba; border-radius:6px;">
            Please select <b>1 cover photo</b> for the hotel
        </MudPaper>

        <InputFile OnChange="HandleFileSelected" accept="image/*" Class="mb-3" />
    }
    else
    {
        <div style="position:relative; display:inline-block; margin-top:10px; width:200px; aspect-ratio:4/3;">
            <MudTooltip Text="@($"{FormState.BasicInfo.CoverImageName} - {FormState.BasicInfo.CoverImageSize} KB")">
                <img src="@FormState.BasicInfo.CoverImagePreviewUrl"
                    style="width:100%; height:100%; object-fit:cover; border-radius:8px; border:2px solid #ddd;" />
            </MudTooltip>

            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                Style="position:absolute; top:4px; right:4px; background:#fff; border-radius:50%; z-index:10;"
                OnClick="@(() => RemoveCoverImage(FormState.BasicInfo.CoverFile))" />
        </div>
    }
</MudForm>

@code {

    public MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        FormState.OnChange += StateHasChanged;

        // Only call API if the city list is empty
        if (FormState.BasicInfo.Cities == null || !FormState.BasicInfo.Cities.Any())
        {
            // Call the method in FormState to load data
            await FormState.LoadCitiesAsync();
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            FormState.BasicInfo.CoverImageName = file.Name;
            FormState.BasicInfo.CoverImageSize = file.Size / 1024;


            // 1. Initialize the object
            FormState.BasicInfo.CoverFile = new UploadFileVM
            {
                FileName = file.Name,
                Size = file.Size,
                ContentType = file.ContentType
            };

            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var ms = new MemoryStream();

            await stream.CopyToAsync(ms);

            ms.Position = 0;

            // Save the original file to be sent to the backend on submit

            FormState.BasicInfo.CoverFile.Content = ms;

            // 4. Generate Base64 string for preview display
            var bytes = ms.ToArray();
            FormState.BasicInfo.CoverImagePreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";


            ;
        }
    }

    private void RemoveCoverImage(UploadFileVM? file)
    {
        FormState.BasicInfo.CoverImageName = null;
        FormState.BasicInfo.CoverImageSize = 0;

        FormState.BasicInfo.CoverImagePreviewUrl = null;

        // Remove both preview and original file
        FormState.BasicInfo.CoverFile = null;

    }

    public void Dispose()
    {
        FormState.OnChange -= StateHasChanged;
    }

    public class HotelVM
    {
        [Required(ErrorMessage = "Please enter the hotel name!")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Please enter the address!")]
        [MinLength(10, ErrorMessage = "Address must be at least 10 characters!")]
        public string Address { get; set; } = "";

        [Required(ErrorMessage = "Please select a city!")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select a city!")]
        public int CityId { get; set; } = 0; // Stores ID

        // Source list
        public List<CityVM> Cities { get; set; } = new();

        [MinLength(20, ErrorMessage = "Description must be at least 20 characters!")]
        public string Description { get; set; } = "";

        [Required(ErrorMessage = "Please select a valid cover photo!")]
        public UploadFileVM? CoverFile { get; set; }

        public string? CoverImageName { get; set; }
        public long CoverImageSize { get; set; }
        public string? CoverImagePreviewUrl { get; set; }
    }

    public class CityVM
    {
        public int Id { get; set; }
        public string Name { get; set; }
        public bool IsSelected { get; set; } = false;
    }
}
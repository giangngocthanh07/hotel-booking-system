@code {
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnPrev { get; set; }
}

<div class="card p-3">
    <h5>Step 5: Room Type</h5>
    <select class="form-select mb-2">
        <option>Standard</option>
        <option>Deluxe</option>
        <option>Suite</option>
    </select>
    <input type="number" class="form-control mb-2" placeholder="Price per night" />
    <input type="number" class="form-control mb-2" placeholder="Capacity" />
    <textarea class="form-control mb-2" placeholder="Description"></textarea>

    <div class="d-flex justify-content-between">
        @if (OnPrev.HasDelegate)
        {
            <button class="btn btn-secondary" @onclick="OnPrev">← Back</button>
        }
        <button class="btn btn-primary" @onclick="OnNext">Next →</button>
    </div>
</div>
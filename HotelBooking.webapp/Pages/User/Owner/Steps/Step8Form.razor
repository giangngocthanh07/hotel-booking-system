@code {
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnPrev { get; set; }

    List<RoomDto> rooms = new();
    string newRoomNumber = "";
    bool isAvailable = false;

    void AddRoom()
    {
        rooms.Add(new RoomDto { RoomNumber = newRoomNumber, IsAvailable = isAvailable });
        newRoomNumber = "";
        isAvailable = false;
    }

    public class RoomDto
    {
        public string RoomNumber { get; set; } = "";
        public bool IsAvailable { get; set; }
    }
}

<div class="card p-3">
    <h5>Step 8: Add Rooms</h5>
    <div class="input-group mb-2">
        <input class="form-control" placeholder="Room number" @bind="newRoomNumber" />
        <div class="input-group-text">
            <input type="checkbox" @bind="isAvailable" /> Available
        </div>
        <button class="btn btn-success" @onclick="AddRoom">Add</button>
    </div>

    <ul class="list-group">
        @foreach (var r in rooms)
        {
            <li class="list-group-item">@r.RoomNumber - @(r.IsAvailable ? "Available" : "Not Available")</li>
        }
    </ul>

    <div class="d-flex justify-content-between mt-3">
        @if (OnPrev.HasDelegate)
        {
            <button class="btn btn-secondary" @onclick="OnPrev">← Back</button>
        }
        <button class="btn btn-primary" @onclick="OnNext">Finish</button>
    </div>
</div>
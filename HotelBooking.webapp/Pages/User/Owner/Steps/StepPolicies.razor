@* @using HotelBooking.webapp.Services
@inject HotelFormState FormState

<MudForm @ref="_form" Class="pa-2">

    <!-- Check-in Policy -->

    <InputSelect @bind-Value="FormState.SelectedCheckInId" class="form-select">

        <option value="">-- Chọn Check-in Policy --</option>
        @foreach (var policy in CheckInPolicies)
        {
            <option value="@policy.Id">@policy.Name</option>
        }
    </InputSelect>

    <!-- Check-out Policy -->

    <InputSelect @bind-Value="FormState.SelectedCheckOutId" class="form-select">
        <option value="">-- Chọn Check-out Policy --</option>
        @foreach (var policy in CheckOutPolicies)
        {
            <option value="@policy.Id">@policy.Name</option>
        }
    </InputSelect>

    <!-- Cancellation Policy -->

    <InputSelect @bind-Value="FormState.SelectedCancellationId" class="form-select">
        <option value="">-- Chọn Cancellation Policy --</option>
        @foreach (var policy in CancellationPolicies)
        {
            <option value="@policy.Id">@policy.Name</option>
        }
    </InputSelect>

    @if (!FormState.SelectedPolicyIds.Any())
    {
        <MudText Color="Color.Error">Vui lòng chọn ít nhất 1 policy</MudText>
    }
</MudForm>


@code {
    public MudForm? _form;
    public List<PolicyVM> CheckInPolicies { get; set; } = new();
    public List<PolicyVM> CheckOutPolicies { get; set; } = new();
    public List<PolicyVM> CancellationPolicies { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var allTypes = await FormState.LoadAllPolicyTypesWithPoliciesAsync();

        var checkInType = allTypes.FirstOrDefault(t => t.Id == 2);
        if (checkInType != null)
            CheckInPolicies = checkInType.Policies;
            Console.WriteLine($"CheckInPolicies count={CheckInPolicies.Count}, first={CheckInPolicies.FirstOrDefault()?.Name}, id={CheckInPolicies.FirstOrDefault()?.Id}");

        var checkOutType = allTypes.FirstOrDefault(t => t.Id == 3);
        if (checkOutType != null)
            CheckOutPolicies = checkOutType.Policies;
            Console.WriteLine($"CheckOutPolicies count={CheckOutPolicies.Count}, first={CheckOutPolicies.FirstOrDefault()?.Name}, id={CheckOutPolicies.FirstOrDefault()?.Id}");

        var cancellationType = allTypes.FirstOrDefault(t => t.Id == 1);
        if (cancellationType != null)
            CancellationPolicies = cancellationType.Policies;
            Console.WriteLine($"CancellationPolicies count={CancellationPolicies.Count}, first={CancellationPolicies.FirstOrDefault()?.Name}, id={CancellationPolicies.FirstOrDefault()?.Id}");

        FormState.OnChange += StateHasChanged;
    } 

    public void OnStateChange()
    {
        InvokeAsync(StateHasChanged);
    }
    public void Dispose()
    {
        FormState.OnChange -= StateHasChanged;
    }


    public class PolicyTypeWithPoliciesVM
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public List<PolicyVM> Policies { get; set; } = new();
    }

    public class PolicyVM
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
} *@
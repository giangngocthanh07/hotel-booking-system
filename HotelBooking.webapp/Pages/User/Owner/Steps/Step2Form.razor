
<div class="card p-3">
    <h5>Step 2: Hotel Amenities</h5>

    <div class="form-check">
        <input type="checkbox" class="form-check-input" @bind="amenities.HasWifi" /> Wifi
    </div>
    <div class="form-check">
        <input type="checkbox" class="form-check-input" @bind="amenities.HasParking" /> Parking
    </div>
    <div class="form-check">
        <input type="checkbox" class="form-check-input" @bind="amenities.HasPool" /> Pool
    </div>

    <div class="d-flex justify-content-between mt-3">
        @if (OnPrev.HasDelegate)
        {
            <button class="btn btn-secondary" @onclick="OnPrev">← Back</button>
        }
        <button class="btn btn-primary" @onclick="Save">Next →</button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnPrev { get; set; }

    AmenityDto amenities = new();
    void Save() => OnNext.InvokeAsync();

    public class AmenityDto
    {
        public bool HasWifi { get; set; }
        public bool HasParking { get; set; }
        public bool HasPool { get; set; }
    }
}

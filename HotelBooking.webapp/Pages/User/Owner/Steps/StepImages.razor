@using HotelBooking.webapp.Services
@inject HotelFormState FormState


<MudForm @ref="_form" Model="FormState.HotelImages" Class="pa-2">
    <MudPaper Class="pa-2 mb-3" Style="background:#FFF3CD; color:#856404; border:1px solid #ffeeba; border-radius:6px;">
        Hãy chọn <b>5 ảnh</b> cho khách sạn của bạn
    </MudPaper>

    <InputFile OnChange="HandleFiles" multiple accept="image/*" Class="mb-3" />

    <MudText Class="mb-3">Uploaded: @( (FormState.HotelImages.MainFile != null ? 1 : 0) +
                FormState.HotelImages.SubFiles.Count ) / 5 ảnh
    </MudText>

    @if (FormState.HotelImages.MainFile != null)
    {
        <MudGrid Class="mt-3">
            <!-- Main photo -->
            <MudItem xs="12" sm="6">
                <div style="width:100%; position:relative;">
                    <img src="@FormState.HotelImages.MainImagePreviewUrl"
                        style="width:100%;height:250px;object-fit:cover; border-radius:8px;border:3px solid blue;" />

                    <span
                        style="position:absolute;bottom:6px;left:6px; background:blue;color:#fff;
                                                                                                                                             padding:3px 8px; border-radius:4px;font-size:12px;">
                        Main Photo
                    </span>

                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                        Style="position:absolute;top:6px;right:6px; background:#fff;
                                                                                                                                                      border-radius:50%;z-index:10;" OnClick="RemoveMain" />
                </div>
            </MudItem>

            <!-- Sub photos -->
            <MudItem xs="12" sm="6">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    @for (int i = 0; i < FormState.HotelImages.SubImagesPreviewUrl.Count; i++)
                    {
                        var idx = i;
                        <div style="position:relative;cursor:pointer;">
                            <img src="@FormState.HotelImages.SubImagesPreviewUrl[idx]"
                                style="width:100%;height:120px;object-fit:cover; border-radius:6px;border:2px solid #ddd;" />

                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                Style="position:absolute;top:4px;right:4px; background:#fff;
                                                                                                                                                                                                                                                                          border-radius:50%;z-index:10;"
                                OnClick="@(() => RemoveSub(idx))" />

                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                Style="position:absolute;bottom:6px;left:6px;z-index:10;" OnClick="@(() => SetMainPhoto(idx))">
                                Set Main
                            </MudButton>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>
    }
</MudForm>

@code {
    public MudForm? _form;

    private async Task HandleFiles(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(5);

        foreach (var file in files)
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var ms = new MemoryStream();

            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var newUpload = new UploadFileVM
            {
                FileName = file.Name,
                Size = file.Size,
                ContentType = file.ContentType,
                Content = ms
            };

            var Preview = $"data:{newUpload.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";

            if (FormState.HotelImages.MainFile == null)
            {
                FormState.HotelImages.MainFile = newUpload;
                FormState.HotelImages.MainImagePreviewUrl = Preview;
            }
            else
            {
                FormState.HotelImages.SubFiles.Add(newUpload);
                FormState.HotelImages.SubImagesPreviewUrl.Add(Preview);
            }
        }
    }

    private void SetMainPhoto(int subIndex)
    {
        if (subIndex < 0 || subIndex >= FormState.HotelImages.SubFiles.Count) return;

        // Lấy file/preview Main hiện tại ra
        var currentMainFile = FormState.HotelImages.MainFile;
        var currentMainPreview = FormState.HotelImages.MainImagePreviewUrl;

        // 1. Đặt Sub được chọn lên làm Main
        FormState.HotelImages.MainFile = FormState.HotelImages.SubFiles[subIndex];
        FormState.HotelImages.MainImagePreviewUrl = FormState.HotelImages.SubImagesPreviewUrl[subIndex];

        // 2. Xóa Sub đó khỏi danh sách Sub
        FormState.HotelImages.SubFiles.RemoveAt(subIndex);
        FormState.HotelImages.SubImagesPreviewUrl.RemoveAt(subIndex);

        // 3. Thêm Main cũ vào lại danh sách Sub (nếu Main cũ tồn tại)
        if (currentMainFile != null)
        {
            // Chèn vào đúng vị trí cũ của Sub
            FormState.HotelImages.SubFiles.Insert(subIndex, currentMainFile);
            FormState.HotelImages.SubImagesPreviewUrl.Insert(subIndex, currentMainPreview);
        }

        StateHasChanged();
    }

    private void RemoveMain()
    {
        // Nếu có ảnh Sub, đôn ảnh Sub đầu tiên lên làm Main
        if (FormState.HotelImages.SubFiles.Count > 0)
        {
            FormState.HotelImages.MainFile = FormState.HotelImages.SubFiles[0];
            FormState.HotelImages.MainImagePreviewUrl = FormState.HotelImages.SubImagesPreviewUrl[0];

            FormState.HotelImages.SubFiles.RemoveAt(0);
            FormState.HotelImages.SubImagesPreviewUrl.RemoveAt(0);
        }
        else
        {
            // Nếu không còn Sub, chỉ cần xóa Main
            FormState.HotelImages.MainFile = null;
            FormState.HotelImages.MainImagePreviewUrl = null;
        }

        StateHasChanged();
    }

    private void RemoveSub(int index)
    {
        if (index < 0 || index >= FormState.HotelImages.SubFiles.Count) return;
        FormState.HotelImages.SubFiles.RemoveAt(index);
        FormState.HotelImages.SubImagesPreviewUrl.RemoveAt(index);

        StateHasChanged();
    }

    public class HotelImagesVM
    {
        public UploadFileVM MainFile { get; set; }
        public List<UploadFileVM> SubFiles { get; set; } = new();
        public string MainImagePreviewUrl { get; set; }
        public List<string> SubImagesPreviewUrl { get; set; } = new();
    }
}
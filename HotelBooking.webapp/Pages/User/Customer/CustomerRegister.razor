@page "/customer-register"

@* Add Service http client *@
@inject IHttpClientFactory HttpClientFactory;
@inject NavigationManager _navManager;
@inject MudBlazor.ISnackbar Snackbar;

@using System.Net.Http.Json
@using System.Text.Json
@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.ViewModels
@using MudBlazor

<PageTitle>Create Account - Hotel Booking</PageTitle>

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="bg-white border rounded shadow-sm p-4">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-2">Create Account</h2>
                        <h6 class="fw-normal text-secondary mb-2">Book your hotel with ease</h6>
                        <p class="text-muted mb-0">
                            <i class="bi bi-star-fill text-warning me-1"></i>
                            Join us to experience the best booking services tailored for you.
                            <i class="bi bi-star-fill text-warning ms-1"></i>
                        </p>
                    </div>

                    <EditForm Model="@userRegister" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(messageAlert))
                        {
                            <div class="alert @(isError ? "alert-danger" : "alert-success") animate__animated animate__fadeIn"
                                 role="alert">
                                @messageAlert
                            </div>
                        }

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="username" class="form-label fw-bold small">Username</label>
                                <InputText @bind-Value="userRegister.Username" class="form-control" id="username"
                                           placeholder="Enter username" />
                                <ValidationMessage For="@(() => userRegister.Username)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label for="email" class="form-label fw-bold small">Email</label>
                                <InputText @bind-Value="userRegister.Email" type="email" class="form-control" id="email"
                                           placeholder="example@domain.com" />
                                <ValidationMessage For="@(() => userRegister.Email)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label for="fullname" class="form-label fw-bold small">Full Name</label>
                                <InputText @bind-Value="userRegister.FullName" class="form-control" id="fullname"
                                           placeholder="John Doe" />
                                <ValidationMessage For="@(() => userRegister.FullName)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label for="phone" class="form-label fw-bold small">Phone Number</label>
                                <InputText @bind-Value="userRegister.PhoneNumber" class="form-control" id="phone"
                                           placeholder="e.g., +84..." />
                                <ValidationMessage For="@(() => userRegister.PhoneNumber)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label for="password" class="form-label fw-bold small">Password</label>
                                <InputText @bind-Value="userRegister.Password" type="password" class="form-control"
                                           id="password" placeholder="••••••••" />
                                <ValidationMessage For="@(() => userRegister.Password)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label for="confirmPassword" class="form-label fw-bold small">Confirm Password</label>
                                <InputText @bind-Value="userRegister.ConfirmPassword" type="password"
                                           class="form-control" id="confirmPassword" placeholder="••••••••" />
                                <ValidationMessage For="@(() => userRegister.ConfirmPassword)"
                                                   class="text-danger small" />
                            </div>
                        </div>

                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="receiveEmail"
                                   @bind="userRegister.ReceiveEmail">
                                <label class="form-check-label small" for="receiveEmail">
                                    Yes, I want to receive exclusive offers and news from Hotel Booking
                                </label>
                            </div>

                            <div class="form-check mb-3">
                                <InputCheckbox @bind-Value="userRegister.AgreeTerm" class="form-check-input"
                                               id="agreeTerm" />
                                <label class="form-check-label small" for="agreeTerm">
                                    I agree to the <a href="/terms" class="text-primary">Terms & Conditions</a>, <a
                                    href="/privacy" class="text-primary">Privacy Policy</a>, and Service Fees.
                                </label>
                                <ValidationMessage For="@(() => userRegister.AgreeTerm)" class="text-danger small" />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Sign Up</button>

                            <div class="text-center mt-3">
                                <small class="text-muted">Already have an account? <a href="/customer-login"
                                                                                          class="login-link">Sign In</a></small>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .login-link {
                text-decoration: none;
                font-weight: 600;
                transition: all 0.3s ease;
                color: #0d6efd;
            }

            .login-link:hover {
                color: #0a58ca;
                text-decoration: underline;
            }
        </style>

@code {
    private UserRegisterVM userRegister = new UserRegisterVM();
    private string messageAlert = "";
    private bool isError = false;

    private async Task HandleValidSubmit()
    {
        if (!userRegister.AgreeTerm)
        {
            isError = true;
            messageAlert = "You must agree to the Terms and Conditions.";
            Snackbar.Add(messageAlert, Severity.Warning);
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("HotelBookingAPI");
            var response = await client.PostAsJsonAsync("v1/authentication/register", new
            {
                Username = userRegister.Username,
                Email = userRegister.Email,
                Password = userRegister.Password,
                FullName = userRegister.FullName,
                PhoneNumber = userRegister.PhoneNumber,
                ReceiveEmail = userRegister.ReceiveEmail
            });

            if (response.IsSuccessStatusCode)
            {
                isError = false;
                messageAlert = "Account created successfully!";
                Snackbar.Add(messageAlert, Severity.Success);

                await Task.Delay(2000);
                _navManager.NavigateTo("/customer-login");
            }
            else
            {
                isError = true;
                var errorContent = await response.Content.ReadAsStringAsync();
                try
                {
                    var apiResp = JsonSerializer.Deserialize<ApiResponse<RegisterResponseVM>>(errorContent, new JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true
                    });
                    messageAlert = apiResp?.Message ?? "Registration failed. Please check your data.";
                }
                catch
                {
                    messageAlert = $"Error: {errorContent}";
                }
                Snackbar.Add(messageAlert, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            isError = true;
            messageAlert = $"A system error occurred: {ex.Message}";
            Snackbar.Add(messageAlert, Severity.Error);
        }
    }
}
@page "/upgrade-owner"
@attribute [Authorize(Roles = "Customer")]
@layout MainLayout
@inject IHttpClientFactory HttpClientFactory
@inject Blazored.LocalStorage.ILocalStorageService _localStorage
@inject MudBlazor.ISnackbar Snackbar
@inject NavigationManager NavigationManager

@using HotelBooking.webapp.Helpers.Common
@using MudBlazor
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Become a Partner - Hotel Booking</PageTitle>

@if (userInfo == null)
{
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="spinner-border text-primary me-2"></div>
        <span>Loading account information...</span>
    </div>
}
else if (userInfo.Content == null)
{
    <div class="container mt-5">
        <div class="alert alert-danger shadow-sm">
            <i class="fas fa-exclamation-circle me-2"></i>@userInfo.Message
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="bg-white border rounded shadow-sm p-4 animate__animated animate__fadeIn">
                        <h2 class="mb-2 fw-bold">Register for Partner Account</h2>
                        <h6 class="mb-3 fw-normal text-secondary">Become a partner and start listing your services</h6>
                        <p class="text-muted mb-4">Please verify your account information and provide your business address
                            and tax code to submit your upgrade request.</p>

                            @if (requestStatus != "None")
                            {
                                <div class="alert @GetStatusAlertClass(requestStatus) d-flex align-items-center shadow-sm"
                                     role="alert">
                                    <strong>Request Status:</strong>
                                    <span class="badge @GetStatusBadgeClass(requestStatus) ms-2 px-3 py-2">@requestStatus</span>
                                </div>
                            }

                            <EditForm Model="@requestModel" OnValidSubmit="HandleValidSubmit">
                                <DataAnnotationsValidator />

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase">Username</label>
                                        <input class="form-control bg-light text-muted" value="@userInfo.Content.UserName"
                                               readonly />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase">Full Name</label>
                                        <input class="form-control bg-light text-muted" value="@userInfo.Content.FullName"
                                               readonly />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase">Email Address</label>
                                        <input class="form-control bg-light text-muted" value="@userInfo.Content.Email"
                                               readonly />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase">Phone Number</label>
                                        <input class="form-control bg-light text-muted" value="@userInfo.Content.PhoneNumber"
                                               readonly />
                                    </div>
                                </div>

                                <div class="row g-3 mt-2">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Business Address</label>
                                        <InputText class="form-control shadow-sm" @bind-Value="requestModel.Address"
                                                   readonly="@isFormReadOnly" placeholder="Enter your business address" />
                                        <ValidationMessage For="@(() => requestModel.Address)" class="text-danger small" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Tax Code</label>
                                        <InputText class="form-control shadow-sm" @bind-Value="requestModel.TaxCode"
                                                   readonly="@isFormReadOnly" placeholder="Enter your business tax code" />
                                        <ValidationMessage For="@(() => requestModel.TaxCode)" class="text-danger small" />
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary w-100 mt-4 py-2 fw-bold shadow-sm"
                                        disabled="@isFormReadOnly">
                                    Submit Upgrade Request
                                </button>

                                @if (requestStatus == "Pending")
                                {
                                    <div class="alert alert-info mt-3 border-0 shadow-sm animate__animated animate__fadeInUp">
                                        <i class="fas fa-clock me-2"></i>Your request has been submitted and is awaiting admin
                                        approval.
                                    </div>
                                }
                                else if (requestStatus == "Approved")
                                {
                                    <div class="alert alert-success mt-3 border-0 shadow-sm">
                                        <i class="fas fa-check-circle me-2"></i>Congratulations! Your request has been approved. You
                                        are now a partner.
                                    </div>
                                }
                                else if (requestStatus == "Rejected")
                                {
                                    <div class="alert alert-warning mt-3 border-0 shadow-sm">
                                        <i class="fas fa-exclamation-triangle me-2"></i>Your request was rejected. Please review
                                        your information and try again.
                                    </div>
                                }
                            </EditForm>

                            @if (!string.IsNullOrEmpty(message))
                            {
                                <div class="alert @alertClass mt-3 shadow-sm">@message</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

@code {
    private ApiResponse<UserForUpgradeVM?>? userInfo;
    private CreateUpgradeRequestVM requestModel = new();
    private string message = "";
    private string alertClass = "alert-success";
    private HttpClient? _httpClient;
    private string requestStatus = "None";
    private bool isFormReadOnly = false;

    protected override async Task OnInitializedAsync()
    {
        _httpClient = HttpClientFactory.CreateClient("HotelBookingAPI");

        var token = await _localStorage.GetItemAsync<string>("accessToken");
        if (!string.IsNullOrEmpty(token))
        {
            _httpClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }

        try
        {
            userInfo = await _httpClient.GetFromJsonAsync<ApiResponse<UserForUpgradeVM?>>("v1/upgrade-requests/my-info");

            if (userInfo?.Content != null)
            {
                requestStatus = userInfo.Content.RequestStatus ?? "None";
                isFormReadOnly = requestStatus == "Pending" || requestStatus == "Approved";

                if (requestStatus == "Approved")
                {
                    NavigationManager.NavigateTo("/owner-dashboard");
                }
            }
            else
            {
                message = userInfo?.Message ?? "Unable to load user information.";
                alertClass = "alert-danger";
                requestStatus = "None";
            }
        }
        catch (Exception ex)
        {
            message = $"Error loading profile data: {ex.Message}";
            alertClass = "alert-danger";
        }
    }

    private async Task HandleValidSubmit()
    {
        var token = await _localStorage.GetItemAsync<string>("accessToken");
        if (string.IsNullOrEmpty(token))
        {
            message = "Authentication required. Please sign in.";
            alertClass = "alert-danger";
            Snackbar.Add(message, Severity.Error);
            return;
        }

        if (_httpClient == null)
        {
            message = "Critical error: HTTP client initialization failed.";
            alertClass = "alert-danger";
            Snackbar.Add(message, Severity.Error);
            return;
        }

        _httpClient.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        try
        {
            var response = await _httpClient.PostAsJsonAsync("v1/upgrade-requests/create-request", requestModel);
            var content = await response.Content.ReadAsStringAsync();

            try
            {
                var apiResp = JsonSerializer.Deserialize<ApiResponse<bool>>(content, new JsonSerializerOptions
                { PropertyNameCaseInsensitive = true });

                if (apiResp?.StatusCode == StatusCodeResponse.Success)
                {
                    alertClass = "alert-success";
                    requestStatus = "Pending";
                    isFormReadOnly = true;
                    message = apiResp.Message ?? "Request submitted successfully. Please wait for admin approval.";
                    Snackbar.Add(message, Severity.Success);
                }
                else
                {
                    message = apiResp?.Message ?? "Failed to submit request.";
                    alertClass = "alert-danger";
                    Snackbar.Add(message, Severity.Error);
                }
            }
            catch
            {
                message = content ?? "Unexpected error occurred.";
                alertClass = "alert-danger";
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            message = $"System Error: {ex.Message}";
            alertClass = "alert-danger";
            Snackbar.Add(message, Severity.Error);
        }
    }

    private string GetStatusAlertClass(string status) => status switch
    {
        "Pending" => "alert-info",
        "Approved" => "alert-success",
        "Rejected" => "alert-warning",
        _ => "alert-secondary"
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-info text-white",
        "Approved" => "bg-success text-white",
        "Rejected" => "bg-warning text-dark",
        _ => "bg-secondary text-white"
    };
}
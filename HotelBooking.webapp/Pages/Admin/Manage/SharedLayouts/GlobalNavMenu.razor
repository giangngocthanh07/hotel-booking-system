@* File: Components/Manage/GlobalNavMenu.razor *@
@using HotelBooking.webapp.Helpers
@using HotelBooking.webapp.Services
@using HotelBooking.webapp.ViewModels.Admin
@inject NavigationManager Nav
@inject IManagementService _manageService
@inject ILogger<GlobalNavMenu> Logger


@* 1. Module Selection Dropdown (Navigation) - Uses ManageModuleConstants *@
<div class="mb-3">
    <label class="form-label small fw-bold text-muted">Data Group</label>
    <select class="form-select" value="@CurrentModule" @onchange="OnModuleChanged">
        @foreach (var module in ManageModuleConstants.GetAll())
        {
            <option value="@module.Module.ToString()">@module.DisplayName</option>
        }
    </select>
</div>

@* 2. Type Selection Dropdown (Loaded via API) *@
@if (_types != null && _types.Any())
{
    <div class="mb-3">
        <label class="form-label small fw-bold text-muted">Category</label>
        <select class="form-select" value="@CurrentTypeId" @onchange="OnTypeChanged">
            @foreach (var t in _types)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
    </div>
}
else if (_isLoading)
{
    <div class="text-center small text-muted">
        <span class="spinner-border spinner-border-sm me-1"></span>Loading menu...
    </div>
}


@code {
    // --- PARAMETERS ---
    // Identifies the current location to highlight the correct options
    [Parameter] public string CurrentModule { get; set; } = "Service";
    [Parameter] public int? CurrentTypeId { get; set; }

    // --- STATE ---
    private List<ManageTypeVM>? _types;

    // Track previous module to prevent redundant API calls
    private string _prevModule = "";

    // State flags for lifecycle coordination
    private bool _isJsReady = false;
    private bool _isLoading = false;

    // --- LIFECYCLE ---
    protected override async Task OnInitializedAsync()
    {
    }

    // Safely trigger API calls once the rendering environment is ready
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isJsReady = true; // Mark JS runtime as ready
            await LoadMenuData(); // Initial load
            StateHasChanged();
        }
    }

    // Synchronize menu when parent parameters change (e.g., user clicks a different link)
    protected override async Task OnParametersSetAsync()
    {
        // Block execution if JS interop is not yet available
        if (!_isJsReady) return;

        // Only reload data if the module has actually changed
        if (CurrentModule != _prevModule)
        {
            _types = null;
            await LoadMenuData();
        }
    }

    private async Task LoadMenuData()
    {
        if (!_isJsReady) return;

        // Update tracking variable to prevent double loading
        _prevModule = CurrentModule;

        _isLoading = true;
        StateHasChanged();

        try
        {
            if (Enum.TryParse<ManageModuleEnum>(CurrentModule, out var moduleEnum))
            {
                var res = await _manageService.GetManageModuleTypesOnly(moduleEnum);
                if (res.StatusCode == StatusCodeResponse.Success)
                {
                    _types = res.Content?.Types;
                }
            }
            else
            {
                _types = new List<ManageTypeVM>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading navigation menu data");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // --- EVENT HANDLERS ---
    private void OnModuleChanged(ChangeEventArgs e)
    {
        var selectedModule = e.Value?.ToString();
        if (string.IsNullOrEmpty(selectedModule)) return;

        // Redirect to a different module (resets TypeId)
        // URL Pattern: /admin/manage/{Module}
        Nav.NavigateTo($"/admin/manage/{selectedModule.ToLower()}");
    }

    private void OnTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newTypeId))
        {
            // Redirect while keeping the same module, updating only the TypeId
            // URL Pattern: /admin/manage/{Module}/{TypeId}
            Nav.NavigateTo($"/admin/manage/{CurrentModule.ToLower()}/{newTypeId}");
        }
    }
}
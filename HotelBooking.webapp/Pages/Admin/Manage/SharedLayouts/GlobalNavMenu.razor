@* File: Components/Manage/GlobalNavMenu.razor *@
@using HotelBooking.webapp.Helpers
@inject NavigationManager Nav
@inject IManagementService _manageService
@inject ILogger<GlobalNavMenu> Logger


@* 1. Dropdown chọn Module (Chuyển trang) - Dùng ManageModuleConstants *@
<div class="mb-3">
    <label class="form-label small fw-bold text-muted">Nhóm dữ liệu</label>
    <select class="form-select" value="@CurrentModule" @onchange="OnModuleChanged">
        @foreach (var module in ManageModuleConstants.GetAll())
        {
            <option value="@module.Module.ToString()">@module.DisplayName</option>
        }
    </select>
</div>

@* 2. Dropdown chọn Type (Load từ API) *@
@if (_types != null && _types.Any())
{
    <div class="mb-3">
        <label class="form-label small fw-bold text-muted">Phân loại</label>
        <select class="form-select" value="@CurrentTypeId" @onchange="OnTypeChanged">
            @foreach (var t in _types)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
    </div>
}
else if (_isLoading)
{
    <div class="text-center small text-muted"><span class="spinner-border spinner-border-sm me-1"></span>Loading menu...
    </div>
}


@code {
    // --- PARAMETERS ---
    // Nhận vào để biết đang đứng ở đâu (để highlight đúng option)
    [Parameter] public string CurrentModule { get; set; } = "Service";
    [Parameter] public int? CurrentTypeId { get; set; }

    // --- STATE ---
    private List<ManageTypeVM>? _types;

    // Thêm biến để lưu Module cũ
    private string _prevModule = "";


    // Thêm biến cờ
    private bool _isJsReady = false;
    private bool _isLoading = false;

    // --- LIFECYCLE ---
    protected override async Task OnInitializedAsync()
    {

    }

    // 3. OnAfterRenderAsync: Nơi gọi API an toàn
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isJsReady = true; // Đánh dấu JS đã sẵn sàng
            await LoadMenuData(); // Load lần đầu
            StateHasChanged();
        }
    }

    // Khi tham số từ cha đổi (VD: User bấm link khác), menu cũng phải update theo
    protected override async Task OnParametersSetAsync()
    {
        // 1. Chặn nếu JS chưa sẵn sàng
        if (!_isJsReady) return;

        // Nếu module thay đổi thì mới load lại
        if (CurrentModule != _prevModule)
        {
            _types = null;
            await LoadMenuData();
        }
    }

    private async Task LoadMenuData()
    {
        // Nếu JS chưa sẵn sàng thì chặn ngay
        if (!_isJsReady) return;

        // Lưu lại vết lần đầu chạy (để tránh load 2 lần)
        _prevModule = CurrentModule;

        _isLoading = true;
        StateHasChanged();

        try
        {
            if (Enum.TryParse<ManageModuleEnum>(CurrentModule, out var moduleEnum))
            {
                var res = await _manageService.GetManageModuleTypesOnly(moduleEnum);
                if (res.StatusCode == StatusCodeResponse.Success)
                {
                    _types = res.Content?.Types;
                }
            }
            else
            {
                _types = new List<ManageTypeVM>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi load menu");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // --- EVENTS ---
    private void OnModuleChanged(ChangeEventArgs e)
    {
        var selectedModule = e.Value?.ToString();
        // Chuyển trang sang module khác (Reset TypeId)
        // URL Pattern: /admin/manage/{Module}
        Nav.NavigateTo($"/admin/manage/{selectedModule.ToLower()}");
    }

    private void OnTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newTypeId))
        {
            // Chuyển trang nhưng giữ nguyên module, chỉ đổi ID
            // URL Pattern: /admin/manage/{Module}/{TypeId}
            Nav.NavigateTo($"/admin/manage/{CurrentModule.ToLower()}/{newTypeId}");
        }
    }
}
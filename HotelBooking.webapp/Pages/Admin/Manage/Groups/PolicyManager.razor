    // ======================== LIFECYCLE ========================
    protected override async Task LoadDataAsync()
    {
        if (Disposed) return;
        _items = null;
        StateHasChanged();

        try
        {
            var res = await Service.GetPoliciesByType(TypeId, _paging);
            if (!Disposed && res.StatusCode == StatusCodeResponse.Success && res.Content != null)
            {
                _items = res.Content.Items;
                _totalPages = res.Content.TotalPages;
                _totalCount = res.Content.TotalCount;
            }
            else
            {
                _items = new List<PolicyVM>();
                if (res.StatusCode != StatusCodeResponse.Success) SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi load policy");
            _items = new List<PolicyVM>();
        }
        finally { if (!Disposed) StateHasChanged(); }
    }

    protected override void OnInitialized() => ResetForm();

    protected override async Task OnParametersSetAsync()
    {
        var effectiveTypeId = TypeId ?? 1002;
        if (effectiveTypeId != _previousTypeId)
        {
            _previousTypeId = effectiveTypeId;
            TypeId = effectiveTypeId;
            _paging.PageIndex = 1;
            ResetForm();
            if (IsJsReady) await LoadDataAsync();
        }
    }

    private async Task HandlePageChanged(int newPage) { _paging.PageIndex = newPage; await LoadDataAsync(); }

    // ======================== CRUD ========================
    private void OnEditItem(PolicyVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;
        _updateModel = PolicyHelper.MapToUpdateVM(item)!;
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(PolicyVM item)
    {
        var res = await Service.DeletePolicy(item.Id);
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        if (res.StatusCode == StatusCodeResponse.Success) await LoadDataAsync();
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;
        int currentTypeId = TypeId ?? 1002;

        _createModel = PolicyHelper.CreateNewPolicyModel(currentTypeId);
        _createModel.Name = "";
        _createModel.Description = "";

        _updateModel = currentTypeId switch
        {
            (int)PolicyTypeEnum.CheckInOut => new CheckInOutPolicyUpdateVM(),
            (int)PolicyTypeEnum.Cancellation => new CancellationPolicyUpdateVM(),
            (int)PolicyTypeEnum.Children => new ChildrenPolicyUpdateVM(),
            (int)PolicyTypeEnum.Pets => new PetPolicyUpdateVM(),
            _ => new CheckInOutPolicyUpdateVM()
        };

        PolicyHelper.ApplyDefaultValues(_createModel, currentTypeId);
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void SuggestDefaultValues()
    {
        int currentTypeId = TypeId ?? 1002;
        if (_isUpdate) PolicyHelper.ApplyDefaultValues(_updateModel, currentTypeId);
        else PolicyHelper.ApplyDefaultValues(_createModel, currentTypeId);
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        if (TypeId == 1004)
        {
            if (_createModel is ChildrenPolicyCreateVM cc && cc.MinAge > cc.MaxAge)
            { _snackbar.Add(MessageResponse.AdminManagement.Policy.INVALID_AGE_RANGE, Severity.Error); return; }
            if (_updateModel is ChildrenPolicyUpdateVM cu && cu.MinAge > cu.MaxAge)
            { _snackbar.Add(MessageResponse.AdminManagement.Policy.INVALID_AGE_RANGE, Severity.Error); return; }
        }

        ApiResponse<PolicyVM> res;
        if (_isUpdate) { res = await Service.UpdatePolicy(_currentEditingId, _updateModel); }
        else { _createModel.TypeId = TypeId ?? 1002; res = await Service.CreatePolicy(_createModel); }

        if (res.StatusCode == StatusCodeResponse.Success)
        { SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!); await LoadDataAsync(); ResetForm(); }
        else { SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!); }
    }
}
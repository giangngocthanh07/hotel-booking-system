@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.Helpers
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@page "/admin/manage/policy"
@page "/admin/manage/policy/{TypeId:int}"

@layout AdminLayout
@inject ILogger<PolicyManager> Logger
@inject ISnackbar _snackbar

@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Đang tải dữ liệu...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="PolicyVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items"
                        Model="@GetModel()"        PageIndex="_paging.PageIndex ?? 1" TotalPages="_totalPages" TotalCount="_totalCount"
                        OnPageChanged="HandlePageChanged"        OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem"
                        OnDelete="HandleDelete" OnCancel="ResetForm" OnNameBlur="SuggestDefaultValues">

        <SidebarTopContent>
            <GlobalNavMenu CurrentModule="Policy" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        <FormContent Context="m">
            @RenderPolicyForm()
            <div class="alert alert-info border-0 shadow-sm mt-3 py-2 small">
                <i class="fa-solid fa-circle-exclamation me-1"></i>
                <strong>Lưu ý:</strong> Đây là các giá trị mặc định. Chủ khách sạn có thể thay đổi lại khi áp dụng.
            </div>
        </FormContent>

        <TableHeader>
            <th class="text-center align-middle" style="width: 50px;">Id</th>
            <th class="text-center align-middle" style="width: 350px;">Tên chính sách</th>
            <th class="text-center align-middle" style="width: 100px;">Thông số cấu hình</th>
            <th class="text-center align-middle">Mô tả chi tiết</th>
        </TableHeader>

        <RowTemplate Context="row">
            <td class="text-center text-muted small">@row.Id</td>
            <td class="text-center align-middle">
                <div class="fw-bold text-dark">@row.Name</div>
            </td>
            <td class="text-center align-middle">
                <div class="d-flex justify-content-center">@RenderRowBadge(row)</div>
            </td>
            <td class="text-center align-middle">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {

                    <div class="text-muted small text-truncate mx-auto" style="max-width: 350px;" title="@row.Description">
                        @row.Description</div>
                    }
                </td>
            </RowTemplate>
        </MasterDetailLayout>
    }

@code {
    [Parameter] public int? TypeId { get; set; }

    private List<PolicyVM>? _items;
    private PolicyCreateVM _createModel = new CheckInOutPolicyCreateVM { TypeId = 1002 };
    private PolicyUpdateVM _updateModel = new CheckInOutPolicyUpdateVM();
    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;
    private int? _previousTypeId = null;
    private MasterDetailLayout<PolicyVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? _updateModel : _createModel;

    // ======================== RENDER FRAGMENTS ========================
    private RenderFragment RenderPolicyForm() => __builder =>
    {
        var typeId = TypeId ?? 1002;
        switch (typeId)
        {
            case 1002: RenderCheckInOutForm(__builder); break;
            case 1003: RenderCancellationForm(__builder); break;
            case 1004: RenderChildrenForm(__builder); break;
            case 2002: RenderPetForm(__builder); break;
        }
    };

    private void RenderCheckInOutForm(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder __builder)
    {
        // Get values based on mode
        TimeOnly? checkInTime = null;
        TimeOnly? checkOutTime = null;
        decimal earlyFee = 0;
        decimal lateFee = 0;

        if (_isUpdate && _updateModel is CheckInOutPolicyUpdateVM u)
        {
            checkInTime = u.CheckInTime;
            checkOutTime = u.CheckOutTime;
            earlyFee = u.EarlyCheckInFee ?? 0;
            lateFee = u.LateCheckOutFee ?? 0;
        }
        else if (_createModel is CheckInOutPolicyCreateVM c)
        {
            checkInTime = c.CheckInTime;
            checkOutTime = c.CheckOutTime;
            earlyFee = c.EarlyCheckInFee ?? 0;
            lateFee = c.LateCheckOutFee ?? 0;
        }

        bool hasFee = earlyFee > 0 || lateFee > 0;

        <h6 class="text-primary fw-bold mb-3"><i class="fa-regular fa-clock me-2"></i>Khung giờ & Phụ thu</h6>

        <div
            class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-3 shadow-sm">
            <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                <i class="fa-solid fa-hand-holding-dollar me-2 @(hasFee ? "text-success" : "text-secondary")"></i>
                @(hasFee ? "Tính phí phụ thu" : "Miễn phí")
            </label>
            <input class="form-check-input" type="checkbox" role="switch" checked="@hasFee"
                   @onchange="@(e => ToggleCheckInOutFee((bool)e.Value!))"
                   style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
            </div>

            @if (hasFee)
            {
                <div class="row g-3 mb-3 animate__animated animate__fadeInDown animate__faster">
                    <div class="col-6">
                        <label class="form-label fw-bold extra-small text-muted">Phí check-in sớm</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-success"><i class="fa-solid fa-sun"></i></span>
                            <input type="text" class="form-control text-end fw-bold text-success" inputmode="numeric"
                                   value="@earlyFee.ToString("N0")"                               @oninput="@(e => SetCheckInOutFee("early", e.Value?.ToString()))" />
                            <span class="input-group-text bg-light fw-bold">VNĐ</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold extra-small text-muted">Phí check-out muộn</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-warning"><i class="fa-solid fa-moon"></i></span>
                            <input type="text" class="form-control text-end fw-bold text-warning" inputmode="numeric"
                                   value="@lateFee.ToString("N0")"                               @oninput="@(e => SetCheckInOutFee("late", e.Value?.ToString()))" />
                            <span class="input-group-text bg-light fw-bold">VNĐ</span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-3">
                    <i class="fa-solid fa-circle-check me-2 fs-5"></i>
                    <div class="extra-small fst-italic"><b>Miễn phí:</b> Không thu thêm phí.</div>
                </div>
            }

            <h6 class="text-primary fw-bold mb-3"><i class="fa-regular fa-clock me-2"></i>Khung giờ chuẩn</h6>
            <div class="row g-3">
                <div class="col-6">
                    <label class="small text-muted fw-bold">Nhận phòng</label>
                    <input type="time" class="form-control shadow-sm" value="@checkInTime?.ToString("HH:mm")"
                           @onchange="@(e => SetCheckInOutTime("in", e.Value?.ToString()))" />
                </div>
                <div class="col-6">
                    <label class="small text-muted fw-bold">Trả phòng</label>
                    <input type="time" class="form-control shadow-sm" value="@checkOutTime?.ToString("HH:mm")"
                           @onchange="@(e => SetCheckInOutTime("out", e.Value?.ToString()))" />
                </div>
            </div>
        }

    private void RenderCancellationForm(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder __builder)
    {
        bool isRefundable = false;
        int? days = 0;
        double? refundPct = 0;

        if (_isUpdate && _updateModel is CancellationPolicyUpdateVM u)
        {
            isRefundable = u.IsRefundable;
            days = u.DaysBeforeCheckIn;
            refundPct = u.RefundPercent;
        }
        else if (_createModel is CancellationPolicyCreateVM c)
        {
            isRefundable = c.IsRefundable;
            days = c.DaysBeforeCheckIn;
            refundPct = c.RefundPercent;
        }

        <h6 class="text-danger fw-bold mb-3"><i class="fa-solid fa-ban me-2"></i>Chính sách hủy phòng</h6>

        <div
            class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-3 shadow-sm">
            <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                <i class="fa-solid fa-hand-holding-dollar me-2 @(isRefundable ? "text-success" : "text-danger")"></i>
                @(isRefundable ? "Có hoàn tiền" : "Non-Refundable")
            </label>
            <input class="form-check-input" type="checkbox" role="switch" checked="@isRefundable"
                   @onchange="@(e => SetCancellationRefundable((bool)e.Value!))"
                   style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
            </div>

            @if (isRefundable)
            {
                <div class="row g-3 animate__animated animate__fadeIn">
                    <div class="col-6">
                        <label class="small text-muted fw-bold">Hủy trước (ngày)</label>
                        <div class="input-group shadow-sm">
                            <input type="number" class="form-control text-center fw-bold" value="@days"
                                   @oninput="@(e => SetCancellationDays(e.Value?.ToString()))" />
                            <span class="input-group-text bg-primary text-white fw-bold">ngày</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="small text-muted fw-bold">Hoàn lại (%)</label>
                        <div class="input-group shadow-sm">
                            <input type="number" class="form-control text-center fw-bold text-success" value="@refundPct"
                                   @oninput="@(e => SetCancellationPercent(e.Value?.ToString()))" />
                            <span class="input-group-text bg-success text-white fw-bold">%</span>
                        </div>
                    </div>
                </div>
                <div class="p-3 rounded bg-light border-start border-4 border-success shadow-sm mt-3">
                    <div class="small fw-bold text-uppercase mb-1 text-muted">Diễn giải:</div>
                    <div class="small fst-italic">Nếu hủy trước <b>@days ngày</b>: Hoàn <b class="text-success">@refundPct%</b>.</div>
                </div>
            }
            else
            {
                <div class="alert alert-danger border-0 py-2 px-3 d-flex align-items-center shadow-sm">
                    <i class="fa-solid fa-ban me-2 fs-5"></i>
                    <div class="extra-small fst-italic"><b>Non-Refundable:</b> Không hoàn tiền khi hủy.</div>
                </div>
            }
        }

    private void RenderChildrenForm(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder __builder)
    {
        int minAge = 0, maxAge = 17;
        decimal extraBedFee = 0;

        if (_isUpdate && _updateModel is ChildrenPolicyUpdateVM u)
        {
            minAge = u.MinAge ?? 0;
            maxAge = u.MaxAge ?? 17;
            extraBedFee = u.ExtraBedFee ?? 0;
        }
        else if (_createModel is ChildrenPolicyCreateVM c)
        {
            minAge = c.MinAge ?? 0;
            maxAge = c.MaxAge ?? 17;
            extraBedFee = c.ExtraBedFee ?? 0;
        }

        bool hasFee = extraBedFee > 0;
        bool isInvalidRange = minAge > maxAge;

        <h6 class="text-success fw-bold mb-3"><i class="fa-solid fa-child-reaching me-2"></i>Trẻ em & Giường phụ</h6>

        <div class="row g-3">
            <div class="col-6">
                <label class="small text-muted fw-bold">Tuổi tối thiểu</label>
                <input type="number" class="form-control fw-bold shadow-sm @(isInvalidRange ? "border-danger" : "")"
                       value="@minAge" @oninput="@(e => SetChildrenAge("min", e.Value?.ToString()))" />
            </div>
            <div class="col-6">
                <label class="small text-muted fw-bold">Tuổi tối đa</label>
                <input type="number" class="form-control fw-bold shadow-sm @(isInvalidRange ? "border-danger" : "")"
                       value="@maxAge" @oninput="@(e => SetChildrenAge("max", e.Value?.ToString()))" />
            </div>

            @if (isInvalidRange)
            {
                <div class="col-12 animate__animated animate__shakeX">
                    <div class="alert alert-danger py-2 px-3 small fw-bold mb-0 shadow-sm"
                         style="border:none; border-left: 4px solid darkred;">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>Tuổi tối thiểu phải nhỏ hơn tối đa.
                    </div>
                </div>
            }

            <div class="col-12 mt-3">
                <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between shadow-sm">
                    <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                        <i class="fa-solid fa-bed me-2 @(hasFee ? "text-success" : "text-secondary")"></i>Phí giường phụ?
                    </label>
                    <input class="form-check-input" type="checkbox" role="switch" checked="@hasFee"
                           @onchange="@(e => ToggleChildrenFee((bool)e.Value!))"
                           style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>
                </div>

                @if (hasFee)
                {
                    <div class="col-12 animate__animated animate__fadeInDown animate__faster">
                        <label class="form-label fw-bold small text-muted text-uppercase">Phí giường phụ</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-success"><i class="fa-solid fa-money-bill-wave"></i></span>
                            <input type="text" class="form-control text-end fw-bold text-success" inputmode="numeric"
                                   value="@extraBedFee.ToString("N0")" @oninput="@(e => SetChildrenFee(e.Value?.ToString()))" />
                            <span class="input-group-text bg-light fw-bold">VNĐ</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="col-12 animate__animated animate__fadeIn">
                        <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0">
                            <i class="fa-solid fa-face-laugh-beam me-2 fs-5"></i>
                            <div class="extra-small"><b>Miễn phí:</b> Không tính thêm phí.</div>
                        </div>
                    </div>
                }
            </div>
        }

    private void RenderPetForm(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder __builder)
    {
        bool isAllowed = false;
        decimal petFee = 0;

        if (_isUpdate && _updateModel is PetPolicyUpdateVM u)
        {
            isAllowed = u.IsPetAllowed;
            petFee = u.PetFee ?? 0;
        }
        else if (_createModel is PetPolicyCreateVM c)
        {
            isAllowed = c.IsPetAllowed;
            petFee = c.PetFee ?? 0;
        }

        bool hasFee = petFee > 0;

        <h6 class="text-warning fw-bold mb-3"><i class="fa-solid fa-paw me-2"></i>Quy định vật nuôi</h6>

        <div
            class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-3 shadow-sm">
            <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                <i class="fa-solid fa-dog me-2 @(isAllowed ? "text-warning" : "text-secondary")"></i>
                @(isAllowed ? "CHO PHÉP" : "KHÔNG CHO PHÉP")
            </label>
            <input class="form-check-input" type="checkbox" role="switch" checked="@isAllowed"
                   @onchange="@(e => SetPetAllowed((bool)e.Value!))" style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
            </div>

            @if (isAllowed)
            {
                <div class="animate__animated animate__fadeIn">
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-white d-flex align-items-center justify-content-between mb-3 shadow-sm"
                         style="border-style: dashed !important;">
                        <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                            <i class="fa-solid fa-hand-holding-dollar me-2 @(hasFee ? "text-success" : "text-secondary")"></i>
                            @(hasFee ? "TÍNH PHÍ" : "MIỄN PHÍ")
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" checked="@hasFee"
                               @onchange="@(e => TogglePetFee((bool)e.Value!))"                           style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                        </div>

                        @if (hasFee)
                        {
                            <div class="mb-3 animate__animated animate__fadeInDown animate__faster">
                                <label class="form-label fw-bold extra-small text-muted text-uppercase">Phí vệ sinh</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-success"><i class="fa-solid fa-money-bill-wave"></i></span>
                                    <input type="text" class="form-control text-end fw-bold text-success" inputmode="numeric"
                                           value="@petFee.ToString("N0")" @oninput="@(e => SetPetFee(e.Value?.ToString()))" />
                                    <span class="input-group-text bg-light fw-bold">VNĐ</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0">
                                <i class="fa-solid fa-face-smile-beam me-2 fs-5"></i>
                                <div class="extra-small fst-italic"><b>Free:</b> Vật nuôi ở miễn phí.</div>
                            </div>
                        }
                    </div>
                }
        else
                {
                    <div class="alert alert-secondary border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0">
                        <i class="fa-solid fa-ban me-2 fs-5"></i>
                        <div class="extra-small fst-italic">Không tiếp nhận vật nuôi.</div>
                    </div>
                }
            }

    private RenderFragment RenderRowBadge(PolicyVM row) => __builder =>
    {
    switch (row)
    {
        case CheckInOutPolicyVM cio:
            var totalFee = (cio.EarlyCheckInFee ?? 0) + (cio.LateCheckOutFee ?? 0);
            <div class="badge bg-primary bg-opacity-10 text-primary border border-primary d-flex flex-column justify-content-center py-1"
                 style="min-width: 160px; height: 42px;">
                <div class="small" style="font-size: 0.75rem;">
                    <span class="badge rounded-pill bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2"
                          style="font-size: 0.65rem;">
                        <i class="fa-regular fa-clock me-1"></i>@cio.CheckInTime?.ToString("HH:mm") -
                        @cio.CheckOutTime?.ToString("HH:mm")
                    </span>
                </div>
                <div class="fw-bold" style="font-size: 0.8rem;">
                    @(totalFee > 0 ? "+" + totalFee.ToString("N0") + "đ" : "Miễn Phí")
                </div>
            </div>
            break;

        case CancellationPolicyVM cancel:
            <div class="badge bg-danger bg-opacity-10 text-danger border border-danger d-flex flex-column justify-content-center py-1"
                 style="min-width: 160px; height: 42px;">
                <div class="mb-1">
                    @if (!cancel.IsRefundable)
                    {
                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-2" style="font-size: 0.65rem;"><i
                            class="fa-solid fa-ban me-1"></i>Non-Refundable</span>
                        }
                        else
                        {

                            <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-2" style="font-size: 0.65rem;"><i
                                class="fa-solid fa-clock-rotate-left me-1"></i>Trước @cancel.DaysBeforeCheckIn ngày</span>
                            }
                        </div>
                        <div class="fw-bold text-uppercase" style="font-size: 0.8rem;">
                            @(cancel.IsRefundable ? $"Hoàn {cancel.RefundPercent}%" : "Không hoàn tiền")
                        </div>
                    </div>
                    break;

            case ChildrenPolicyVM child:
                        <div class="badge bg-success bg-opacity-10 text-success border border-success d-flex flex-column justify-content-center py-1"
                             style="min-width: 160px; height: 42px;">
                            <div class="small" style="font-size: 0.75rem;">
                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info border-opacity-25 px-2"
                                      style="font-size: 0.7rem;">
                                    <i class="fa-solid fa-child-reaching me-1"></i>@(child.MaxAge >= 99 ? $"Từ {child.MinAge} tuổi +" :
                                                $"{child.MinAge} - {child.MaxAge} tuổi")
                                </span>
                            </div>
                            <div class="fw-bold" style="font-size: 0.8rem;">@(child.ExtraBedFee > 0 ? "+" + child.ExtraBedFee?.ToString("N0") +
                                        "đ" : "Miễn phí")</div>
                            </div>
                            break;

            case PetPolicyVM pet:
                                <div class="badge @(pet.IsPetAllowed ? "bg-warning text-warning border-warning" : "bg-secondary text-secondary border-secondary") bg-opacity-10 border d-flex flex-column justify-content-center py-1"
                                     style="min-width: 160px; height: 42px;">
                                    <div class="small" style="font-size: 0.7rem;">
                                        <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-2" style="font-size: 0.65rem;">
                                            <i class="fa-solid fa-paw me-1"></i>@(pet.IsPetAllowed ? "Cho phép" : "Không cho phép")
                                        </span>
                                    </div>
                                    @if (pet.IsPetAllowed)
                                    {
                                        <div class="fw-bold mt-1" style="font-size: 0.85rem;">@(pet.PetFee > 0 ? "+" + pet.PetFee?.ToString("N0") + "đ" :
                                                    "Miễn phí")</div>
                                        }
                                    </div>
                                    break;

                                    default:
<span class="text-muted opacity-50 fw-bold">---</span>
                break;
                                }
                            }
                            ;

    // ======================== FORM HANDLERS ========================
    private void ToggleCheckInOutFee(bool hasFee)
    {
        if (_isUpdate && _updateModel is CheckInOutPolicyUpdateVM u)
        { u.EarlyCheckInFee = hasFee ? 50000 : 0; u.LateCheckOutFee = hasFee ? 50000 : 0; }
        else if (_createModel is CheckInOutPolicyCreateVM c)
        { c.EarlyCheckInFee = hasFee ? 50000 : 0; c.LateCheckOutFee = hasFee ? 50000 : 0; }
        StateHasChanged();
    }

    private void SetCheckInOutFee(string type, string? val)
    {
        decimal.TryParse(val?.Replace(",", "").Replace(".", ""), out var fee);
        if (_isUpdate && _updateModel is CheckInOutPolicyUpdateVM u)
        { if (type == "early") u.EarlyCheckInFee = fee; else u.LateCheckOutFee = fee; }
        else if (_createModel is CheckInOutPolicyCreateVM c)
        { if (type == "early") c.EarlyCheckInFee = fee; else c.LateCheckOutFee = fee; }
        StateHasChanged();
    }

    private void SetCheckInOutTime(string type, string? val)
    {
        if (!TimeOnly.TryParse(val, out var time)) return;
        if (_isUpdate && _updateModel is CheckInOutPolicyUpdateVM u)
        { if (type == "in") u.CheckInTime = time; else u.CheckOutTime = time; }
        else if (_createModel is CheckInOutPolicyCreateVM c)
        { if (type == "in") c.CheckInTime = time; else c.CheckOutTime = time; }
        StateHasChanged();
    }

    private void SetCancellationRefundable(bool isRefundable)
    {
        if (_isUpdate && _updateModel is CancellationPolicyUpdateVM u)
        {
            u.IsRefundable = isRefundable; if (!isRefundable) { u.DaysBeforeCheckIn = 0; u.RefundPercent = 0; }
            else
            {
                u.DaysBeforeCheckIn = 3; u.RefundPercent = 100;
            }
        }
        else if (_createModel is CancellationPolicyCreateVM c)
        {
            c.IsRefundable = isRefundable; if (!isRefundable) { c.DaysBeforeCheckIn = 0; c.RefundPercent = 0; }
            else
            {
                c.DaysBeforeCheckIn = 3; c.RefundPercent = 100;
            }
        }
        StateHasChanged();
    }


@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.Helpers.Manage.Icon
@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.Helpers
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ROUTING DEFINITION --- *@
@page "/admin/manage/roomview"

@* --- 2. LAYOUT CONFIGURATION --- *@
@layout AdminLayout
@inject ILogger<RoomViewManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING STATE (Controlled by Base Class) --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Loading data...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="RoomViewVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items"
                        Model="@GetModel()" PageIndex="_paging.PageIndex ?? 1" TotalPages="_totalPages" TotalCount="_totalCount"
                        OnPageChanged="HandlePageChanged" OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem"
                        OnDelete="HandleDelete" OnCancel="ResetForm">

        @* --- A. SIDEBAR CONFIGURATION --- *@
        <SidebarTopContent>
            @* Global Navigation Component with dynamic dropdown logic *@
            <GlobalNavMenu CurrentModule="RoomView" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. FORM CONFIGURATION (UI Enhancements) --- *@
        <FormContent Context="m">

            @* 1. ICON PREVIEW *@
            @* Resolves and displays a real-time icon preview based on the room view name *@
            @{
                string currentName = _isUpdate ? _updateModel.Name : _createModel.Name;
            }
            @if (!string.IsNullOrEmpty(currentName))
            {
                <div class="alert alert-light border d-flex align-items-center shadow-sm animate__animated animate__fadeIn">
                    <div class="me-3">
                        <div class="rounded-circle bg-white border d-flex align-items-center justify-content-center shadow-sm"
                             style="width: 40px; height: 40px;">
                            <i class="@GetViewIcon(currentName) text-primary fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <small class="text-muted d-block text-uppercase extra-small fw-bold">Display Preview:</small>
                        <strong class="text-dark">@currentName</strong>
                    </div>
                </div>
            }
        </FormContent>

        @* --- C. TABLE CONFIGURATION --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">Id</th>
            <th class="text-center" style="width: 80px;">Icon</th>
            <th class="text-center" style="width: 320px;">View Name</th>
            <th class="text-center">Description</th>
            <th class="text-center" style="width: 150px;">Status</th>
        </TableHeader>

        <RowTemplate Context="row">
            @* 1. ID *@
            <td class="text-center text-muted small">@row.Id</td>

            @* 2. Automatic Icon Column *@
            <td class="text-center">
                <i class="@GetViewIcon(row.Name) fs-5 text-secondary opacity-75"></i>
            </td>

            @* 3. View Name *@
            <td class="text-center align-middle text-primary fw-bold">
                @row.Name
            </td>

            @* 4. Description - Truncated for layout consistency *@
            <td class="text-center align-middle text-muted small text-truncate" style="max-width: 500px;"
                title="@row.Description">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 500px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>

            @* 5. Status Badge *@
            <td class="text-center">
                <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-1 rounded-pill">
                    Active
                </span>
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}

@code {
    // --- URL PARAMETERS ---
    [Parameter] public int? TypeId { get; set; }

    // --- STATE MANAGEMENT ---
    private List<RoomViewVM>? _items;
    private RoomViewCreateVM _createModel = new RoomViewCreateVM();
    private RoomViewUpdateVM _updateModel = new RoomViewUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    // --- PAGINATION ---
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? (BaseCreateOrUpdateAdminVM)_updateModel :
    (BaseCreateOrUpdateAdminVM)_createModel;

    private MasterDetailLayout<RoomViewVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- HELPER: Resolve icon based on name ---
    private string GetViewIcon(string? name) => RoomViewIconHelper.GetIcon(name);

    // --- LIFECYCLE ---
    protected override async Task LoadDataAsync()
    {
        _items = null;
        StateHasChanged();

        try
        {
            var res = await Service.GetRoomViews(_paging);

            if (!Disposed)
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    _items = res.Content.Items;
                    _totalPages = res.Content.TotalPages;
                    _totalCount = res.Content.TotalCount;
                }
                else
                {
                    _items = new List<RoomViewVM>();
                    if (res.StatusCode != StatusCodeResponse.Success)
                    {
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading room view data");
            _items = new List<RoomViewVM>();
        }
    }

    protected override void OnInitialized()
    {
        ResetForm();
    }

    // --- PARAMETERS HANDLING ---
    protected override async Task OnParametersSetAsync()
    {
        ResetForm();
        if (IsJsReady)
        {
            await LoadDataAsync();
        }
    }

    // --- PAGINATION HANDLING ---
    private async Task HandlePageChanged(int newPage)
    {
        _paging.PageIndex = newPage;
        await LoadDataAsync();
    }

    // --- CRUD OPERATIONS ---
    private void OnEditItem(RoomViewVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        _updateModel = new RoomViewUpdateVM
        {
            Name = item.Name,
            Description = item.Description
        };

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(RoomViewVM item)
    {
        var res = await Service.DeleteRoomView(item.Id);
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        _createModel = new RoomViewCreateVM();
        _updateModel = new RoomViewUpdateVM();

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        ApiResponse<RoomViewVM> res;
        if (_isUpdate)
            res = await Service.UpdateRoomView(_currentEditingId, _updateModel);
        else
            res = await Service.CreateRoomView(_createModel);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            await LoadDataAsync();
            ResetForm();
        }
        else
        {
            // Do NOT reset form on server-side error to allow correction
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        }
    }
}
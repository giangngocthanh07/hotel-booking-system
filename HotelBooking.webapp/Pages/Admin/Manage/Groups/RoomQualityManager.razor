@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.ViewModels.Admin
@using HotelBooking.webapp.ViewModels.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ROUTING DEFINITIONS --- *@
@page "/admin/manage/roomquality"
@page "/admin/manage/roomquality/{TypeId:int}"

@* --- 2. LAYOUT CONFIGURATION --- *@
@layout AdminLayout
@inject ILogger<RoomQualityManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING STATE (Controlled by Base Class) --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Loading data...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="RoomQualityVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items"
                        Model="@GetModel()" PageIndex="_paging.PageIndex ?? 1" TotalPages="_totalPages" TotalCount="_totalCount"
                        OnPageChanged="HandlePageChanged" OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem"
                        OnDelete="HandleDelete" OnCancel="ResetForm">

        @* --- A. SIDEBAR CONFIGURATION (RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* Global Navigation Component for dynamic module selection *@
            <GlobalNavMenu CurrentModule="RoomQuality" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. FORM CONFIGURATION (UI Enhancements) --- *@
        <FormContent Context="m">

            @{
                // Validation error display fragment for SortOrder field
                RenderFragment RenderVal(string prop) => __builder =>
                {
                    if (_isUpdate && prop == "SortOrder")
                    {
                        <ValidationMessage For="() => _updateModel.SortOrder" class="val-msg" />
                    }
                    else if (!_isUpdate && prop == "SortOrder")
                    {
                        <ValidationMessage For="() => _createModel.SortOrder" class="val-msg" />
                    }
                };

                // Get current SortOrder value for preview logic
                int? currentSort = _isUpdate ? _updateModel.SortOrder : _createModel.SortOrder;
            }

            @* 1. SORT ORDER SETTING *@
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Priority Sort Order</label>
                <div class="input-group" style="max-width: 150px;">
                    <span class="input-group-text bg-white"><i class="fa-solid fa-sort-numeric-down text-muted"></i></span>
                    <input type="number" class="form-control text-center fw-bold" value="@currentSort"
                           @oninput="@(e => HandleSortInput(e.Value?.ToString()))" />
                </div>
                @RenderVal("SortOrder")
                <div class="form-text extra-small mt-2 animate__animated animate__fadeIn">
                    <i class="fa-solid fa-circle-info me-1 text-info"></i>
                    Higher numbers prioritize this quality level in display results.
                </div>
            </div>

            @* Priority Badge Preview *@
            @if (currentSort >= 5)
            {
                <div
                    class="alert alert-info border-0 py-2 px-3 d-flex align-items-center shadow-sm animate__animated animate__bounceIn">
                    <i class="fa-solid fa-star me-2 fs-5"></i>
                    <div class="small fw-bold">This is a HIGH PRIORITY quality level.</div>
                </div>
            }
        </FormContent>

        @* --- C. TABLE CONFIGURATION --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">Id</th>
            <th class="text-center" style="width: 400px;">Quality Level Name</th>
            <th class="text-center" style="width: 100px;"></th> @* Badge Column *@
            <th class="text-center">Description / Notes</th> @* Flexible description column *@
            <th class="text-center" style="width: 150px;">Sort Order</th>
        </TableHeader>

        <RowTemplate Context="row">
            @* 1. ID *@
            <td class="text-center text-muted small">@row.Id</td>

            @* 2. Quality Level Name *@
            <td class="text-center align-middle">
                <span class="@(row.SortOrder >= 5 ? "text-primary fw-bold" : "text-dark")">
                    @row.Name
                </span>
            </td>

            @* 3. Priority Badge *@
            <td class="text-center align-middle">
                @if (row.SortOrder >= 5)
                {
                    <span
                        class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-3 py-2 animate__animated animate__fadeIn"
                        style="font-size: 0.65rem; letter-spacing: 0.5px; text-transform: uppercase;">
                        <i class="fa-solid fa-star me-1"></i>High Priority
                    </span>
                }
            </td>

            @* 4. Description *@
            <td class="text-center align-middle">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 250px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>

            @* 5. Sort Order Preview *@
            <td class="text-center">
                <div class="d-inline-flex align-items-center justify-content-center bg-light border rounded-circle fw-bold text-secondary shadow-sm"
                     style="width: 32px; height: 32px; font-size: 0.85rem;">
                    @row.SortOrder
                </div>
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}

@code {
    // --- URL PARAMETERS ---
    [Parameter] public int? TypeId { get; set; }

    // --- STATE MANAGEMENT ---
    private List<RoomQualityVM>? _items;
    private RoomQualityCreateVM _createModel = new RoomQualityCreateVM();
    private RoomQualityUpdateVM _updateModel = new RoomQualityUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    // --- PAGINATION MANAGEMENT ---
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;

    private int? _previousTypeId = null;

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? (BaseCreateOrUpdateAdminVM)_updateModel :
    (BaseCreateOrUpdateAdminVM)_createModel;

    private MasterDetailLayout<RoomQualityVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- REACTIVE INPUT HANDLING ---
    private async Task HandleSortInput(string? val)
    {
        int.TryParse(val, out var sort);

        if (_isUpdate) _updateModel.SortOrder = sort;
        else _createModel.SortOrder = sort;

        StateHasChanged();
        _layoutRef?.TriggerValidate(); // Immediate error clearing
    }

    // --- LIFECYCLE ---
    protected override async Task LoadDataAsync()
    {
        _items = null!;
        StateHasChanged();

        try
        {
            var res = await Service.GetRoomQualitiesByType(TypeId, _paging);

            if (!Disposed)
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    _items = res.Content.Items;
                    _totalPages = res.Content.TotalPages;
                    _totalCount = res.Content.TotalCount;
                }
                else
                {
                    _items = new List<RoomQualityVM>();
                    if (res.StatusCode != StatusCodeResponse.Success)
                    {
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading room quality data");
            _items = new List<RoomQualityVM>();
        }
    }

    protected override void OnInitialized()
    {
        ResetForm();
    }

    // --- TAB SWITCHING LOGIC ---
    protected override async Task OnParametersSetAsync()
    {
        if (TypeId == null) TypeId = 1;

        if (TypeId != _previousTypeId)
        {
            _previousTypeId = TypeId;
            ResetForm();

            if (IsJsReady)
            {
                _paging.PageIndex = 1;
                await LoadDataAsync();
            }
        }
    }

    // --- PAGINATION HANDLING ---
    private async Task HandlePageChanged(int newPage)
    {
        _paging.PageIndex = newPage;
        await LoadDataAsync();
    }

    // --- CRUD OPERATIONS ---
    private void OnEditItem(RoomQualityVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        _updateModel = new RoomQualityUpdateVM
        {
            Name = item.Name,
            Description = item.Description,
            SortOrder = item.SortOrder
        };

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(RoomQualityVM item)
    {
        var res = await Service.DeleteRoomQuality(item.Id);
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        _createModel = new RoomQualityCreateVM
        {
            TypeId = TypeId ?? 0,
            SortOrder = 0
        };
        _updateModel = new RoomQualityUpdateVM();

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        ApiResponse<RoomQualityVM> res;

        if (_isUpdate)
        {
            res = await Service.UpdateRoomQuality(_currentEditingId, _updateModel);
        }
        else
        {
            _createModel.TypeId = TypeId ?? 0;
            res = await Service.CreateRoomQuality(_createModel);
        }

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            await LoadDataAsync();
            ResetForm();
        }
        else
        {
            // Do NOT reset form on server-side validation error
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        }
    }
}
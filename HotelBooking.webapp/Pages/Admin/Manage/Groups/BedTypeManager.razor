@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.ViewModels.Admin
@using HotelBooking.webapp.ViewModels.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ROUTING DEFINITION --- *@
@page "/admin/manage/bedtype"

@* --- 2. LAYOUT CONFIGURATION --- *@
@layout AdminLayout
@inject ILogger<BedTypeManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING STATE --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Loading data...</span>
    </div>
}
else
{
    <MasterDetailLayout TItem="BedTypeVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items" Model="@GetModel()"
                        PageIndex="_paging.PageIndex ?? 1" TotalPages="_totalPages" TotalCount="_totalCount"
                        OnPageChanged="HandlePageChanged"                        OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem"
                        OnDelete="HandleDelete" OnCancel="ResetForm">

        @* --- A. SIDEBAR CONFIGURATION (RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* Global Navigation Component with dynamic dropdown logic *@
            <GlobalNavMenu CurrentModule="BedType" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. FORM CONFIGURATION --- *@
        <FormContent Context="m">
            @* --- 1. PRE-RENDERING LOGIC --- *@
            @{
                var activeModel = GetModel();
                double? currentCapacity = _isUpdate ? _updateModel.DefaultCapacity : _createModel.DefaultCapacity;

                // Validation render fragment for BedType specific fields
                RenderFragment RenderVal(string prop) => __builder =>
                {
                    if (prop == "Capacity")
                    {
                        if (_isUpdate)
                        {
                            <ValidationMessage For="() => _updateModel.DefaultCapacity" class="val-msg" />
                        }
                        else
                        {
                            <ValidationMessage For="() => _createModel.DefaultCapacity" class="val-msg" />
                        }
                    }
                    else if (prop == "Width")
                    {
                        if (_isUpdate)
                        {
                            <ValidationMessage For="() => _updateModel.MinWidth" class="val-msg" />
                        }
                        else
                        {
                            <ValidationMessage For="() => _createModel.MinWidth" class="val-msg" />
                        }
                    }
                };
            }

            @* --- 1. CAPACITY SETTINGS --- *@
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Capacity (Persons)</label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white"><i class="fa-solid fa-user-group text-muted"></i></span>
                    <input type="number" class="form-control fw-bold" min="1" value="@currentCapacity"
                           @oninput="@(e => HandleNumericInput(e.Value?.ToString(), "Capacity"))" />
                </div>
                @RenderVal("Capacity")
                <div class="form-text extra-small mt-1">Default maximum occupancy for this bed type.</div>
            </div>

            @* --- 2. DIMENSION SETTINGS --- *@
            @{
                bool isVarying = _isUpdate ? _updateModel.IsVaryingSize : _createModel.IsVaryingSize;
                double currentMinWidth = _isUpdate ? _updateModel.MinWidth : _createModel.MinWidth;
                double currentMaxWidth = _isUpdate ? _updateModel.MaxWidth : _createModel.MaxWidth;
            }

            <div class="mb-4 p-3 bg-light rounded border shadow-sm">
                <label class="form-label fw-bold small d-block mb-2 text-primary">DIMENSION SETTINGS</label>

                <div class="form-check form-switch custom-switch mb-3">
                    <input type="checkbox" class="form-check-input" role="switch" id="swVarying" checked="@isVarying"
                           @onchange="@(e => HandleToggleVarying((bool)(e.Value ?? false)))"
                           style="cursor: pointer; width: 2.5rem; height: 1.25rem;" />

                    <label class="form-check-label ms-2 small fw-bold" for="swVarying">
                        @(isVarying ? "Varying Dimensions" : "Fixed Dimensions")
                    </label>
                </div>

                @if (!isVarying)
                {
                    <div class="p-1 rounded bg-primary bg-opacity-10 border border-primary border-opacity-25 shadow-sm">
                        <label class="fw-bold text-muted text-uppercase mb-1"
                               style="font-size: 0.62rem; letter-spacing: 0.5px;">
                            WIDTH (INCHES)
                        </label>
                        <div class="d-flex align-items-center gap-2">
                            @if (_isUpdate)
                            {
                                <InputNumber class="form-control form-control-sm fw-bold text-primary shadow-sm"
                                             style="width: 85px;" @bind-Value="_updateModel.MinWidth" />
                                <span class="text-muted small">-</span>
                                <InputNumber class="form-control form-control-sm fw-bold text-primary shadow-sm"
                                             style="width: 85px;" @bind-Value="_updateModel.MaxWidth" />
                            }
                            else
                            {
                                <input type="number" class="form-control form-control-sm fw-bold text-primary text-center"
                                       style="width: 85px;" value="@currentMinWidth"
                                       @oninput="@(e => HandleNumericInput(e.Value?.ToString(), "Min"))" />
                                <span class="text-muted small">-</span>
                                <input type="number" class="form-control form-control-sm fw-bold text-primary text-center"
                                       style="width: 85px;" value="@currentMaxWidth"
                                       @oninput="@(e => HandleNumericInput(e.Value?.ToString(), "Max"))" />
                            }
                        </div>
                        @RenderVal("Width")
                    </div>
                }
            </div>
        </FormContent>

        @* --- C. TABLE CONFIGURATION --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">ID</th>
            <th class="text-center" style="width: 150px;">Bed Type Name</th>
            <th class="text-center" style="width: 120px;">Capacity</th>
            <th class="text-center" style="width: 180px;">Dimensions (Inches)</th>
            <th class="text-center">Description</th>
        </TableHeader>

        <RowTemplate Context="row">
            <td class="text-center text-muted small">@row.Id</td>
            <td class="text-center align-middle text-primary">@row.Name</td>

            @* Content Centering & Capacity Badges *@
            <td class="text-center">
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2">
                    <span class="fs-6 fw-bold me-1">@row.DefaultCapacity</span>
                    <i class="fa-solid fa-user ms-1 opacity-50" style="font-size: 0.8em;"></i>
                </span>
            </td>

            <td class="text-center align-middle">
                @if (row.IsVaryingSize)
                {
                    <span class="text-muted small fst-italic">Varying</span>
                }
                else
                {
                    <div class="badge bg-primary bg-opacity-10 text-primary border border-primary shadow-sm px-2 py-1">
                        <i class="fa-solid fa-ruler-horizontal me-1"></i> @row.MinWidth - @row.MaxWidth"
                    </div>
                }
            </td>

            @* Truncate description if too long *@
            <td class="text-center align-middle text-muted small text-truncate" style="max-width: 250px;"
                title="@row.Description">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 250px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}

@code {
    // --- URL PARAMETERS ---
    [Parameter] public int? TypeId { get; set; }

    // --- STATE MANAGEMENT ---
    private List<BedTypeVM>? _items;
    private BedTypeCreateVM _createModel = new BedTypeCreateVM();
    private BedTypeUpdateVM _updateModel = new BedTypeUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    // --- PAGINATION ---
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;

    private bool _isFirstLoad = true;

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? _updateModel : _createModel;

    private MasterDetailLayout<BedTypeVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- NUMERIC INPUT HANDLING (REACTIVE) ---
    private async Task HandleNumericInput(string? val, string field)
    {
        double.TryParse(val, out var num);

        if (_isUpdate)
        {
            if (field == "Capacity") _updateModel.DefaultCapacity = (int)num;
            else if (field == "Min") _updateModel.MinWidth = num;
            else if (field == "Max") _updateModel.MaxWidth = num;
        }
        else
        {
            if (field == "Capacity") _createModel.DefaultCapacity = (int)num;
            else if (field == "Min") _createModel.MinWidth = num;
            else if (field == "Max") _createModel.MaxWidth = num;
        }

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleToggleVarying(bool val)
    {
        if (_isUpdate)
        {
            _updateModel.IsVaryingSize = val;
            // Inject standard size (Twin bed) if toggled off and currently zero
            if (!val && _updateModel.MinWidth <= 0) { _updateModel.MinWidth = 38; _updateModel.MaxWidth = 75; }
        }
        else
        {
            _createModel.IsVaryingSize = val;
            if (!val && _createModel.MinWidth <= 0) { _createModel.MinWidth = 38; _createModel.MaxWidth = 75; }
        }

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    // --- 1. LOAD DATA ---
    protected override async Task LoadDataAsync()
    {
        _items = null!;
        StateHasChanged();

        try
        {
            var res = await Service.GetBedTypes(_paging);

            if (!Disposed)
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    _items = res.Content.Items;
                    _totalPages = res.Content.TotalPages;
                    _totalCount = res.Content.TotalCount;
                }
                else
                {
                    _items = new List<BedTypeVM>();
                    if (res.StatusCode != StatusCodeResponse.Success)
                    {
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading bed type data");
            _items = new List<BedTypeVM>();
        }
    }

    protected override void OnInitialized()
    {
        ResetForm();
    }

    // --- 2. PARAMETERS HANDLING ---
    protected override async Task OnParametersSetAsync()
    {
        if (_isFirstLoad && IsJsReady)
        {
            _isFirstLoad = false;
            ResetForm();
            await LoadDataAsync();
        }
    }

    // --- PAGINATION HANDLING ---
    private async Task HandlePageChanged(int newPage)
    {
        _paging.PageIndex = newPage;
        await LoadDataAsync();
    }

    // --- CRUD METHODS ---
    private void OnEditItem(BedTypeVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        var updateModel = RoomAttributeHelper.MapToUpdateVM(item);

        if (updateModel is BedTypeUpdateVM mapped)
        {
            _updateModel = mapped;
        }

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(BedTypeVM item)
    {
        var res = await Service.DeleteBedType(item.Id);
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        if (RoomAttributeHelper.CreateNewCreateModel(RoomAttributeType.BedType) is BedTypeCreateVM newModel)
        {
            _createModel = newModel;
        }

        _updateModel = new BedTypeUpdateVM();

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        ApiResponse<BedTypeVM> res;

        if (_isUpdate)
        {
            res = await Service.UpdateBedType(_currentEditingId, _updateModel);
        }
        else
        {
            res = await Service.CreateBedType(_createModel);
        }

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            await LoadDataAsync();
            ResetForm();
        }
        else
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        }
    }
}
@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.ViewModels.Admin
@using HotelBooking.webapp.ViewModels.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ROUTING DEFINITION --- *@
@page "/admin/manage/unittype"

@* --- 2. SHARED ADMIN LAYOUT --- *@
@layout AdminLayout
@inject ILogger<UnitTypeManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING STATE --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Loading data...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="UnitTypeVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items"
                        Model="@GetModel()" PageIndex="_paging.PageIndex ?? 1" TotalPages="_totalPages" TotalCount="_totalCount"
                        OnPageChanged="HandlePageChanged" OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem"
                        OnDelete="HandleDelete" OnCancel="ResetForm">

        @* --- A. SIDEBAR CONFIGURATION (RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* Integrated dynamic navigation menu *@
            <GlobalNavMenu CurrentModule="UnitType" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. FORM CONFIGURATION (Booking.com Standards) --- *@
        <FormContent Context="m">

            @* 1. PROPERTY TYPE CONFIGURATION (IS ENTIRE PLACE) *@
            @{
                bool isEntire = _isUpdate
                ? (_updateModel.IsEntirePlace ?? false)
                : (_createModel.IsEntirePlace ?? false);
            }

            <div class="card bg-white border mb-3 shadow-sm animate__animated animate__fadeIn">
                <div class="card-header bg-light py-2 border-bottom">
                    <h6 class="mb-0 fw-bold small text-uppercase text-muted">Property Configuration</h6>
                </div>
                <div class="card-body">
                    @* --- TOGGLE SWITCH --- *@
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <label class="form-label fw-bold text-dark mb-0">Is this an entire place rental?</label>
                        <div class="form-check form-switch custom-switch">
                            <input class="form-check-input" type="checkbox" role="switch" checked="@isEntire"
                                   @onchange="@(e => HandleToggleEntire((bool)(e.Value ?? false)))"
                                   style="cursor: pointer; width: 3rem; height: 1.5rem;">
                            </div>
                        </div>

                        @* --- VISUAL DESCRIPTION (BOOKING.COM STYLE) --- *@
                        <div
                            class="p-3 rounded border @(isEntire ? "bg-success bg-opacity-10 border-success" : "bg-light border-secondary")">
                            <div class="d-flex align-items-start animate__animated animate__fadeIn">
                                <div class="me-3">
                                    <span
                                        class="badge @(isEntire ? "bg-success" : "bg-secondary") rounded-circle p-2 shadow-sm">
                                        <i class="fa-solid @(isEntire ? "fa-key" : "fa-bed") fs-5 text-white"></i>
                                    </span>
                                </div>
                                <div>
                                    <strong class="@(isEntire ? "text-success" : "text-dark")">
                                        @(isEntire ? "Entire Place" : "Private Room / Hotel Room")
                                    </strong>
                                    <p class="mb-0 small text-muted mt-1 fst-italic">
                                        @if (isEntire)
                                        {
                                            <span>Guests have the whole place to themselves (kitchen, private
                                                entrance...).<br />Ideal for: Apartments, Villas, Studios.</span>
                                            }
                                    else
                                            {
                                                <span>Guests rent a specific bedroom (typically with an ensuite bathroom).<br />Ideal
                                                    for: Hotels, Resorts, Guesthouses.</span>
                                                }
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </FormContent>

                    @* --- C. TABLE CONFIGURATION --- *@
                    <TableHeader>
                        <th class="text-center" style="width: 50px;">Id</th>
                        <th class="text-center" style="width: 250px;">Accommodation Type</th>
                        <th class="text-center">Description</th>
                        <th class="text-center" style="width: 250px;">Rental Type</th>
                    </TableHeader>

                    <RowTemplate Context="row">
                        <td class="text-center text-muted small">@row.Id</td>
                        <td class="text-center align-middle text-primary fw-bold">@row.Name</td>

                        <td class="text-center align-middle text-muted small text-truncate" style="max-width: 250px;"
                            title="@row.Description">
                            @if (string.IsNullOrWhiteSpace(row.Description))
                            {
                                <span class="text-muted opacity-50">---</span>
                            }
                            else
                            {
                                <div class="text-muted small text-truncate mx-auto" style="max-width: 500px;" title="@row.Description">
                                    @row.Description
                                </div>
                            }
                        </td>

                        <td class="text-center">
                            @if (row.IsEntirePlace == true)
                            {
                                <span class="badge rounded-pill bg-success px-3 py-2 shadow-sm">
                                    <i class="fa-solid fa-key me-1"></i>Entire Place
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-light text-dark border px-3 py-2 shadow-sm">
                                    <i class="fa-solid fa-bed me-1"></i>Private Room
                                </span>
                            }
                        </td>
                    </RowTemplate>

                </MasterDetailLayout>
            }

@code {
    // --- URL PARAMETERS ---
    [Parameter] public int? TypeId { get; set; }

    // --- STATE MANAGEMENT ---
    private List<UnitTypeVM>? _items;
    private UnitTypeCreateVM _createModel = new UnitTypeCreateVM();
    private UnitTypeUpdateVM _updateModel = new UnitTypeUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    // --- PAGINATION ---
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;

    private bool _isFirstLoad = true;

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? (BaseCreateOrUpdateAdminVM)_updateModel :
    (BaseCreateOrUpdateAdminVM)_createModel;

    private MasterDetailLayout<UnitTypeVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- REACTIVE SWITCH HANDLER ---
    private void HandleToggleEntire(bool val)
    {
        if (_isUpdate) _updateModel.IsEntirePlace = val;
        else _createModel.IsEntirePlace = val;

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    // --- 1. LOAD DATA ---
    protected override async Task LoadDataAsync()
    {
        _items = null;
        StateHasChanged();

        try
        {
            var res = await Service.GetUnitTypes(_paging);

            if (!Disposed)
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    _items = res.Content.Items;
                    _totalPages = res.Content.TotalPages;
                    _totalCount = res.Content.TotalCount;
                }
                else
                {
                    _items = new List<UnitTypeVM>();
                    if (res.StatusCode != StatusCodeResponse.Success)
                    {
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading unit type data");
            _items = new List<UnitTypeVM>();
        }
    }

    protected override void OnInitialized()
    {
        ResetForm();
    }

    // --- 2. PARAMETERS HANDLING ---
    protected override async Task OnParametersSetAsync()
    {
        if (_isFirstLoad && IsJsReady)
        {
            _isFirstLoad = false;
            ResetForm();
            await LoadDataAsync();
        }
    }

    // --- PAGINATION HANDLING ---
    private async Task HandlePageChanged(int newPage)
    {
        _paging.PageIndex = newPage;
        await LoadDataAsync();
    }

    // --- CRUD METHODS ---
    private void OnEditItem(UnitTypeVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        _updateModel = new UnitTypeUpdateVM
        {
            Name = item.Name,
            Description = item.Description,
            IsEntirePlace = item.IsEntirePlace
        };

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(UnitTypeVM item)
    {
        var res = await Service.DeleteUnitType(item.Id);
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        _createModel = new UnitTypeCreateVM { IsEntirePlace = false };
        _updateModel = new UnitTypeUpdateVM();

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        ApiResponse<UnitTypeVM> res;

        if (_isUpdate)
        {
            res = await Service.UpdateUnitType(_currentEditingId, _updateModel);
        }
        else
        {
            res = await Service.CreateUnitType(_createModel);
        }

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            await LoadDataAsync();
            ResetForm();
        }
        else
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        }
    }
}
@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.Helpers.Manage.Icon
@using HotelBooking.webapp.ViewModels.Admin
@using HotelBooking.webapp.ViewModels.Admin.Base
@using HotelBooking.webapp.ViewModels.Hotel
@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.Helpers

@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ROUTING DEFINITIONS --- *@
@page "/admin/manage/service"
@page "/admin/manage/service/{TypeId:int}"

@* --- 2. LAYOUT CONFIGURATION --- *@
@layout AdminLayout
@inject ILogger<ServiceManager> Logger
@inject ISnackbar _snackbar

@* --- 3. MASTER DETAIL LAYOUT (OPTIMIZED VERSION) --- *@
@if (!ShouldRenderUI())
{
    <div class="p-4 text-center">Loading authentication...</div>
}
else
{
    <MasterDetailLayout TItem="ServiceVM" @ref="_layoutRef" TModel="BaseCreateOrUpdateAdminVM" Items="items" Model="@GetModel()"
        PageIndex="_paging.PageIndex ?? 1" TotalPages="totalPages" TotalCount="totalCount" OnPageChanged="HandlePageChanged"
        OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem" OnDelete="HandleDelete" OnCancel="ResetForm" OnNameBlur="SuggestDefaultValues">

        @* --- A. SIDEBAR CONFIGURATION (RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* Global Navigation Component with dynamic dropdown logic *@
            <GlobalNavMenu CurrentModule="Service" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. FORM CONFIGURATION --- *@
        <FormContent Context="m">
            
            @* --- 1. LOCAL RENDERING HELPERS --- *@
            @{
                // Displays validation messages based on the active model state
                RenderFragment RenderVal(string prop) => __builder => {
                    @if (_isUpdate) {
                        if (prop == "Price") { <ValidationMessage For="() => _updateModel.Price" class="val-msg" /> }
                        else if (prop == "Unit" && StdUp != null) { <ValidationMessage For="() => StdUp.Unit" class="val-msg" /> }
                        else if (prop == "RoundTripPrice") { <ValidationMessage For="() => ((ServiceAirportUpdateVM)_updateModel).RoundTripPrice" class="val-msg" /> }
                        else if (prop == "AdditionalFee") { <ValidationMessage For="() => ((ServiceAirportUpdateVM)_updateModel).AdditionalFee" class="val-msg" /> }
                    } else {
                        if (prop == "Price") { <ValidationMessage For="() => _createModel.Price" class="val-msg" /> }
                        else if (prop == "Unit" && StdCr != null) { <ValidationMessage For="() => StdCr.Unit" class="val-msg" /> }
                        else if (prop == "RoundTripPrice") { <ValidationMessage For="() => ((ServiceAirportCreateVM)_createModel).RoundTripPrice" class="val-msg" /> }
                        else if (prop == "AdditionalFee") { <ValidationMessage For="() => ((ServiceAirportCreateVM)_createModel).AdditionalFee" class="val-msg" /> }
                    }
                };

                decimal currentPrice = _isUpdate ? _updateModel.Price : _createModel.Price;
            }

            @* --- CASE 1: STANDARD SERVICE --- *@
            @if (TypeId == 1)
            {
                @* --- 1. UNIT OF MEASUREMENT --- *@
                <div class="mb-3">
                    <label class="small text-muted fw-bold text-uppercase">Unit of Measurement</label>
                    @if (_isUpdate && StdUp != null)
                    {
                        <input type="text" class="form-control shadow-sm" 
                        value="@StdUp.Unit" 
                        @oninput="@(e => HandleUnitInput(e.Value?.ToString()))" 
                        placeholder="Trip, Person, Kg..." />
                    }
                    else if (!_isUpdate && StdCr != null)
                    {
                        <input type="text" class="form-control shadow-sm" 
                        value="@StdCr.Unit" 
                        @oninput="@(e => HandleUnitInput(e.Value?.ToString()))" 
                        placeholder="Trip, Person, Kg..." />
                    }
                    @RenderVal("Unit")
                </div>

                @* --- 2. SUGGESTED PRICE --- *@
                <div class="mb-3">
                    <label class="small text-muted fw-bold text-uppercase">Suggested Price</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white text-success">
                            <i class="fa-solid fa-money-bill-wave"></i>
                        </span>
                        <input type="text" class="form-control text-end fw-bold text-success" 
                        inputmode="numeric"
                        value="@(currentPrice.ToString("N0"))" 
                        @oninput="@(e => HandlePriceInput(e.Value?.ToString(), "Price"))" 
                        placeholder="Enter amount..." />
                        <span class="input-group-text bg-light fw-bold">VND</span>
                    </div>
                    @RenderVal("Price")
                </div>
            }

            @* --- CASE 2: AIRPORT TRANSFER (DYNAMIC FLOW) --- *@
            else if (TypeId == 2)
            {
                @* Vehicle Specs *@
                <div class="row g-2 mb-4 bg-light p-2 rounded border mx-0">
                    <div class="col-6 text-center border-end">
                        <label class="extra-small text-muted fw-bold">MAX PASSENGERS</label>
                        <div class="d-flex align-items-center justify-content-center w-100">
                            <i class="fa-solid fa-users text-info flex-shrink-0"></i>
                            @if(_isUpdate && AirUp != null) { <input type="number" @bind="AirUp.MaxPassengers" class="form-control form-control-sm border-0 bg-transparent fw-bold p-0 text-center flex-grow-0" style="width: 50px;" /> }
                            else if(AirCr != null) { <input type="number" @bind="AirCr.MaxPassengers" class="form-control form-control-sm border-0 bg-transparent fw-bold p-0 text-center flex-grow-0" style="width: 50px;" /> }
                        </div>
                    </div>
                    <div class="col-6 text-center">
                        <label class="extra-small text-muted fw-bold">MAX LUGGAGE</label>
                        <div class="d-flex align-items-center justify-content-center w-100">
                            <i class="fa-solid fa-suitcase text-info flex-shrink-0"></i>
                             @if(_isUpdate && AirUp != null) { <input type="number" @bind="AirUp.MaxLuggage" class="form-control form-control-sm border-0 bg-transparent fw-bold p-0 text-center flex-grow-0" style="width: 50px;"/> }
                            else if(AirCr != null) { <input type="number" @bind="AirCr.MaxLuggage" class="form-control form-control-sm border-0 bg-transparent fw-bold p-0 text-center flex-grow-0" style="width: 50px;" /> }
                        </div>
                    </div>
                </div>

                @* One-Way Service *@
                bool is1W = (_isUpdate && AirUp?.IsOneWayPaid == true) || (!_isUpdate && AirCr?.IsOneWayPaid == true);
                <div class="mb-3">
                    <label class="form-label fw-bold small d-block mb-2">1. Is the one-way service chargeable?</label>
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-2 shadow-sm">
                        <label class="small fw-bold text-muted mb-0 ms-1 uppercase">
                            <i class="fa-solid fa-hand-holding-dollar me-2 @(is1W ? "text-success" : "text-secondary")"></i>
                            @(is1W ? "CHARGEABLE SERVICE" : "COMPLIMENTARY")
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" checked="@is1W" @onchange="@(e => HandleOneWayToggle((bool)e.Value!))" style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>

                    @if (is1W)
                    {
                        <div class="mt-2 ps-3 border-start border-primary border-3 bg-light p-2 rounded shadow-sm">
                            <div class="col-12 mt-1">
                                <label class="extra-small fw-bold text-muted uppercase mb-1">ONE-WAY PRICE</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-success"><i class="fa-solid fa-money-bill-wave"></i></span>
                                    <input type="text" class="form-control text-end fw-bold text-primary" inputmode="numeric"
                                       value="@(currentPrice.ToString("N0"))" @oninput="@(e => HandlePriceInput(e.Value?.ToString(), "Price"))" />
                                    <span class="input-group-text bg-light fw-bold">VND</span>
                                </div>
                                @RenderVal("Price")
                            </div>
                        </div>
                    }
                </div>

                @* Round Trip *@
                bool hasRT = _isUpdate ? AirUp?.HasRoundTrip == true : AirCr?.HasRoundTrip == true;
                bool rtPaid = _isUpdate ? AirUp?.IsRoundTripPaid == true : AirCr?.IsRoundTripPaid == true;
                decimal rtPriceValue = _isUpdate ? (AirUp?.RoundTripPrice ?? 0) : (AirCr?.RoundTripPrice ?? 0);
                
                <div class="mb-3">
                    <label class="form-label fw-bold small d-block mb-2">2. Is round-trip service available?</label>
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-2 shadow-sm">
                        <label class="small fw-bold text-muted mb-0 uppercase">
                            <i class="fa-solid fa-arrows-left-right me-2 @(hasRT ? "text-warning" : "text-secondary")"></i>
                            @(hasRT ? "ROUND-TRIP SUPPORTED" : "ONE-WAY ONLY")
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" checked="@hasRT" @onchange="@(e => HandleRoundTripToggle((bool)e.Value!))" style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>

                    @if (hasRT)
                    {
                        <div class="mt-2 ps-3 border-start border-warning border-3 bg-light p-2 rounded shadow-sm animate__animated animate__fadeIn">
                            <label class="extra-small fw-bold text-muted mb-1 d-block">IS THE ROUND-TRIP CHARGEABLE?</label>
                            <div class="d-flex gap-3 mb-2 px-1">
                                <div class="form-check custom-radio">
                                    <input type="radio" class="form-check-input" name="rt_option_@TypeId" checked="@(!rtPaid)" @onclick="() => SetRoundTripPaid(false)" />
                                    <label class="small fw-bold text-success cursor-pointer">Free</label>
                                </div>
                                <div class="form-check custom-radio">
                                    <input type="radio" class="form-check-input" name="rt_option_@TypeId" checked="@rtPaid" @onclick="() => SetRoundTripPaid(true)" />
                                    <label class="small fw-bold text-danger cursor-pointer">Chargeable</label>
                                </div>
                            </div>

                            @if (rtPaid)
                            {
                                <div class="col-12 mt-1 animate__animated animate__fadeInDown animate__faster">
                                    <label class="extra-small fw-bold text-muted uppercase mb-1">ROUND-TRIP PRICE</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-white text-warning"><i class="fa-solid fa-money-bill-transfer"></i></span>
                                        <input type="text" class="form-control text-end fw-bold text-warning" inputmode="numeric"
                                            value="@(rtPriceValue.ToString("N0"))" @oninput="@(e => HandlePriceInput(e.Value?.ToString(), "RoundTrip"))" />
                                        <span class="input-group-text bg-light fw-bold">VND</span>
                                    </div>
                                    @RenderVal("RoundTripPrice")
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Night Surcharge *@
                bool hasNight = _isUpdate ? AirUp?.HasNightFee == true : AirCr?.HasNightFee == true;
                decimal nightFeeValue = _isUpdate ? (AirUp?.AdditionalFee ?? 0) : (AirCr?.AdditionalFee ?? 0);
                var startTime = AirUp?.AdditionalFeeStartTime ?? AirCr?.AdditionalFeeStartTime;
                var endTime = AirUp?.AdditionalFeeEndTime ?? AirCr?.AdditionalFeeEndTime;

                double totalHours = 0;
                if (startTime.HasValue && endTime.HasValue)
                {
                    var diff = endTime.Value - startTime.Value;
                    totalHours = diff.TotalHours < 0 ? diff.TotalHours + 24 : diff.TotalHours;
                }
                bool isOvernight = startTime.HasValue && endTime.HasValue && startTime > endTime;
                    
                <div class="mb-3">
                    <label class="form-label fw-bold small d-block mb-2">3. Apply night service surcharge?</label>
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-2 shadow-sm">
                        <label class="small fw-bold text-muted mb-0 ms-1 uppercase">
                            <i class="fa-solid fa-moon me-2 @(hasNight ? "text-danger" : "text-secondary")"></i>
                            @(hasNight ? "SURCHARGE APPLIED" : "NO NIGHT FEE")
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" checked="@hasNight" @onchange="@(e => HandleNightFeeToggle((bool)e.Value!))" style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>

                    @if (hasNight)
                    {
                        <div class="mt-2 ps-3 border-start border-danger border-3 bg-light p-2 rounded shadow-sm">
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="extra-small fw-bold text-muted mb-1">FROM</label>
                                    @if (AirUp != null) { <input type="time" @bind="AirUp!.AdditionalFeeStartTime" class="form-control form-control-sm" /> }
                                    else if (AirCr != null) { <input type="time" @bind="AirCr!.AdditionalFeeStartTime" class="form-control form-control-sm" /> }
                                </div>
                                <div class="col-6">
                                    <label class="extra-small fw-bold text-muted mb-1">TO</label>
                                    @if (AirUp != null) { <input type="time" @bind="AirUp!.AdditionalFeeEndTime" class="form-control form-control-sm" /> }
                                    else if (AirCr != null) { <input type="time" @bind="AirCr!.AdditionalFeeEndTime" class="form-control form-control-sm" /> }
                                </div>

                                <div class="col-12 mt-2">
                                    @if (isOvernight)
                                    {
                                        <div class="alert alert-warning py-1 px-2 mb-1 border-0 shadow-none d-flex align-items-center" style="font-size: 0.65rem;">
                                            <i class="fa-solid fa-moon me-2"></i>
                                            <span><strong>Overnight</strong> mode active (ends next morning).</span>
                                        </div>
                                    }
                                    @if (totalHours > 12)
                                    {
                                        <div class="alert alert-danger py-1 px-2 mb-2 border-0 shadow-none d-flex align-items-center" style="font-size: 0.65rem;">
                                            <i class="fa-solid fa-circle-exclamation me-2"></i>
                                            <span>Error: Duration too long (<strong>@Math.Round(totalHours, 1)h</strong>). Max 12h.</span>
                                        </div>
                                    }
                                    else if (totalHours > 0)
                                    {
                                        <div class="text-muted ps-1 mb-2" style="font-size: 0.65rem;">
                                            <i class="fa-solid fa-hourglass-half me-1"></i> Total: <strong>@Math.Round(totalHours, 1) hours</strong> surcharge duration.
                                        </div>
                                    }
                                </div>

                                <div class="col-12 mt-1 animate__animated animate__fadeInDown animate__faster">
                                    <label class="extra-small fw-bold text-muted uppercase mb-1">SURCHARGE FEE</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-white text-success"><i class="fa-solid fa-money-bill-wave"></i></span>
                                        <input type="text" class="form-control text-end fw-bold text-danger" inputmode="numeric" value="@(nightFeeValue.ToString("N0"))" @oninput="@(e => HandlePriceInput(e.Value?.ToString(), "NightFee"))" />
                                        <span class="input-group-text bg-light fw-bold">VND</span>
                                    </div>
                                    @RenderVal("AdditionalFee")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </FormContent>

        @* --- C. TABLE CONFIGURATION --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">Id</th>
            <th class="text-center" style="width: 60px;">Icon</th>
            <th class="text-center" style="width: 200px;">Service Template</th>
            <th class="text-center">Description / Notes</th>

            @if (TypeId == 1 || TypeId == null) 
            {
                <th class="text-center" style="width: 100px;">Unit</th>
                <th class="text-center" style="width: 150px;">Suggested Price</th>
                <th style="width: 50px;"></th>
            }
            else if (TypeId == 2) 
            {
                <th class="text-center" style="width: 150px;">Price (1W/2W)</th>
                <th class="text-center" style="width: 120px;">Capacity</th>
                <th class="text-center" style="min-width: 150px;">Night Fee</th>
            }
        </TableHeader>

        <RowTemplate Context="row">
            <td class="text-center text-muted small">@row.Id</td>
            <td class="text-center">
                <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center shadow-sm mx-auto" style="width: 32px; height: 32px;">
                    <i class="@GetServiceIcon(row.Name) text-primary"></i>
                </div>
            </td>
            <td class="text-center align-middle text-dark fw-bold">@row.Name</td>
            <td class="text-center align-middle">
                <div class="text-muted small text-truncate mx-auto" style="max-width: 400px;" title="@row.Description">
                    @(string.IsNullOrWhiteSpace(row.Description) ? "---" : row.Description)
                </div>
            </td>

            @if (row is ServiceStandardVM standard)
            {
                <td class="text-center align-middle">
                    <span class="badge bg-light text-dark border px-2 shadow-sm">@standard.Unit</span>
                </td>
                <td class="text-center align-middle fw-bold text-success">
                    @standard.Price.ToString("N0")đ
                </td>
                <td></td>
            }
            else if (row is ServiceAirportTransferVM at)
            {
                <td class="text-center align-middle">
                    <div class="d-flex flex-column align-items-center justify-content-center">
                        <div class="small w-100 mb-1 d-flex justify-content-center gap-1" style="min-width: 120px;">
                            <span class="text-muted" style="width: 25px; text-align: left;">1W:</span>
                            <span class="fw-bold @(at.IsOneWayPaid ? "text-primary" : "text-success")" style="min-width: 70px; text-align: right;">
                                @(at.IsOneWayPaid? at.Price.ToString("N0") + "đ" : "Free")
                            </span>
                        </div>
                        <div class="small w-100 d-flex justify-content-center gap-1" style="min-width: 120px;">
                            <span class="text-muted" style="width: 25px; text-align: left;">2W:</span>
                            @if (at.HasRoundTrip)
                            {
                                <span class="fw-bold @(at.IsRoundTripPaid ? "text-warning" : "text-success")" style="min-width: 70px; text-align: right;">
                                    @(at.IsRoundTripPaid? at.RoundTripPrice?.ToString("N0") + "đ" : "Free")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted opacity-50" style="min-width: 70px; text-align: right;">---</span>
                            }
                        </div>
                    </div>
                </td>
                <td class="text-center align-middle">
                    <div class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-3 py-1 shadow-sm">
                        <i class="fa-solid fa-users me-1"></i> @at.MaxPassengers
                        <span class="mx-1 text-muted opacity-50">|</span>
                        <i class="fa-solid fa-suitcase me-1"></i> @at.MaxLuggage
                    </div>
                </td>
                <td class="text-center align-middle">
                    @if (at.HasNightFee || (at.AdditionalFee.HasValue && at.AdditionalFee > 0))
                    {
                        <div class="p-1 rounded bg-danger bg-opacity-10 border border-danger border-opacity-25 shadow-sm">
                            <div class="text-danger fw-bold small mb-0">
                                <i class="fa-solid fa-moon me-1"></i>+@(at.AdditionalFee?.ToString("N0") ?? "0")đ
                            </div>
                            <div class="extra-small text-muted fw-bold" style="font-size: 0.65rem;">
                                @(at.AdditionalFeeStartTime?.ToString("HH:mm") ?? "--:--") - @(at.AdditionalFeeEndTime?.ToString("HH:mm") ?? "--:--")
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted small opacity-50 fst-italic">Not applicable</span>
                    }
                </td>
            }
        </RowTemplate>
    </MasterDetailLayout>
}

@code {
    [Parameter] public int? TypeId { get; set; }

    private List<ServiceVM>? items; 
    private ServiceCreateVM _createModel = new ServiceStandardCreateVM();
    private ServiceUpdateVM _updateModel = new ServiceStandardUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int totalPages = 0;
    private int totalCount = 0;

    private int? _previousTypeId = null;
    private MasterDetailLayout<ServiceVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    private ServiceStandardCreateVM? StdCr => _createModel as ServiceStandardCreateVM;
    private ServiceStandardUpdateVM? StdUp => _updateModel as ServiceStandardUpdateVM;
    private ServiceAirportCreateVM? AirCr => _createModel as ServiceAirportCreateVM;
    private ServiceAirportUpdateVM? AirUp => _updateModel as ServiceAirportUpdateVM;

    private void SuggestDefaultValues()
    {
        if (_isUpdate) ServiceHelper.ApplyDefaultValues(_updateModel, TypeId ?? 1);
        else ServiceHelper.ApplyDefaultValues(_createModel, TypeId ?? 1);

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleUnitInput(string? val)
    {
        if (_isUpdate && StdUp != null) StdUp.Unit = val ?? "";
        else if (StdCr != null) StdCr.Unit = val ?? "";

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private async Task HandlePriceInput(string? val, string field)
    {
        var clean = new string((val ?? "").Where(char.IsDigit).ToArray());
        decimal.TryParse(clean, out var amount);

        if (field == "Price") {
            if (_isUpdate) {
                _updateModel.Price = amount;
                if (AirUp != null) AirUp.IsOneWayPaid = amount > 0;
            } else {
                _createModel.Price = amount;
                if (AirCr != null) AirCr.IsOneWayPaid = amount > 0;
            }
        } else if (field == "RoundTrip") {
            if (_isUpdate && AirUp != null) {
                AirUp.RoundTripPrice = amount;
                AirUp.IsRoundTripPaid = amount > 0;
            }
            else if (AirCr != null) {
                AirCr.RoundTripPrice = amount;
                AirCr.IsRoundTripPaid = amount > 0;
            }
        } else if (field == "NightFee") {
            if (_isUpdate && AirUp != null) AirUp.AdditionalFee = amount; 
            else if (AirCr != null) AirCr.AdditionalFee = amount;
        }

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleOneWayToggle(bool isEnabled)
    {
        decimal val = isEnabled ? 350000 : 0; 
        if (_isUpdate && AirUp != null) {
            AirUp.IsOneWayPaid = isEnabled;
            AirUp.Price = val;
        } else if (AirCr != null) {
            AirCr.IsOneWayPaid = isEnabled;
            AirCr.Price = val;
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleRoundTripToggle(bool isEnabled)
    {
        if (_isUpdate && AirUp != null)
        {
            AirUp.HasRoundTrip = isEnabled;
            if (!isEnabled) { AirUp.IsRoundTripPaid = false; AirUp.RoundTripPrice = 0; }
            else { AirUp.IsRoundTripPaid = true; AirUp.RoundTripPrice = 650000; }
        }
        else if (AirCr != null)
        {
            AirCr.HasRoundTrip = isEnabled;
            if (!isEnabled) { AirCr.IsRoundTripPaid = false; AirCr.RoundTripPrice = 0; }
            else { AirCr.IsRoundTripPaid = true; AirCr.RoundTripPrice = 650000; }
        }
        StateHasChanged(); 
        _layoutRef?.TriggerValidate();
    }

    private void HandleNightFeeToggle(bool isEnabled)
    {
        decimal suggestedFee = isEnabled ? 100000 : 0;
        if (_isUpdate && AirUp != null)
        {
            AirUp.HasNightFee = isEnabled;
            AirUp.AdditionalFee = suggestedFee;
            if (isEnabled && AirUp.AdditionalFeeStartTime == default) {
                AirUp.AdditionalFeeStartTime = new TimeOnly(22, 0);
                AirUp.AdditionalFeeEndTime = new TimeOnly(5, 0);
            }
        }
        else if (AirCr != null)
        {
            AirCr.HasNightFee = isEnabled;
            AirCr.AdditionalFee = suggestedFee;
            if (isEnabled && AirCr.AdditionalFeeStartTime == default) {
                AirCr.AdditionalFeeStartTime = new TimeOnly(22, 0);
                AirCr.AdditionalFeeEndTime = new TimeOnly(5, 0);
            }
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void SetRoundTripPaid(bool isPaid)
    {
        decimal val = isPaid ? 650000 : 0;
        if (_isUpdate && AirUp != null) {
            AirUp.IsRoundTripPaid = isPaid;
            AirUp.RoundTripPrice = val;
        } else if (AirCr != null) {
            AirCr.IsRoundTripPaid = isPaid;
            AirCr.RoundTripPrice = val;
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private BaseCreateOrUpdateAdminVM GetModel()
    {
        if (_isUpdate) return _updateModel ?? new ServiceStandardUpdateVM();
        return _createModel ?? new ServiceStandardCreateVM();
    }
    
    private string GetServiceIcon(string? name) => ServiceIconHelper.GetIcon(name);

    protected override async Task LoadDataAsync()
    {
        if (Disposed) return;
        items = null;
        StateHasChanged();

        try
        {
            var res = await Service.GetServicesByType(TypeId, _paging);
            if (!Disposed && res.StatusCode == StatusCodeResponse.Success && res.Content != null)
            {
                items = res.Content.Items;
                totalPages = res.Content.TotalPages;
                totalCount = res.Content.TotalCount;
            }
            else
            {
                items = new List<ServiceVM>();
                if (res.StatusCode != StatusCodeResponse.Success)
                    SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading service data");
            items = new List<ServiceVM>();
        }
        finally
        {
            if (!Disposed) StateHasChanged();
        }
    }

    protected override void OnInitialized() => ResetForm();

    protected override async Task OnParametersSetAsync()
    {
        if (TypeId == null) TypeId = 1;
        if (TypeId != _previousTypeId)
        {
            _previousTypeId = TypeId;
            ResetForm();
            if (IsJsReady) 
            {
                _paging.PageIndex = 1;
                await LoadDataAsync();
            }
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        _paging.PageIndex = newPage;
        await LoadDataAsync();
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;
        _createModel = ServiceHelper.CreateNewServiceModel(TypeId ?? 1);
        _updateModel = new ServiceStandardUpdateVM();
        _layoutRef?.TriggerValidate();
        StateHasChanged();
    }

    private void OnEditItem(ServiceVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;
        var updateVm = ServiceHelper.MapToUpdateVM(item);
        if (updateVm != null) _updateModel = updateVm;
    }

    private async Task HandleDelete(ServiceVM item)
    {
        var res = await Service.DeleteService(item.Id);
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        if (res.StatusCode == StatusCodeResponse.Success) await LoadDataAsync();
    }

    private async Task SaveData()
    {
        decimal p = _isUpdate ? _updateModel.Price : _createModel.Price;
        if (p <= 0 && TypeId == 1) { _snackbar.Add(MessageResponse.AdminManagement.Service.REQUIRED_PRICE, Severity.Warning); return; }

        if (TypeId == 2) 
        {
            TimeOnly? start, end;
            bool hasNightFee;
            if (_isUpdate)
            {
                var m = (ServiceAirportUpdateVM)_updateModel;
                start = m.AdditionalFeeStartTime; end = m.AdditionalFeeEndTime; hasNightFee = m.HasNightFee;
            }
            else
            {
                var m = (ServiceAirportCreateVM)_createModel;
                start = m.AdditionalFeeStartTime; end = m.AdditionalFeeEndTime; hasNightFee = m.HasNightFee;
            }

            if (hasNightFee && start.HasValue && end.HasValue)
            {
                double hours = (end.Value - start.Value).TotalHours;
                if (hours < 0) hours += 24;

                if (hours > 12)
                {
                    _snackbar.Add("Surcharge time frame is too long (>12h). Please adjust!", Severity.Error);
                    return;
                }
                if (start == end)
                {
                    _snackbar.Add("Start and end times cannot be the same!", Severity.Error);
                    return;
                }
            }
        }

        ApiResponse<ServiceVM> res;
        if (_isUpdate) res = await Service.UpdateService(_currentEditingId, _updateModel);
        else res = await Service.CreateService(_createModel);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            await LoadDataAsync();
            ResetForm();
        }
        else SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
    }
}
@using HotelBooking.webapp.Components.Manage.Service
@using HotelBooking.webapp.ViewModels.Hotel


@page "/admin/manages/manage-services"
@layout AdminLayout

@inject HttpClient _httpClient // Inject HttpClient để gọi API
@inject IHttpClientFactory _httpClientFactory
@inject ISnackbar Snackbar

<div class="container-fluid p-4">
    <h2 class="text-primary mb-4">Manage Services</h2>

    <div class="row">
        <ServiceCreateOrUpdateCard PageData="@PageData" ServiceParam="@SelectedService"
            OnServiceTypeChanged="@HandleServiceTypeChange" OnSaveUpdate="@SaveOrUpdateService" />

        <ListServicesCard IsLoading="@_isLoading" PageData="@PageData" EventOnEdit="@EditService"
            EventOnDelete="@DeleteService" />

    </div>
</div>

@code {
    private bool _isLoading = false;
    private ManageServiceVM PageData = new();
    public int selectedTypeId = 0;

    public ServiceBaseVM? SelectedService { get; set; }
    // Biến lưu danh sách lấy từ API

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        await LoadData(null);

    }

    private async Task LoadData(int? typeId)
    {
        _isLoading = true;
        var url = $"hotel/get-manage-service-data?selectedTypeId={typeId}";

        var response = await _httpClient.GetFromJsonAsync<ApiResponse<ManageServiceVM>>(url);

        if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
        {
            PageData = response.Content;

            SelectedService = ServiceHelper.CreateNewServiceInstance(PageData.SelectedTypeId);

        }

        _isLoading = false;
    }


    private async Task HandleServiceTypeChange(int newId)
    {
        if (PageData != null)
        {
            PageData.SelectedTypeId = newId;
            // (Tùy chọn) Xóa tạm list services cũ để hiện Loading hoặc bảng trắng
            PageData.Services = new List<ServiceBaseVM>();
        }
        await LoadData(newId);
    }


    private async Task SaveOrUpdateService()
    {
        // 1. Kiểm tra Null (Phòng thủ)
        if (SelectedService == null)
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error, "Vui lòng chọn loại dịch vụ trước khi lưu.");
            return;
        }

        // 2. Xác định hành động (Create hay Update)
        bool isCreate = (SelectedService.Id == 0);
        string actionKey = isCreate ? "Create" : "Update";

        // 3. Xây dựng API Endpoint động
        string apiAction = isCreate ? "create" : "update";
        string apiType = PageData!.SelectedTypeId switch
        {
            1 => "standard-service",
            2 => "airport-transfer-service",
            _ => throw new InvalidOperationException("Invalid service type selected.")
        };

        // Kết quả: "hotel/create-standard-service" hoặc "hotel/update-standard-service/5"
        string apiEndpoint = $"hotel/{apiAction}-{apiType}";
        if (!isCreate)
        {
            apiEndpoint += $"/{SelectedService.Id}";
        }

        try
        {
            // 4. Gọi API (Hợp nhất logic HTTP)
            HttpResponseMessage response;
            if (isCreate)
            {
                response = await _httpClient.PostAsJsonAsync(apiEndpoint, SelectedService);
            }
            else
            {
                response = await _httpClient.PutAsJsonAsync(apiEndpoint, SelectedService);
            }

            // 5. Xử lý phản hồi bằng Helper (Gọn gàng & Tái sử dụng)
            var finalApiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<ServiceBaseVM>>();

            // Bảo vệ null: sử dụng giá trị mặc định nếu finalApiResponse là null
            var status = finalApiResponse?.StatusCode ?? StatusCodeResponse.Error;
            var message = finalApiResponse?.Message ?? MessageResponse.ERROR_IN_SERVER;
            SnackbarHelper.Show(Snackbar, status, message);

            // 6. Reset Form & Tải lại danh sách (Chỉ khi thành công)
            if (status == StatusCodeResponse.Success)
            {
                // Tạo object mới để xóa trắng form
                SelectedService = ServiceHelper.CreateNewServiceInstance(PageData.SelectedTypeId);

                // Tải lại bảng dữ liệu
                await LoadData(PageData.SelectedTypeId);

                // Cập nhật UI
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception)
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error, MessageResponse.ERROR_IN_SERVER);
        }
    }

    private async Task EditService(ServiceBaseVM service)
    {
        var findService = PageData?.Services.FirstOrDefault(x => x.Id == service.Id);

        if (findService == null) return;

        // 2. Clone bằng Helper (An toàn, Nhanh, Không dùng JSON/Object)
        SelectedService = ServiceHelper.CloneService(findService);

        // Kích hoạt render để hiển thị form Edit
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteService(int id)
    {
        // Gọi API DELETE
        var response = await _httpClient.DeleteAsync($"hotel/delete-service/{id}");
        var result = await response.Content.ReadFromJsonAsync<ApiResponse<bool>>();

        if (result?.StatusCode == StatusCodeResponse.Success)
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Success, "Đã xóa thành công");
            await LoadData(PageData.SelectedTypeId);
        }
        else
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error, result?.Message ?? "Lỗi xóa");
        }
    }
}
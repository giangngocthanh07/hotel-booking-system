@using HotelBooking.webapp.Components.Manage.Service
@using HotelBooking.webapp.ViewModels.Hotel

@page "/admin/manages/manage-services"
@layout AdminLayout

@inject HttpClient _httpClient // Inject HttpClient để gọi API
@inject IHttpClientFactory _httpClientFactory
@inject ISnackbar Snackbar

<div class="container-fluid p-4">
    <h2 class="text-primary mb-4">Manage Services</h2>

    <div class="row">
        <ServiceCreateOrUpdateCard ServiceTypeList="@serviceTypesList" SelectedServiceType="@selectedServiceType"
            ServiceParam="@SelectedService" OnServiceTypeChanged="@HandleServiceTypeChange"
            OnSaveUpdate="@SaveOrUpdateService" />

        <ListServicesCard SelectedServiceType="@selectedServiceType" ServicesByType="@ListServicesByType" />

    </div>
</div>

@code {
    int selectedServiceType = 0;
    public ServiceBaseVM? SelectedService { get; set; }
    // Biến lưu danh sách lấy từ API
    private List<ServiceTypeVM>? serviceTypesList;

    // List dùng cho cách ứng dụng tính đa hình (ListServiceCard.razor)
    public List<ServiceBaseVM> ListServicesByType = new();

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        await GetAllServiceTypes();
    }

    // 1 Hàm duy nhất trả về List service theo các type thay vì hard code viết nhiều hàm,
    // Sử dụng tính đa hình - coi trong ServiceBaseVM
    private async Task GetAllServiceTypes()
    {
        try
        {
            // Gọi API
            var response = await _httpClient.GetFromJsonAsync<ApiResponse<List<ServiceTypeVM>>>("hotel/get-all-service-types");

            if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                serviceTypesList = response.Content;
            }
        }
        catch (Exception ex)
        {
            //Xử lý lỗi(ví dụ: log lỗi, hiển thị thông báo)
            Console.WriteLine($"Lỗi khi tải ServiceTypes: {ex.Message}");
        }
    }

    private async Task HandleServiceTypeChange(ChangeEventArgs e)
    {
        // 1. Lấy giá trị 'string' từ sự kiện
        var newIdString = e.Value?.ToString();

        // 2. Chuyển sang Int
        if (int.TryParse(newIdString, out int newId))
        {
            // 3. Kiểm tra xem giá trị có thực sự thay đổi không
            if (selectedServiceType == newId)
            {
                return;
            }

            // 4. Có thay đổi thì cập nhật lại giá trị
            selectedServiceType = newId;

            await GetAllServicesByType();

            SelectedService = ServiceHelper.CreateNewServiceInstance(newId);

            // 6.
            await InvokeAsync(StateHasChanged);
        }
    }


    private async Task GetAllServicesByType()
    {
        if (selectedServiceType == 0)
        {
            ListServicesByType = new();
            return;
        }

        try
        {
            ListServicesByType = null;
            await InvokeAsync(StateHasChanged);

            // Gọi API
            var response = await
            _httpClient.GetFromJsonAsync<ApiResponse<List<ServiceBaseVM>>>($"hotel/get-all-service-by-type/{selectedServiceType}");

            if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                ListServicesByType = response.Content;
            }
            else
            {
                ListServicesByType = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task SaveOrUpdateService()
    {
        if (SelectedService == null)
        {
            // Xử lý lỗi (ví dụ: hiển thị thông báo "Vui lòng chọn loại dịch vụ")
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error, "Vui lòng chọn loại dịch vụ trước khi lưu.");
            return;
        }

        if (SelectedService.Id == 0)
        {
            string apiEndpoint = selectedServiceType switch
            {
                1 => "hotel/create-standard-service",
                2 => "hotel/create-airport-transfer-service",
                _ => throw new InvalidOperationException("Invalid service type selected.")
            };

            // Gọi API 1 LẦN duy nhất sau switch
            var response = await _httpClient.PostAsJsonAsync(apiEndpoint, SelectedService);

            // BIẾN LƯU KẾT QUẢ CUỐI CÙNG
            ApiResponse<ServiceBaseVM> finalApiResponse;

            if (response.IsSuccessStatusCode)
            {
                // THÀNH CÔNG: Đọc và hiển thị kết quả thành công
                finalApiResponse = (await response.Content.ReadFromJsonAsync<ApiResponse<ServiceBaseVM>>())
                ?? new ApiResponse<ServiceBaseVM>
                {
                    StatusCode = StatusCodeResponse.NotFound,
                    Message = MessageResponse.NOT_FOUND
                };

            }
            else // XỬ LÝ LỖI (API trả về 4xx, 5xx)
            {
                // Cố gắng đọc nội dung lỗi dưới dạng ApiResponse nếu có, nếu không, đọc Plain Text
                finalApiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<ServiceBaseVM>>()
                ?? new ApiResponse<ServiceBaseVM>
                {
                    StatusCode = StatusCodeResponse.Error,
                    Message = MessageResponse.ERROR_IN_SERVER
                };
            }

            // 3. HIỂN THỊ SNACKBAR
            SnackbarHelper.Show(Snackbar, finalApiResponse.StatusCode, finalApiResponse.Message);

            // 4. RESET
            if (finalApiResponse.StatusCode == StatusCodeResponse.Success)
            {
                SelectedService = ServiceHelper.CreateNewServiceInstance(selectedServiceType);
                await GetAllServicesByType();
                await InvokeAsync(StateHasChanged);
            }
        }
    }
}
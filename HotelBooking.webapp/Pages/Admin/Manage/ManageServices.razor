@using HotelBooking.webapp.Components.Manage.Service
@using HotelBooking.webapp.ViewModels.Hotel

@page "/admin/manages/manage-services"
@layout AdminLayout

@inject HttpClient _httpClient // Inject HttpClient để gọi API
@inject IHttpClientFactory _httpClientFactory
@inject ISnackbar Snackbar

<div class="container-fluid p-4">
    <h2 class="text-primary mb-4">Manage Services</h2>

    <div class="row">
        <ServiceCreateOrUpdateCard ServiceTypeList="@serviceTypesList" SelectedServiceType="@selectedServiceType"
            ServiceParam="@SelectedService" OnServiceTypeChanged="@HandleServiceTypeChange"
            OnSaveUpdate="@SaveOrUpdateService" />

        <ListServicesCard SelectedServiceType="@selectedServiceType" ServicesByType="@ListServicesByType"
            EventOnEdit="@EditService" EventOnDelete="@DeleteService" />

    </div>
</div>

@code {
    int selectedServiceType = 0;
    public ServiceBaseVM? SelectedService { get; set; }
    // Biến lưu danh sách lấy từ API
    private List<ServiceTypeVM>? serviceTypesList;

    // List dùng cho cách ứng dụng tính đa hình (ListServiceCard.razor)
    public List<ServiceBaseVM> ListServicesByType = new();

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        await GetAllServiceTypes();
    }

    // 1 Hàm duy nhất trả về List service theo các type thay vì hard code viết nhiều hàm,
    // Sử dụng tính đa hình - coi trong ServiceBaseVM
    private async Task GetAllServiceTypes()
    {
        try
        {
            // Gọi API
            var response = await _httpClient.GetFromJsonAsync<ApiResponse<List<ServiceTypeVM>>>("hotel/get-all-service-types");

            if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                serviceTypesList = response.Content;
            }
        }
        catch (Exception ex)
        {
            //Xử lý lỗi(ví dụ: log lỗi, hiển thị thông báo)
            Console.WriteLine($"Lỗi khi tải ServiceTypes: {ex.Message}");
        }
    }

    private async Task HandleServiceTypeChange(ChangeEventArgs e)
    {
        // 1. Lấy giá trị 'string' từ sự kiện
        var newIdString = e.Value?.ToString();

        // 2. Chuyển sang Int
        if (int.TryParse(newIdString, out int newId))
        {
            // 3. Kiểm tra xem giá trị có thực sự thay đổi không
            if (selectedServiceType == newId)
            {
                return;
            }

            // 4. Có thay đổi thì cập nhật lại giá trị
            selectedServiceType = newId;

            await GetAllServicesByType();

            SelectedService = ServiceHelper.CreateNewServiceInstance(newId);

            // 6.
            await InvokeAsync(StateHasChanged);
        }
    }


    private async Task GetAllServicesByType()
    {
        if (selectedServiceType == 0)
        {
            ListServicesByType = new();
            return;
        }

        try
        {
            ListServicesByType = null;
            await InvokeAsync(StateHasChanged);

            // Gọi API
            var response = await
            _httpClient.GetFromJsonAsync<ApiResponse<List<ServiceBaseVM>>>($"hotel/get-all-service-by-type/{selectedServiceType}");

            if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                ListServicesByType = response.Content;
            }
            else
            {
                ListServicesByType = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task SaveOrUpdateService()
    {
        // 1. Kiểm tra Null (Phòng thủ)
        if (SelectedService == null)
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error, "Vui lòng chọn loại dịch vụ trước khi lưu.");
            return;
        }

        // 2. Xác định hành động (Create hay Update)
        bool isCreate = (SelectedService.Id == 0);
        string actionKey = isCreate ? "Create" : "Update";

        // 3. Xây dựng API Endpoint động
        string apiAction = isCreate ? "create" : "update";
        string apiType = selectedServiceType switch
        {
            1 => "standard-service",
            2 => "airport-transfer-service",
            _ => throw new InvalidOperationException("Invalid service type selected.")
        };

        // Kết quả: "hotel/create-standard-service" hoặc "hotel/update-standard-service/5"
        string apiEndpoint = $"hotel/{apiAction}-{apiType}";
        if (!isCreate)
        {
            apiEndpoint += $"/{SelectedService.Id}";
        }


        // 4. Gọi API (Hợp nhất logic HTTP)
        HttpResponseMessage response;
        if (isCreate)
        {
            response = await _httpClient.PostAsJsonAsync(apiEndpoint, SelectedService);
        }
        else
        {
            response = await _httpClient.PutAsJsonAsync(apiEndpoint, SelectedService);
        }

        // 5. Xử lý phản hồi bằng Helper (Gọn gàng & Tái sử dụng)
        var finalApiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<ServiceBaseVM>>();

        SnackbarHelper.Show(Snackbar, finalApiResponse.StatusCode, finalApiResponse.Message);

        // 6. Reset Form & Tải lại danh sách (Chỉ khi thành công)
        if (finalApiResponse?.StatusCode == StatusCodeResponse.Success)
        {
            // Tạo object mới để xóa trắng form
            SelectedService = ServiceHelper.CreateNewServiceInstance(selectedServiceType);

            // Tải lại bảng dữ liệu
            await GetAllServicesByType();

            // Cập nhật UI
            await InvokeAsync(StateHasChanged);
        }
    }


    private async Task EditService(ServiceBaseVM service)
    {
        var findService = ListServicesByType.Find(svInList => svInList.Id == service.Id);

        if (findService == null) return;

        SelectedService = ServiceHelper.CreateNewServiceInstance(findService.ServiceTypeId);

        if (SelectedService == null) return;

        SelectedService.Id = findService.Id;
        SelectedService.Name = findService.Name;
        SelectedService.Description = findService.Description;

        // Ánh xạ các trường đặc thù bằng Pattern Matching
        switch (findService.ServiceTypeId)
        {
            case 1: // Standard Service
                    // Kiểm tra và ép kiểu an toàn cho cả NGUỒN và ĐÍCH
                if (findService is ServiceStandardVM sourceStandard && SelectedService is ServiceStandardVM targetStandard)
                {
                    // Ánh xạ các thuộc tính riêng biệt
                    targetStandard.Unit = sourceStandard.Unit;

                }
                break;
            default:
                break;
        }

        // Kích hoạt render để hiển thị form Edit
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteService(int id)
    {
        // Gọi API DELETE
        var response = await _httpClient.DeleteAsync($"hotel/delete-service/{id}");

        if (response.IsSuccessStatusCode)
        {
            ListServicesByType.RemoveAll(sv => sv.Id == id);
            StateHasChanged();
        }

        var finalApiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<bool>>();
        SnackbarHelper.Show(Snackbar, finalApiResponse?.StatusCode ?? "Error", finalApiResponse?.Message);

        // a. Tải lại danh sách từ Server (Đảm bảo đồng bộ dữ liệu chính xác nhất)
        await GetAllServicesByType();

        // b. Reset form về trạng thái Add New
        // (Để tránh trường hợp form đang hiển thị dữ liệu của item vừa bị xóa)
        SelectedService = ServiceHelper.CreateNewServiceInstance(selectedServiceType);

        // c. Cập nhật UI
        await InvokeAsync(StateHasChanged);
    }

}

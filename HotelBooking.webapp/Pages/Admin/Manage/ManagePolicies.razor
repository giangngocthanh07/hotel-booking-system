@using HotelBooking.webapp.Components.Manage.Policy

@page "/admin/manages/manage-policies"
@layout AdminLayout
@inject HttpClient _httpClient // Inject HttpClient để gọi API
@inject IHttpClientFactory _httpClientFactory

<div class="container-fluid p-4">
    <h2 class="text-primary mb-4">Manage Policies</h2>

    <div class="row">
        <!-- Dropdown chọn PolicyType bên trái -->
        <PolicyTypeDropDown PolicyTypeList="@policyTypesList" SelectedPolicyType="@selectedPolicyType"
            OnPolicyTypeChanged="@HandlePolicyTypeChange" />

        <!-- Bảng danh sách các Policies dựa theo PolicyType được chọn bên phải -->
        <ListPoliciesByType SelectedPolicyType="@selectedPolicyType" PoliciesByType="@policiesListByType" />

    </div>
</div>

@code {
    // PolicyType đã chọn
    int selectedPolicyType = 0;
    // Biến lưu danh sách lấy từ API
    private List<PolicyTypeVM>? policyTypesList;
    private List<PolicyVM> policiesListByType = new();
    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        await GetAllPolicyTypes();

    }

    private async Task GetAllPolicyTypes()
    {
        try
        {
            // Gọi API
            var response = await _httpClient.GetFromJsonAsync<ApiResponse<List<PolicyTypeVM>>>("hotel/get-all-policy-types");

            if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                policyTypesList = response.Content;
            }
        }
        catch (Exception ex)
        {
            //Xử lý lỗi(ví dụ: log lỗi, hiển thị thông báo)
            Console.WriteLine($"Lỗi khi tải PolicyTypes: {ex.Message}");
        }
    }

    private async Task HandlePolicyTypeChange(ChangeEventArgs e)
    {
        // 1. Lấy giá trị 'string' từ sự kiện
        var newIdString = e.Value?.ToString();

        // 2. Chuyển sang Int
        if (int.TryParse(newIdString, out int newId))
        {
            // 3. Kiểm tra xem giá trị có thực sự thay đổi không
            if (selectedPolicyType == newId)
            {
                return;
            }

            // 4. Có thay đổi thì cập nhật lại giá trị
            selectedPolicyType = newId;

            // 5. Gọi API để tải lại bảng
            await GetPoliciesListByType();

            // 6.
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task GetPoliciesListByType()
    {
        if (selectedPolicyType == 0)
        {
            policiesListByType = new();
            return;
        }

        try
        {
            policiesListByType = null;
            await InvokeAsync(StateHasChanged);

            // Gọi API
            var response = await
            _httpClient.GetFromJsonAsync<ApiResponse<List<PolicyVM>>>($"hotel/get-all-policy-by-type/{selectedPolicyType}");

            if (response != null && response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                policiesListByType = response.Content;
            }
            else
            {
                policiesListByType = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"{ex.Message}");
            policiesListByType = new();
        }
    }
}
@* @page "/admin/manages/manage-policies"
@inject IHttpClientFactory _httpClientFactory
@inject IToastService ToastService

<div class="container-fluid p-4">
    <h2 class="text-primary mb-4">Manage Policies</h2>

    <div class="row">
        <!-- Form thêm/sửa bên trái -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        @(SelectedPolicy.Id == 0 ? "Add New Policy" : "Edit Policy")
                    </h5>
                </div>
                <div class="card-body">
                    <EditForm Model="@SelectedPolicy" OnValidSubmit="SaveOrUpdatePolicy">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Policy Name</label>
                            <InputText class="form-control" @bind-Value="SelectedPolicy.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="SelectedPolicy.Description" />
                        </div>

                        <div class="d-flex">
                            <button type="submit" class="btn btn-success me-2 w-50">
                                @(SelectedPolicy.Id == 0 ? "SAVE" : "UPDATE")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <!-- Bảng danh sách bên phải -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Policies List</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:60px;">Id</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th style="width:160px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Policies.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        No policies found
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var policy in Policies)
                                {
                                    <tr>
                                        <td>@policy.Id</td>
                                        <td>@policy.Name</td>
                                        <td>@policy.Description</td>
                                        <td>
                                            <button class="btn btn-warning btn-sm me-2" @onclick="() => EditPolicy(policy)">
                                                EDIT
                                            </button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeletePolicy(policy.Id)">
                                                DELETE
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<PolicyVM> Policies = new();
    private PolicyVM SelectedPolicy = new();

    HttpClient? _httpClient;

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");
        await GetAllPolicies();
    }

    private async Task GetAllPolicies()
    {
        var apiResponse = await _httpClient.GetFromJsonAsync<ApiResponse<List<PolicyVM>>>("hotel/get-all-policies");
        if (apiResponse != null && apiResponse.StatusCode == StatusCodeResponse.Success && apiResponse.Content != null)
        {
            Policies = apiResponse.Content;
        }
        else
        {
            Policies = new List<PolicyVM>();
            ToastHelper.Show(ToastService, apiResponse?.StatusCode ?? "Error", apiResponse?.Message ?? "Failed to load policies.");
        }
    }

    private void EditPolicy(PolicyVM policy)
    {
        SelectedPolicy = new PolicyVM
        {
            Id = policy.Id,
            Name = policy.Name,
            Description = policy.Description
        };
    }

    private async Task SaveOrUpdatePolicy()
    {
        if (SelectedPolicy.Id == 0)
        {
            var response = await _httpClient.PostAsJsonAsync("hotel/create-policy", SelectedPolicy);
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<PolicyVM>>();
            ToastHelper.Show(ToastService, apiResponse?.StatusCode ?? "Error", apiResponse?.Message ?? "Failed to create policy.");
        }
        else
        {
            var response = await _httpClient.PutAsJsonAsync($"hotel/update-policy/{SelectedPolicy.Id}", SelectedPolicy);
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<PolicyVM>>();
            ToastHelper.Show(ToastService, apiResponse?.StatusCode ?? "Error", apiResponse?.Message ?? "Failed to update policy.");
        }

        await GetAllPolicies();
        SelectedPolicy = new PolicyVM(); // reset form
    }

    private async Task DeletePolicy(int id)
    {
        var response = await _httpClient.DeleteAsync($"hotel/delete-policy/{id}");
        var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();
        ToastHelper.Show(ToastService, apiResponse?.StatusCode ?? "Error", apiResponse?.Message ?? "Failed to delete policy.");

        await GetAllPolicies();
        SelectedPolicy = new PolicyVM(); // reset form
    }
} *@
@using HotelBooking.webapp.ViewModels
@using HotelBooking.webapp.ViewModels.Request

@code {
    [Parameter] public RequestStatsVM Stats { get; set; } = new();
}

<div class="row mb-4">
    @* Upgrade Request Stats *@
    <div class="col-md-3">
        <div class="card bg-light border-0 shadow-sm p-3 text-center">
            <h6>Pending</h6>
            <h2 class="text-primary">@Stats.UpgradeRequest.Pending</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-light border-0 shadow-sm p-3 text-center">
            <h6>Approved</h6>
            <h2 class="text-success">@Stats.UpgradeRequest.Approved</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-light border-0 shadow-sm p-3 text-center">
            <h6>Rejected</h6>
            <h2 class="text-danger">@Stats.UpgradeRequest.Rejected</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-light border-0 shadow-sm p-3 text-center">
            <h6>Today</h6>
            <h2 class="text-info">@Stats.TotalToday</h2>
        </div>
    </div>
</div>

@* More Stats Row *@
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted">This Week</small>
                    <h4 class="mb-0">@Stats.UpgradeRequest.ThisWeek</h4>
                </div>
                <i class="fas fa-calendar-week fa-2x text-primary opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted">This Month</small>
                    <h4 class="mb-0">@Stats.UpgradeRequest.ThisMonth</h4>
                </div>
                <i class="fas fa-calendar-alt fa-2x text-success opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted">Total</small>
                    <h4 class="mb-0">@Stats.UpgradeRequest.Total</h4>
                </div>
                <i class="fas fa-list fa-2x text-secondary opacity-50"></i>
            </div>
        </div>
    </div>
</div>
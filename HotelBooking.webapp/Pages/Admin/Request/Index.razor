@* filepath: e:\Cybersoft\FinalProject\Hotel_Blazor\HotelBooking.webapp\Pages\Admin\Request\RequestDashboard.razor *@
@page "/admin/requests/requests-overview"
@implements IDisposable
@using HotelBooking.webapp.ViewModels
@using System.Net.Http.Headers
@using HotelBooking.webapp.ViewModels.Request

@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout

@inject NavigationManager NavigationManager
@inject IHttpClientFactory _httpClientFactory
@inject Blazored.LocalStorage.ILocalStorageService _localStorage

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="w-100 mx-4">
        <PageTitle>Requests Dashboard</PageTitle>

        <h2 class="text-center mb-4">Requests Dashboard</h2>

        <div class="px-4">
            <RequestOverview Stats="@stats" />
            <RecentRequests Requests="@pagedRequests" />

            <Pagination CurrentPage="@CurrentPage" TotalPages="@TotalPages" TotalCount="@TotalCount"
                        IsLoading="@isLoading" OnPageChange="GoToPage" />
        </div>
    </div>
</div>

@code {
    private HttpClient _httpClient = null!;
    private CancellationTokenSource _cts = new();

    private List<UpgradeRequestVM> pagedRequests = new();
    private RequestStatsVM stats = new();
    private bool isLoading = false;

    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 5;
    private int TotalPages { get; set; } = 0;
    private int TotalCount { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        var token = await _localStorage.GetItemAsync<string>("accessToken");
        if (!string.IsNullOrEmpty(token))
        {
            _httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        await LoadStatsAsync();
        await LoadPagedRequestsAsync();
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            var response = await _httpClient.GetAsync("v1/admin/requests/stats", _cts.Token);
            if (response.IsSuccessStatusCode)
            {
                var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<RequestStatsVM>>();
                if (apiResponse?.Content != null)
                {
                    stats = apiResponse.Content;
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
    }

    private async Task LoadPagedRequestsAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var url = $"v1/admin/upgrade-requests?pageIndex={CurrentPage}&pageSize={PageSize}";
            var response = await _httpClient.GetAsync(url, _cts.Token);

            if (response.IsSuccessStatusCode)
            {
                var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<PagedResult<UpgradeRequestVM>>>();
                if (apiResponse?.Content != null)
                {
                    pagedRequests = apiResponse.Content.Items;
                    TotalPages = apiResponse.Content.TotalPages;
                    TotalCount = apiResponse.Content.TotalCount;
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading requests: {ex.Message}");
            pagedRequests = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages && page != CurrentPage)
        {
            CurrentPage = page;
            await LoadPagedRequestsAsync();
        }
    }

}
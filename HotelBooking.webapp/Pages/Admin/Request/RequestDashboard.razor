@page "/admin/requests/requests-overview"
@using HotelBooking.webapp.ViewModels
@using System.Net.Http.Headers

@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout

@inject NavigationManager NavigationManager
@inject IHttpClientFactory _httpClientFactory
@inject Blazored.LocalStorage.ILocalStorageService _localStorage

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">

    <div class="w-100 mx-4">
        <PageTitle>Requests Dashboard</PageTitle>

        <h2 class="text-center mb-4">Requests Dashboard</h2>

        <div class="px-4">
            <RequestOverview Stats="@stats" />
            <RecentRequests Requests="@pagedRequests" />

            @* Pagination Controls - dùng data từ BE *@
            @if (TotalPages > 0)
            {
                <div class="d-flex justify-content-center mt-4">
                    <nav aria-label="Page navigation">
                        <ul class="pagination">
                            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="PreviousPage" disabled="@isLoading">&laquo;</button>
                            </li>
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                var pageNumber = i;
                                <li class="page-item @(pageNumber == CurrentPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(pageNumber)"
                                            disabled="@isLoading">@i</button>
                                </li>
                            }
                            <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="NextPage" disabled="@isLoading">&raquo;</button>
                            </li>
                        </ul>
                    </nav>
                </div>
                <div class="text-center text-muted">
                    <small>Trang @CurrentPage / @TotalPages (Tổng: @TotalCount requests)</small>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private HttpClient _httpClient = null!;
    private List<UpgradeRequestVM> pagedRequests = new();
    private RequestStatsVM stats = new();
    private bool isLoading = false;

    // Pagination state - nhận từ BE
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 5;
    private int TotalPages { get; set; } = 0;
    private int TotalCount { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        var token = await _localStorage.GetItemAsync<string>("accessToken");
        if (!string.IsNullOrEmpty(token))
        {
            _httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        // Load stats (dùng API cũ để đếm tổng)
        await LoadStatsAsync();

        // Load page đầu tiên (dùng API mới có phân trang)
        await LoadPagedRequestsAsync();
    }

    /// <summary>
    /// Load stats count (Pending/Approved/Rejected) - dùng API cũ
    /// </summary>
    private async Task LoadStatsAsync()
    {
        try
        {
            var response = await _httpClient.GetAsync("v1/admin/Request/get-all-requests");
            if (response.IsSuccessStatusCode)
            {
                var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<List<UpgradeRequestVM>>>();
                if (apiResponse?.Content != null)
                {
                    stats.Pending = apiResponse.Content.Count(r => r.Status == "Pending");
                    stats.Approved = apiResponse.Content.Count(r => r.Status == "Approved");
                    stats.Rejected = apiResponse.Content.Count(r => r.Status == "Rejected");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"{MessageResponse.RequestManagement.UpgradeRequest.ERROR_LOADING_STATS}: {ex.Message}");
        }
    }

    /// <summary>
    /// Load requests có phân trang từ BE
    /// </summary>
    private async Task LoadPagedRequestsAsync()
    {
        isLoading = true;
        try
        {
            var url = $"v1/admin/Request/get-requests-paged?pageIndex={CurrentPage}&pageSize={PageSize}";
            var response = await _httpClient.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<PagedResult<UpgradeRequestVM>>>();
                if (apiResponse?.Content != null)
                {
                    pagedRequests = apiResponse.Content.Items;
                    TotalPages = apiResponse.Content.TotalPages;
                    TotalCount = apiResponse.Content.TotalCount;
                }
            }
            else
            {
                Console.WriteLine($"{MessageResponse.RequestManagement.UpgradeRequest.ERROR_LOADING_PAGED}. Status: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"{MessageResponse.RequestManagement.UpgradeRequest.ERROR_LOADING_PAGED}: {ex.Message}");
            pagedRequests = new List<UpgradeRequestVM>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages && page != CurrentPage)
        {
            CurrentPage = page;
            await LoadPagedRequestsAsync();
        }
    }

    private async Task PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            await LoadPagedRequestsAsync();
        }
    }

    private async Task NextPage()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
            await LoadPagedRequestsAsync();
        }
    }
}
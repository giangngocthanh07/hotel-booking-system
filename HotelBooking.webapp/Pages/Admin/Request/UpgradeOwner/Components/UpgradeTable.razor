@using HotelBooking.webapp.ViewModels.Request

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-table me-2"></i>
            Danh sách yêu cầu
            @if (!string.IsNullOrEmpty(SelectedStatus))
            {
                <span class="badge bg-secondary ms-2">@SelectedStatus</span>
            }
        </h5>
        <span class="text-muted">
            Hiển thị @DisplayCount / @TotalCount
            @if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                <span class="text-primary ms-2">(Đang tìm: "@SearchTerm")</span>
            }
        </span>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 60px;">#</th>
                    <th>Username</th>
                    <th>Họ tên</th>
                    <th>Số điện thoại</th>
                    <th>Mã số thuế</th>
                    <th>Trạng thái</th>
                    <th>Ngày yêu cầu</th>
                    <th style="width: 150px;" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (IsLoading)
                {
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 mb-0 text-muted">Đang tải dữ liệu...</p>
                        </td>
                    </tr>
                }
                else if (!Requests.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="mb-0 text-muted">
                                @if (!string.IsNullOrWhiteSpace(SearchTerm))
                                {
                                    <span>Không tìm thấy kết quả cho "<strong>@SearchTerm</strong>"</span>
                                }
                                else
                                {
                                    <span>Không có yêu cầu nào</span>
                                }
                            </p>
                        </td>
                    </tr>
                }
                else
                {
                    var index = 0;
                    @foreach (var request in Requests)
                    {
                        index++;
                        <tr>
                            <td class="text-muted">@((CurrentPage - 1) * PageSize + index)</td>
                            <td><strong>@request.UserName</strong></td>
                            <td>@request.FullName</td>
                            <td>@(string.IsNullOrEmpty(request.PhoneNumber) ? "-" : request.PhoneNumber)</td>
                            <td><code>@(string.IsNullOrEmpty(request.TaxCode) ? "-" : request.TaxCode)</code></td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(request.Status)">
                                    <i class="@GetStatusIcon(request.Status) me-1"></i>
                                    @request.Status
                                </span>
                            </td>
                            <td>
                                <small>@request.RequestedAt.ToString("dd/MM/yyyy")</small><br />
                                <small class="text-muted">@request.RequestedAt.ToString("HH:mm")</small>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-info" title="Xem chi tiết"
                                            @onclick="() => OnView.InvokeAsync(request)">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    @if (request.Status == "Pending")
                                    {
                                        <button class="btn btn-outline-success" title="Duyệt"
                                                @onclick="() => OnApprove.InvokeAsync(request)">
                                            <i class="fas fa-check"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" title="Từ chối"
                                                @onclick="() => OnReject.InvokeAsync(request)">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    @if (TotalPages > 1)
    {
        <div class="card-footer bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted">
                    Trang @CurrentPage / @TotalPages (Tổng: @TotalCount)
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(1)">
                                <i class="fas fa-angle-double-left"></i>
                            </button>
                        </li>
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(CurrentPage - 1)">
                                <i class="fas fa-angle-left"></i>
                            </button>
                        </li>
                        @foreach (var p in GetPageNumbers())
                        {
                            var pageNum = p;
                            <li class="page-item @(pageNum == CurrentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(pageNum)">
                                    @pageNum
                                </button>
                            </li>
                        }
                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(CurrentPage + 1)">
                                <i class="fas fa-angle-right"></i>
                            </button>
                        </li>
                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(TotalPages)">
                                <i class="fas fa-angle-double-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<UpgradeRequestVM> Requests { get; set; } = new List<UpgradeRequestVM>();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int TotalPages { get; set; }  // ✅ Thêm property này
    [Parameter] public int DisplayCount { get; set; }
    [Parameter] public string? SelectedStatus { get; set; }
    [Parameter] public string? SearchTerm { get; set; }

    [Parameter] public EventCallback<UpgradeRequestVM> OnView { get; set; }
    [Parameter] public EventCallback<UpgradeRequestVM> OnApprove { get; set; }
    [Parameter] public EventCallback<UpgradeRequestVM> OnReject { get; set; }
    [Parameter] public EventCallback<int> OnPageChange { get; set; }  // ✅ Thêm property này

    private IEnumerable<int> GetPageNumbers()
    {
        var start = Math.Max(1, CurrentPage - 2);
        var end = Math.Min(TotalPages, CurrentPage + 2);
        return Enumerable.Range(start, end - start + 1);
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Cancelled" => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetStatusIcon(string status) => status switch
    {
        "Pending" => "fas fa-hourglass-half",
        "Approved" => "fas fa-check",
        "Rejected" => "fas fa-times",
        "Cancelled" => "fas fa-ban",
        _ => "fas fa-question"
    };
}
@using HotelBooking.webapp.ViewModels.Request
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-warning h-100 cursor-pointer @(SelectedStatus == "Pending" ? "border-3" : "")"
             @onclick="@(() => OnStatusClick.InvokeAsync("Pending"))">
            <div class="card-body text-center">
                <i class="fas fa-hourglass-half fa-2x text-warning mb-2"></i>
                <h3 class="mb-0 text-warning">@Stats.Pending</h3>
                <small class="text-muted">Đang chờ duyệt</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success h-100 cursor-pointer @(SelectedStatus == "Approved" ? "border-3" : "")"
             @onclick="@(() => OnStatusClick.InvokeAsync("Approved"))">
            <div class="card-body text-center">
                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                <h3 class="mb-0 text-success">@Stats.Approved</h3>
                <small class="text-muted">Đã duyệt</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger h-100 cursor-pointer @(SelectedStatus == "Rejected" ? "border-3" : "")"
             @onclick="@(() => OnStatusClick.InvokeAsync("Rejected"))">
            <div class="card-body text-center">
                <i class="fas fa-times-circle fa-2x text-danger mb-2"></i>
                <h3 class="mb-0 text-danger">@Stats.Rejected</h3>
                <small class="text-muted">Đã từ chối</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-primary h-100 cursor-pointer @(string.IsNullOrEmpty(SelectedStatus) ? "border-3" : "")"
             @onclick="@(() => OnStatusClick.InvokeAsync(null))">
            <div class="card-body text-center">
                <i class="fas fa-list fa-2x text-primary mb-2"></i>
                <h3 class="mb-0 text-primary">@Stats.Total</h3>
                <small class="text-muted">Tổng cộng</small>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public RequestTypeStatsVM Stats { get; set; } = new();
    [Parameter] public string? SelectedStatus { get; set; }
    [Parameter] public EventCallback<string?> OnStatusClick { get; set; }
}
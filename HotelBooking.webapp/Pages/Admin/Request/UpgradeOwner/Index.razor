@* filepath: e:\Cybersoft\FinalProject\Hotel_Blazor\HotelBooking.webapp\Pages\Admin\Request\UpgradeOwner\Index.razor *@

@page "/admin/requests/upgrade-owner"
@using HotelBooking.webapp.Pages.Admin.Base
@using HotelBooking.webapp.Services.Interface
@inherits AdminPageBase<IRequestService>

@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout

@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<div class="container-fluid py-4">
    <PageTitle>Upgrade Owner Requests</PageTitle>

    <h2 class="text-center mb-4">Upgrade Owner Requests</h2>

    @* Stats Cards *@
    <UpgradeStatsCard Stats="@stats" OnStatusClick="FilterByStatus" />

    @* Filters *@
    <UpgradeFilters SearchTerm="@searchTerm" SelectedStatus="@selectedStatus" PageSize="@pageSize"
                    StatusList="@statusList" SearchTermChanged="OnSearchTermChanged" SelectedStatusChanged="OnSelectedStatusChanged"
                    PageSizeChanged="OnPageSizeChanged" OnApply="ApplyFilters" OnReset="ResetFilters" />

    @* Data Table *@
    <UpgradeTable Requests="@FilteredRequests" IsLoading="@isLoading" OnView="ViewDetails"                  OnApprove="ShowApproveModal"
                  OnReject="ShowRejectModal" />

    @* Pagination *@
    <Pagination CurrentPage="@currentPage" TotalPages="@totalPages" TotalCount="@totalCount" IsLoading="@isLoading"
                OnPageChange="GoToPage" />
</div>

@* Confirm Modal *@
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header @modalHeaderClass text-white">
                <h5 class="modal-title">
                    <i class="@modalIcon me-2"></i>@modalTitle
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>@modalMessage</p>
                @if (selectedRequest != null)
                {
                    <div class="alert alert-light">
                        <strong>Request ID:</strong> @selectedRequest.RequestId<br />
                        <strong>User:</strong> @selectedRequest.FullName (@selectedRequest.UserName)
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn @modalBtnClass" @onclick="ConfirmAction" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Confirm
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private CancellationTokenSource _cts = new();

    // Data
    private List<UpgradeRequestVM> requests = new();
    private List<string> statusList = new() { "Pending", "Approved", "Rejected", "Cancelled" };
    private RequestTypeStatsVM stats = new();

    // Paging & Filters
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 0;
    private int totalCount = 0;
    private string searchTerm = "";
    private string? selectedStatus = null;

    // State
    private bool isLoading = false;
    private bool isProcessing = false;

    // Modal
    private UpgradeRequestVM? selectedRequest;
    private string modalTitle = "";
    private string modalMessage = "";
    private string modalHeaderClass = "bg-primary";
    private string modalBtnClass = "btn-primary";
    private string modalIcon = "fas fa-question-circle";
    private string actionType = "";

    // Client-side filter
    private IEnumerable<UpgradeRequestVM> FilteredRequests => string.IsNullOrWhiteSpace(searchTerm)
        ? requests
        : requests.Where(r =>
            r.RequestId.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (r.UserName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (r.FullName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (r.PhoneNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (r.TaxCode?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (r.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
        );

    // ==========================================
    // LIFECYCLE (Override base class)
    // ==========================================

    /// <summary>
    /// Override LoadDataAsync từ AdminPageBase - được gọi tự động sau khi token được set.
    /// </summary>
    protected override async Task LoadDataAsync()
    {
        await LoadStatsAsync();
        await LoadRequestsAsync();
    }

    public override void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        base.Dispose();
    }

    // ==========================================
    // DATA LOADING
    // ==========================================

    private async Task LoadStatsAsync()
    {
        try
        {
            var response = await Service.GetStatsAsync();
            if (response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                stats = response.Content.UpgradeRequest;
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
    }

    private async Task LoadRequestsAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Service.GetUpgradeRequestsAsync(currentPage, pageSize, selectedStatus);

            if (response.StatusCode == StatusCodeResponse.Success && response.Content != null)
            {
                requests = response.Content.Items;
                totalPages = response.Content.TotalPages;
                totalCount = response.Content.TotalCount;
            }
            else
            {
                requests = new();
                SnackbarHelper.Show(Snackbar, response.StatusCode ?? StatusCodeResponse.Error, response.Message ??
MessageResponse.Common.ERROR_IN_SERVER);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading requests: {ex.Message}");
            requests = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ==========================================
    // EVENT HANDLERS (From Components)
    // ==========================================

    private void OnSearchTermChanged(string value) => searchTerm = value;

    private async Task OnSelectedStatusChanged(string? value)
    {
        selectedStatus = value;
        currentPage = 1;
        await LoadRequestsAsync();
    }

    private async Task OnPageSizeChanged(int value)
    {
        pageSize = value;
        currentPage = 1;
        await LoadRequestsAsync();
    }

    private async Task FilterByStatus(string? status)
    {
        selectedStatus = status;
        currentPage = 1;
        await LoadRequestsAsync();
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        await LoadRequestsAsync();
    }

    private async Task ResetFilters()
    {
        searchTerm = "";
        selectedStatus = null;
        pageSize = 10;
        currentPage = 1;
        await LoadRequestsAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages && page != currentPage)
        {
            currentPage = page;
            await LoadRequestsAsync();
        }
    }

    // ==========================================
    // ACTIONS
    // ==========================================

    private void ViewDetails(UpgradeRequestVM request)
    {
        Navigation.NavigateTo($"/admin/requests/upgrade-owner/{request.RequestId}");
    }

    private async Task ShowApproveModal(UpgradeRequestVM request)
    {
        selectedRequest = request;
        modalTitle = "Confirm Approval";
        modalMessage = "Are you sure you want to APPROVE this request? The user will be upgraded to Owner.";
        modalHeaderClass = "bg-success";
        modalBtnClass = "btn-success";
        modalIcon = "fas fa-check-circle";
        actionType = "approve";
        await JSRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('confirmModal')).show()");
    }

    private async Task ShowRejectModal(UpgradeRequestVM request)
    {
        selectedRequest = request;
        modalTitle = "Confirm Rejection";
        modalMessage = "Are you sure you want to REJECT this request?";
        modalHeaderClass = "bg-danger";
        modalBtnClass = "btn-danger";
        modalIcon = "fas fa-times-circle";
        actionType = "reject";
        await JSRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('confirmModal')).show()");
    }

    private async Task ConfirmAction()
    {
        if (selectedRequest == null) return;

        isProcessing = true;
        StateHasChanged();

        try
        {
            var response = actionType == "approve"
                ? await Service.ApproveUpgradeRequestAsync(selectedRequest.RequestId)
                : await Service.RejectUpgradeRequestAsync(selectedRequest.RequestId);

            SnackbarHelper.Show(Snackbar, response.StatusCode ?? StatusCodeResponse.Error, response.Message ??
MessageResponse.Common.ERROR_IN_SERVER);

            if (response.StatusCode == StatusCodeResponse.Success)
            {
                await JSRuntime.InvokeVoidAsync("eval",
                    "bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide()");
                await LoadStatsAsync();
                await LoadRequestsAsync();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error, ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}

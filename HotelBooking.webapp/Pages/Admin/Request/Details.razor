@* filepath: e:\Cybersoft\FinalProject\Hotel_Blazor\HotelBooking.webapp\Pages\Admin\Request\RequestDetails.razor *@
@page "/admin/requests/details/{RequestId:int}"
@page "/admin/upgrade-requests/{RequestId:int}"
@implements IDisposable
@using System.Net.Http.Headers
@using HotelBooking.webapp.Helpers.Common
@using HotelBooking.webapp.ViewModels.Request

@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout

@inject NavigationManager NavigationManager
@inject IHttpClientFactory _httpClientFactory
@inject Blazored.LocalStorage.ILocalStorageService _localStorage
@inject ISnackbar Snackbar

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-sm" style="min-width: 600px;">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Request Details #@RequestId</h4>
            <button class="btn btn-secondary" @onclick="NavigateBack">
                <i class="fas fa-arrow-left"></i> Back
            </button>
        </div>
        <div class="card-body">
            @if (request != null)
            {
                <form class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" value="@request.UserName" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" value="@request.FullName" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input type="text" class="form-control" value="@request.PhoneNumber" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tax Code</label>
                        <input type="text" class="form-control" value="@request.TaxCode" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <input type="text"                               class="form-control text-white fw-bold @GetStatusBadgeClass(request.Status)"
                               value="@request.Status" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Requested At</label>
                        <input type="text" class="form-control" value="@request.RequestedAt.ToString("dd/MM/yyyy HH:mm")"
                               readonly />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Address</label>
                        <textarea class="form-control" rows="2" readonly>@request.Address</textarea>
                    </div>
                </form>

                @if (request.Status == "Pending")
                {
                    <div class="mt-4 row">
                        <div class="col-md-6">
                            <button class="btn btn-success btn-lg w-100" @onclick="ApproveRequest" disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="fas fa-check"></i> Approve
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-danger btn-lg w-100" @onclick="RejectRequest" disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="fas fa-times"></i> Reject
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int RequestId { get; set; }

    private HttpClient _httpClient = null!;
    private CancellationTokenSource _cts = new();

    private UpgradeRequestVM? request;
    private bool isProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        _httpClient = _httpClientFactory.CreateClient("HotelBookingAPI");

        var token = await _localStorage.GetItemAsync<string>("accessToken");
        if (!string.IsNullOrEmpty(token))
        {
            _httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        await LoadRequestDetails();
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private async Task LoadRequestDetails()
    {
        try
        {
            var response = await _httpClient.GetAsync($"v1/admin/upgrade-requests/{RequestId}", _cts.Token);

            if (response.IsSuccessStatusCode)
            {
                var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<UpgradeRequestVM>>();
                if (apiResponse?.Content != null)
                {
                    request = apiResponse.Content;
                }
                else
                {
                    SnackbarHelper.Show(Snackbar, StatusCodeResponse.NotFound, MessageResponse.RequestManagement.Request.NOT_FOUND);
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            SnackbarHelper.Show(Snackbar, StatusCodeResponse.Error,
MessageResponse.RequestManagement.Request.ERROR_LOADING_DETAILS);
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/admin/requests/requests-overview");
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        UpgradeRequestStatusConst.Pending => "bg-primary",
        UpgradeRequestStatusConst.Approved => "bg-success",
        UpgradeRequestStatusConst.Rejected => "bg-danger",
        UpgradeRequestStatusConst.Cancelled => "bg-secondary",
        _ => "bg-secondary"
    };

    private async Task ApproveRequest()
    {
        if (isProcessing) return;

        isProcessing = true;
        StateHasChanged();

        try
        {
            var response = await _httpClient.PostAsync($"v1/admin/upgrade-requests/{RequestId}/approve", null, _cts.Token);
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();

            if (apiResponse != null && !string.IsNullOrEmpty(apiResponse.StatusCode))
            {
                SnackbarHelper.Show(Snackbar, apiResponse.StatusCode, apiResponse.Message ?? string.Empty);
            }

            if (response.IsSuccessStatusCode)
            {
                request!.Status = UpgradeRequestStatusConst.Approved;
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task RejectRequest()
    {
        if (isProcessing) return;

        isProcessing = true;
        StateHasChanged();

        try
        {
            var response = await _httpClient.PostAsync($"v1/admin/upgrade-requests/{RequestId}/reject", null, _cts.Token);
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();

            if (apiResponse != null && !string.IsNullOrEmpty(apiResponse.StatusCode))
            {
                SnackbarHelper.Show(Snackbar, apiResponse.StatusCode, apiResponse.Message ?? string.Empty);
            }

            if (response.IsSuccessStatusCode)
            {
                request!.Status = UpgradeRequestStatusConst.Rejected;
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}
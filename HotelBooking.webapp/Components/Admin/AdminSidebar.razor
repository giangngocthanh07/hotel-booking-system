    }

    .nav-link:not(.active):hover {
        background-color: rgba(255, 255, 255, 0.08);
        color: #fff !important;
        padding-left: 16px;
    }

    .nav-link:hover i {
        transform: scale(1.1);
        color: #fff;
    }

    /* Active State NavLink */
    .nav-link.active {
        color: #fff !important;
        background-color: rgba(255, 255, 255, 0.1);
    }

    /* Sub-link Active */
    .sub-link.active {
        background-color: #0d6efd !important;
        color: #fff !important;
        font-weight: 600;
    }

    /* Sub-link padding */
    .sub-link {
        font-size: 0.85rem;
        padding: 8px 10px;
        border-radius: 6px;
    }

    /* Collapse logic styles */
    .nav-link[data-bs-toggle="collapse"][aria-expanded="true"] {
        color: #fff !important;
    }

    .nav-link[aria-expanded="true"] .transition-icon {
        transform: rotate(180deg);
    }

    .transition-icon {
        transition: transform 0.3s ease;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #495057;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #6c757d;
    }

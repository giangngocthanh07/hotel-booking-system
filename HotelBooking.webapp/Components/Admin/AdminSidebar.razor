        font-weight: 700;
        color: #6c757d;
        letter-spacing: 0.5px;
    }

    .nav-link {
        color: #adb5bd !important;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        font-weight: 500;
        font-size: 0.9rem;
        cursor: pointer;
    }

    .nav-link i {
        font-size: 1.1rem;
        margin-right: 12px;

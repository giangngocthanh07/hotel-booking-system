<div class="col-md-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3>Chọn loại chính sách</h3>


        </div>
        <div class="card-body">
            @if (PolicyTypeList == null)
            {
                <p><em>Đang tải danh sách...</em></p>
            }
            else
            {
                <div class="form-group">
                    <label class="mb-3">Loại chính sách:</label>

                    <select class="form-control" value="@SelectedPolicyType" @onchange="OnPolicyTypeChanged">

                        <option value="0">-- Vui lòng chọn --</option>
                        @foreach (var type in PolicyTypeList)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    </select>
                </div>

                <hr />

                @if (SelectedPolicyType > 0)
                {
                    <p><strong>Bạn chọn:</strong> @SelectedPolicyType</p>
                }
            }
        </div>
        <hr />
        @if (SelectedPolicyType != 0 || SelectedPolicyType > 0)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        @(PolicyParam.Id == 0 ? "Add New Policy" : "Edit Policy")
                    </h5>
                </div>

                <div class="card-body">
                    <EditForm Model="@PolicyParam" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        @* <ValidationSummary /> *@

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="PolicyParam.Name" />
                            <ValidationMessage For="@(() => PolicyParam.Name)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputText class="form-control" @bind-Value="PolicyParam.Description" />
                            <ValidationMessage For="@(() => PolicyParam.Description)" class="text-danger" />
                        </div>

                        <div class="d-flex">
                            <button type="submit" class="btn btn-success me-2 w-100">
                                @(PolicyParam.Id == 0 ? "SAVE" : "UPDATE")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

    </div>
</div>


@code {
    //
    [Parameter]
    public PolicyVM PolicyParam { get; set; }
    //
    [Parameter]
    public int SelectedPolicyType { get; set; }
    //
    [Parameter]
    public List<PolicyTypeVM> PolicyTypeList { get; set; }
    // Biến này sẽ tự động cập nhật khi người dùng chọn
    // Đây chính là "data type mà được chọn" mà bạn muốn lưu lại

    [Parameter]
    public EventCallback<ChangeEventArgs> OnPolicyTypeChanged { get; set; }

    [Parameter]
    public EventCallback<PolicyVM> OnSaveUpdate { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnSaveUpdate.InvokeAsync(PolicyParam);
    }

}
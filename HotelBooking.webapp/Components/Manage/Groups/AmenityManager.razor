@using HotelBooking.webapp.Pages.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ĐỊNH NGHĨA ROUTING --- *@
@page "/admin/manage/amenity"
@page "/admin/manage/amenity/{TypeId:int}"

@* --- 2. SỬ DỤNG LAYOUT ADMIN CHUNG --- *@
@layout AdminLayout
@inject ILogger<AmenityManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING (Check cờ từ Cha) --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Đang tải dữ liệu...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="AmenityVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items"
        Model="@GetModel()" PageIndex="_paging.PageIndex ?? 1" TotalPages="_totalPages" TotalCount="_totalCount"
        OnPageChanged="HandlePageChanged" OnSubmit="SaveData" OnEdit="OnEditItem" OnDelete="HandleDelete"
        OnCancel="ResetForm">

        @* --- A. CẤU HÌNH MENU BÊN TRÁI (THÔNG QUA RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* NHÚNG COMPONENT MENU THÔNG MINH VÀO ĐÂY *@
            @* Nó tự biết đường vẽ ra Dropdown *@
            <GlobalNavMenu CurrentModule="Amenity" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. CẤU HÌNH FORM (Tiện nghi mặc định MIỄN PHÍ) --- *@
        <FormContent Context="m">

            @* --- 1. ICON PREVIEW --- *@
            @* Vì Layout không có chỗ hiện Icon cạnh ô Name, ta hiện 1 bản preview nhỏ ở đây *@
            <div
                class="d-flex align-items-center mb-3 p-2 border rounded bg-light shadow-sm animate__animated animate__fadeIn">
                <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm me-3"
                    style="width: 45px; height: 45px;">
                    <i class="@GetAmenityIcon(m.Name) fs-4 text-success"></i>
                </div>
                <div>
                    <div class="extra-small text-muted fw-bold text-uppercase">Icon nhận diện</div>
                    <div class="small fw-bold text-dark">@(string.IsNullOrEmpty(m.Name) ? "Đang chờ tên..." : m.Name)</div>
                </div>
            </div>

            <div class="card border-success bg-success bg-opacity-10 mb-3">
                <div class="card-body py-2 d-flex align-items-center">
                    <i class="fa-solid fa-circle-check text-success me-2"></i>
                    <span class="small fw-bold text-success">Tiện nghi phòng luôn được mặc định MIỄN PHÍ.</span>
                </div>
            </div>
        </FormContent>

        @* --- C. CẤU HÌNH BẢNG (Giao diện chuẩn hóa) --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">Id</th>
            <th class="text-center" style="width: 80px;">Icon</th>
            <th class="text-center" style="width: 300px;">Tên tiện nghi</th>
            <th class="text-center">Mô tả / Ghi chú</th> @* Cột này sẽ tự co giãn (Flexible) *@
            <th class="text-center" style="width: 120px;">Phân loại</th>
            <th class="text-center" style="width: 100px;">Trạng thái</th>
        </TableHeader>

        <RowTemplate Context="row">
            @* 1. ID - Căn giữa *@
            <td class="text-center text-muted small">@row.Id</td>

            @* 2. Icon - Căn giữa *@
            <td class="text-center">
                <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center shadow-sm mx-auto"
                    style="width: 32px; height: 32px;">
                    <i class="@GetAmenityIcon(row.Name) text-success"></i>
                </div>
            </td>

            @* 3. Tên  *@
            <td class="text-center align-middle text-dark">
                @row.Name
            </td>

            @* 4. MÔ TẢ - Căn giữa dấu --- *@
            <td class="text-center align-middle text-truncate">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    @* Giới hạn width để không đẩy bảng *@
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 280px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>

            @* 5. Loại - Căn giữa *@
            <td class="text-center">
                <span class="badge bg-light text-secondary border px-2 py-1" style="font-size: 0.75rem;">
                    <i class="fa-solid fa-tag me-1"></i>Group #@row.TypeId
                </span>
            </td>

            @* 6. Trạng thái - Căn giữa *@
            <td class="text-center">
                <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-1">
                    Free
                </span>
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}


@code {
    // --- PARAMETERS TỪ URL ---
    // Tự động nhận giá trị từ URL /admin/manage/amenity/{TypeId}
    [Parameter] public int? TypeId { get; set; }

    // --- STATE ---
    private List<AmenityVM>? _items;
    private AmenityCreateVM _createModel = new AmenityCreateVM();
    private AmenityUpdateVM _updateModel = new AmenityUpdateVM();
    private int _currentEditingId = 0; // Lưu ID khi edit
    private bool _isUpdate = false;


    // --- QUẢN LÝ PHÂN TRANG ---
    // Khởi tạo request: Trang 1, Size 10
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;


    // Biến kiểm soát vòng đời & Re-render
    private int? _previousTypeId = -999;

    // --- HELPER: Tự động chọn Icon dựa trên tên tiện nghi ---
    private string GetAmenityIcon(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "fa-solid fa-plus-circle";

        var n = name.ToLower();

        // Nhóm Vệ sinh / Phòng tắm
        if (n.Contains("towel") || n.Contains("khăn") || n.Contains("soap") || n.Contains("xà bông") || n.Contains("shampoo"))
            return "fa-solid fa-pump-soap";
        if (n.Contains("toilet") || n.Contains("vệ sinh") || n.Contains("shower") || n.Contains("vòi"))
            return "fa-solid fa-shower";

        // Nhóm Điện tử / Giải trí
        if (n.Contains("tv") || n.Contains("tivi") || n.Contains("television")) return "fa-solid fa-tv";
        if (n.Contains("wifi") || n.Contains("mạng") || n.Contains("internet")) return "fa-solid fa-wifi";
        if (n.Contains("phone") || n.Contains("điện thoại")) return "fa-solid fa-phone";

        // Nhóm Đồ gia dụng
        if (n.Contains("fan") || n.Contains("quạt")) return "fa-solid fa-fan";
        if (n.Contains("heat") || n.Contains("sưởi")) return "fa-solid fa-temperature-arrow-up";
        if (n.Contains("air cond") || n.Contains("máy lạnh") || n.Contains("điều hòa")) return "fa-solid fa-snowflake";
        if (n.Contains("safe") || n.Contains("két")) return "fa-solid fa-vault";
        if (n.Contains("desk") || n.Contains("bàn làm việc")) return "fa-solid fa-table";

        return "fa-solid fa-check-circle"; // Mặc định
    }

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? (BaseCreateOrUpdateAdminVM)_updateModel :
    (BaseCreateOrUpdateAdminVM)_createModel;

    private MasterDetailLayout<AmenityVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- LIFECYCLE ---
    // --- 1. LOAD DATA (Override từ Cha) ---
    protected override async Task LoadDataAsync()
    {
        // Reset UI loading
        _items = null;
        StateHasChanged();

        try
        {
            // Gọi API (Dùng 'Service' của Cha)
            var res = await Service.GetAmenitiesByType(TypeId, _paging);

            if (!Disposed) // Check cờ 'Disposed' của Cha
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    _items = res.Content.Items;
                    _totalPages = res.Content.TotalPages;
                    _totalCount = res.Content.TotalCount;
                }
                else
                {
                    _items = new List<AmenityVM>();
                    if (res.StatusCode != StatusCodeResponse.Success)
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi load data amenity");
            _items = new List<AmenityVM>();
        }
    }

    protected override void OnInitialized()
    {
        // Ép Model đúng kiểu ngay khi component vừa được tạo ra
        ResetForm();
    }

    // 2. OnAfterRenderAsync: Nơi DUY NHẤT an toàn để gọi LocalStorage lần đầu
    // --- 2. XỬ LÝ CHUYỂN TAB ---
    protected override async Task OnParametersSetAsync()
    {
        if (TypeId == null) TypeId = 1;

        // Nếu TypeId thay đổi thì mới load lại
        if (TypeId != _previousTypeId)
        {
            _previousTypeId = TypeId;
            ResetForm();

            if (IsJsReady)
            {
                _paging.PageIndex = 1;
                await LoadDataAsync();
            }
        }
    }

    // --- HÀM XỬ LÝ KHI BẤM CHUYỂN TRANG ---
    private async Task HandlePageChanged(int newPage)
    {
        // Cập nhật số trang mới vào Request
        _paging.PageIndex = newPage;
        // Gọi lại API
        await LoadDataAsync();
    }

    // --- CRUD METHODS ---
    private void OnEditItem(AmenityVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id; // Lưu ID lại

        _updateModel = new AmenityUpdateVM
        {
            Name = item.Name,
            Description = item.Description
            // Không map TypeId vì UpdateVM không có chứa nó
        };

        StateHasChanged();

        // Đảm bảo khi mở form Edit, các lỗi cũ không bị "nhảy" ra
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(AmenityVM item)
    {
        // Gọi API xóa thực tế
        var res = await Service.DeleteAmenity(item.Id);

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            // Xóa thành công thì load lại bảng
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        // Reset CreateVM (Nhớ gán TypeId hiện tại)
        _createModel = new AmenityCreateVM
        {
            TypeId = TypeId ?? 0
        };
        _updateModel = new AmenityUpdateVM();

        StateHasChanged();

        // Xóa sạch dấu vết lỗi của lần nhập trước
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        ApiResponse<AmenityVM> res;

        if (_isUpdate) res = await Service.UpdateAmenity(_currentEditingId, _updateModel);
        else
        {
            // [THAY ĐỔI 4] Gọi Create API (Gửi CreateVM có TypeId)
            // Đảm bảo TypeId luôn đúng
            _createModel.TypeId = TypeId ?? 0;
            res = await Service.CreateAmenity(_createModel);
        }

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
            ResetForm();
        }
    }
}
@using HotelBooking.webapp.Pages.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ĐỊNH NGHĨA ROUTING --- *@
@page "/admin/manage/roomview"

@* --- 2. SỬ DỤNG LAYOUT ADMIN CHUNG --- *@
@layout AdminLayout
@inject ILogger<RoomViewManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING (Kiểm soát bởi Class Cha) --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Đang tải dữ liệu...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="RoomViewVM" TModel="BaseCreateOrUpdateAdminVM" Items="items"
                        Model="@GetModel()" PageIndex="_paging.PageIndex ?? 1" TotalPages="totalPages" TotalCount="totalCount"
                        OnPageChanged="HandlePageChanged" OnSubmit="SaveData" IsEditMode="_isUpdate" OnEdit="OnEditItem"
                        OnDelete="HandleDelete"               OnCancel="ResetForm">

        @* --- A. CẤU HÌNH MENU BÊN TRÁI (THÔNG QUA RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* NHÚNG COMPONENT MENU THÔNG MINH VÀO ĐÂY *@
            @* Nó tự biết đường vẽ ra Dropdown *@
            <GlobalNavMenu CurrentModule="RoomView" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. CẤU HÌNH FORM (Đã tút tát lại) --- *@
        <FormContent Context="m">

            @* 3. PREVIEW ICON *@
            @* Lấy tên hiện tại để preview *@
            @{
                string currentName = _isUpdate ? _updateModel.Name : _createModel.Name;
            }
            @if (!string.IsNullOrEmpty(currentName))
            {
                <div class="alert alert-light border d-flex align-items-center">
                    <div class="me-3">
                        @* Gọi hàm Helper bên dưới để lấy icon *@
                        <div class="rounded-circle bg-white border d-flex align-items-center justify-content-center shadow-sm"
                             style="width: 40px; height: 40px;">
                            <i class="@GetViewIcon(currentName) text-primary"></i>
                        </div>
                    </div>
                    <div>
                        <small class="text-muted d-block">Minh họa hiển thị:</small>
                        <strong class="text-dark">@currentName</strong>
                    </div>
                </div>
            }
        </FormContent>

        @* --- C. CẤU HÌNH BẢNG (Thêm cột Icon & Trạng thái) --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">Id</th>
            <th class="text-center" style="width: 80px;">Icon</th> @* Cột mới *@
            <th class="text-center" style="width: 320px;">Tên hướng nhìn</th>
            <th class="text-center">Mô tả</th>
            <th class="text-center" style="width: 150px;">Trạng thái</th> @* Cột lấp chỗ trống *@
        </TableHeader>

        <RowTemplate Context="row">
            <td class="text-center text-muted small">@row.Id</td>

            @* Cột Icon tự động *@
            <td class="text-center">
                <i class="@GetViewIcon(row.Name) fs-5 text-secondary opacity-75"></i>
            </td>

            <td class="text-center align-middle text-primary">
                @row.Name
            </td>

            <td class="text-center align-middle text-muted small text-truncate" style="max-width: 500px;"
                title="@row.Description">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    @* Giới hạn width để không đẩy bảng *@
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 500px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>

            @* Cột trạng thái giả lập (cho đỡ trống) *@
            <td class="text-center">
                <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 rounded-pill">
                    Hoạt động
                </span>
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}


@code {
    // --- PARAMETERS TỪ URL ---
    // Tự động nhận giá trị từ URL /admin/manage/roomview
    [Parameter] public int? TypeId { get; set; }

    // --- STATE ---
    private List<RoomViewVM>? items;

    // Tách Model
    private RoomViewCreateVM _createModel = new RoomViewCreateVM();
    private RoomViewUpdateVM _updateModel = new RoomViewUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;
    // --- PHÂN TRANG ---
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int totalPages = 0;
    private int totalCount = 0;

    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? (BaseCreateOrUpdateAdminVM)_updateModel :
    (BaseCreateOrUpdateAdminVM)_createModel;

    private MasterDetailLayout<RoomViewVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- HELPER: Tự động chọn Icon dựa trên tên ---
    private string GetViewIcon(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "fa-solid fa-image"; // Mặc định

        name = name.ToLower();

        // 1. Biển / Hồ / Nước
        if (name.Contains("sea") || name.Contains("ocean") || name.Contains("lake") || name.Contains("pool") ||
        name.Contains("biển") || name.Contains("hồ"))
            return "fa-solid fa-water";

        // 2. Vườn / Cây / Rừng / Núi
        if (name.Contains("garden") || name.Contains("forest") || name.Contains("mountain") || name.Contains("hill") ||
        name.Contains("vườn") || name.Contains("núi"))
            return "fa-solid fa-tree";

        // 3. Thành phố / Phố
        if (name.Contains("city") || name.Contains("street") || name.Contains("landmark") || name.Contains("phố"))
            return "fa-solid fa-city";

        // 4. Mặc định
        return "fa-solid fa-street-view";
    }

    // --- 1. LOAD DATA (Override từ Cha) ---
    protected override async Task LoadDataAsync()
    {
        // Reset UI Loading
        items = null;
        StateHasChanged();

        try
        {
            // Gọi API Lấy tất cả (Non-Type) - Dùng 'Service' của Cha
            var res = await Service.GetRoomViews(_paging);

            if (!Disposed) // Check cờ Disposed từ Cha
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    items = res.Content.Items;
                    totalPages = res.Content.TotalPages;
                    totalCount = res.Content.TotalCount;
                }
                else
                {
                    items = new List<RoomViewVM>();

                    if (res.StatusCode != StatusCodeResponse.Success)
                    {
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi load data roomview");
            items = new List<RoomViewVM>();
        }
    }

    protected override void OnInitialized()
    {
        // Ép Model đúng kiểu ngay khi component vừa được tạo ra
        ResetForm();
    }

    // --- 2. XỬ LÝ PARAMETERS ---
    protected override async Task OnParametersSetAsync()
    {
        ResetForm();

        if (IsJsReady)
        {
            await LoadDataAsync();
        }
    }
    // --- XỬ LÝ CHUYỂN TRANG ---
    private async Task HandlePageChanged(int newPage)
    {
        _paging.PageIndex = newPage;
        await LoadDataAsync();
    }

    // --- CRUD METHODS ---
    private void OnEditItem(RoomViewVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        // Map sang UpdateVM
        _updateModel = new RoomViewUpdateVM
        {
            Name = item.Name,
            Description = item.Description
        };

        StateHasChanged();

        // Đảm bảo khi mở form Edit, các lỗi cũ không bị "nhảy" ra
        _layoutRef?.TriggerValidate();
    }

    private async Task HandleDelete(RoomViewVM item)
    {
        // Gọi API xóa thực tế
        var res = await Service.DeleteRoomView(item.Id);

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            // Xóa thành công thì load lại bảng
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        // Reset CreateVM
        _createModel = new RoomViewCreateVM();
        _updateModel = new RoomViewUpdateVM();

        StateHasChanged();

        // Đảm bảo khi mở form Edit, các lỗi cũ không bị "nhảy" ra
        _layoutRef?.TriggerValidate();
    }

    private async Task SaveData()
    {
        ApiResponse<RoomViewVM> res;
        if (_isUpdate) res = await Service.UpdateRoomView(_currentEditingId, _updateModel);
        else res = await Service.CreateRoomView(_createModel);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            // Hiển thị thông báo
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
            await LoadDataAsync();
            ResetForm();
        }
        else
        {
            // KHÔNG gọi ResetForm() nếu có lỗi từ Server (như trùng tên)
            // Dữ liệu vẫn nằm nguyên trong _updateModel để Admin sửa tiếp
            SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
        }
    }

}
@using HotelBooking.webapp.Pages.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ĐỊNH NGHĨA ROUTING --- *@
@page "/admin/manage/policy"
@page "/admin/manage/policy/{TypeId:int}"

@* --- 2. SỬ DỤNG LAYOUT ADMIN CHUNG --- *@
@layout AdminLayout
@inject ILogger<PolicyManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING (Kiểm soát bởi Class Cha) --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Đang tải dữ liệu...</span>
    </div>
}
else
{
    <MasterDetailLayout @ref="_layoutRef" TItem="PolicyVM" TModel="BaseCreateOrUpdateAdminVM" Items="items" Model="@GetModel()"
        PageIndex="_paging.PageIndex ?? 1" TotalPages="totalPages" TotalCount="totalCount" OnPageChanged="HandlePageChanged"
        OnSubmit="SaveData" OnEdit="OnEditItem" OnDelete="HandleDelete" OnCancel="ResetForm" OnNameBlur="SuggestDefaultValues">

        @* --- A. CẤU HÌNH MENU BÊN TRÁI (THÔNG QUA RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* NHÚNG COMPONENT MENU THÔNG MINH VÀO ĐÂY *@
            @* Nó tự biết đường vẽ ra Dropdown *@
            <GlobalNavMenu CurrentModule="Policy" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. CẤU HÌNH FORM (Mở khóa để Admin thiết lập mẫu) --- *@
        <FormContent Context="m">
            @* LƯU Ý: Biến 'm' ở đây chính là Model được Layout truyền xuống qua @FormContent(Model).
           Vì TModel được ràng buộc là BaseCreateOrUpdateAdminVM, bạn có thể truy cập 
           các thuộc tính chung. Tuy nhiên, các thuộc tính riêng của Policy (Percent, Amount...) 
           cần được xử lý khéo léo để đảm bảo Strong Type.
            *@

            @* --- HELPER VALIDATION NỘI BỘ (Chống lỗi FullConditionalExpression) --- *@
            @{
                // Switcher Validation để trỏ đúng model con
                RenderFragment RenderVal(string prop) => __builder => {
                    @if (_isUpdate) {
                        if (prop == "Amount") { <ValidationMessage For="() => _updateModel.Amount" class="val-msg" /> }
                        else if (prop == "Percent") { <ValidationMessage For="() => _updateModel.Percent" class="val-msg" /> }
                        else if (prop == "IntValue1") { <ValidationMessage For="() => _updateModel.IntValue1" class="val-msg" /> }
                    } else {
                        if (prop == "Amount") { <ValidationMessage For="() => _createModel.Amount" class="val-msg" /> }
                        else if (prop == "Percent") { <ValidationMessage For="() => _createModel.Percent" class="val-msg" /> }
                        else if (prop == "IntValue1") { <ValidationMessage For="() => _createModel.IntValue1" class="val-msg" /> }
                        }
                };
            }

            @* --- CASE 1002: CHECK-IN / CHECK-OUT --- *@
            @if (TypeId == 1002)
            {
                @* ----- SET TRẠNG THÁI CHO PHẦN AMOUNT -----*@
                // Lấy giá trị hiện tại để xác định trạng thái Switch
                decimal currentAmt = _isUpdate ? (_updateModel.Amount ?? 0) : (_createModel.Amount ?? 0);
                bool isPaid = currentAmt > 0;

                @* ----- SET TRẠNG THÁI CHO PHẦN KHUNG GIỜ -----*@
                // 1. Lấy giá trị hiện tại
                var tFrom = _isUpdate ? _updateModel.TimeFrom : _createModel.TimeFrom;
                var tTo = _isUpdate ? _updateModel.TimeTo : _createModel.TimeTo;

                // 2. Logic tính tổng số giờ
                double totalHours = 0;
                if (tFrom.HasValue && tTo.HasValue)
                {
                    var diff = tTo.Value - tFrom.Value;
                    totalHours = diff.TotalHours;
                    // Nếu trả phòng < nhận phòng (thuê xuyên đêm), cộng thêm 24h
                    if (totalHours <= 0) totalHours += 24; 
                }

                // 3. Biến kiểm tra lỗi (Lỗi nếu thời gian ở > 12 tiếng)
                bool isInvalidTime = totalHours > 23;

                @* --- 1a. NÚT GẠT CHỌN MIỄN PHÍ / TÍNH PHÍ --- *@
                <h6 class="text-primary fw-bold mb-3"><i class="fa-regular fa-clock me-2"></i>Khung giờ & Phụ thu</h6>
                <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between mb-3 shadow-sm">
                    <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                        <i class="fa-solid fa-hand-holding-dollar me-2 @(isPaid ? "text-success" : "text-secondary")"></i>
                        @(isPaid ? "Tính phí phụ thu" : "Miễn phí")
                    </label>
                    <input class="form-check-input" type="checkbox" role="switch" 
                        checked="@isPaid"
                        @onchange="@(e => HandleToggleSurcharge((bool)e.Value!))"
                        style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                </div>

                
                @* --- 1b. HIỂN THỊ Ô NHẬP TIỀN NẾU CHỌN TÍNH PHÍ --- *@
                @if (isPaid)
                {
                    <div class="mb-3 animate__animated animate__fadeInDown animate__faster">
                        <label class="form-label fw-bold extra-small text-muted text-uppercase">Số tiền phụ thu mẫu</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-success">
                                <i class="fa-solid fa-money-bill-wave"></i>
                            </span>
                            <input type="text" class="form-control text-end fw-bold text-success" 
                                inputmode="numeric"
                                value="@currentAmt.ToString("N0")" 
                                @oninput="@(e => HandleAmountInput(e.Value?.ToString()))" 
                                placeholder="Nhập số tiền..." />
                            <span class="input-group-text bg-light fw-bold">VNĐ</span>
                        </div>
                        @RenderVal("Amount")
                    </div>
                }
                else
                {
                    <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-3 animate__animated animate__fadeIn">
                        <i class="fa-solid fa-circle-check me-2 fs-5"></i>
                        <div class="extra-small fst-italic"><b>Miễn phí:</b> Owner sẽ không thu thêm phí cho khung giờ này.</div>
                    </div>
                }
                <div class="form-text small mb-3">Số tiền này sẽ được dùng làm giá gợi ý khi khách sạn áp dụng chính sách.
                </div>
                
                @* ----- 2a. KHUNG GIỜ CHUẨN -----*@
                <h6 class="text-primary fw-bold mb-3"><i class="fa-regular fa-clock me-2"></i>Thiết lập khung giờ chuẩn</h6>

                <div class="row g-3">
                    <div class="col-6">
                        <label class="small text-muted fw-bold">Nhận phòng</label>
                        @if(_isUpdate) { <input type="time" class="form-control shadow-sm @(isInvalidTime ? "border-danger text-danger" : "")" @bind="_updateModel.TimeFrom" /> }
                        else { <input type="time" class="form-control shadow-sm @(isInvalidTime ? "border-danger text-danger" : "")" @bind="_createModel.TimeFrom" /> }
                    </div>
                    <div class="col-6">
                        <label class="small text-muted fw-bold">Trả phòng</label>
                        @if(_isUpdate) { <input type="time" class="form-control shadow-sm @(isInvalidTime ? "border-danger text-danger" : "")" @bind="_updateModel.TimeTo" /> }
                        else { <input type="time" class="form-control shadow-sm @(isInvalidTime ? "border-danger text-danger" : "")" @bind="_createModel.TimeTo" /> }
                    </div>
                

                    @* 2b. HIỂN THỊ LỖI LOGIC GIỜ GIẤC *@
                    @if (isInvalidTime)
                    {
                        <div class="col-12 animate__animated animate__shakeX">
                            <div class="alert alert-danger py-2 px-3 small fw-bold mb-0 shadow-sm" style="border:none; border-left: 4px solid darkred;">
                                <i class="fa-solid fa-circle-exclamation me-2"></i>
                                Lỗi: Thời gian lưu trú (@totalHours.ToString("0.0")h) không được vượt quá 12 tiếng.
                            </div>
                        </div>
                    }
                    else if (totalHours > 0)
                    {
                        <div class="col-12">
                            <div class="extra-small text-muted fst-italic px-2">
                                <i class="fa-solid fa-info-circle me-1"></i>Tổng thời gian lưu trú dự kiến: <b>@totalHours.ToString("0.0") giờ</b>.
                            </div>
                        </div>
                    }
                </div>
            }

            @* --- CASE 1003: CANCELLATION --- *@
            @if (TypeId == 1003)
            {
                <h6 class="text-danger fw-bold mb-3"><i class="fa-solid fa-ban me-2"></i>Thiết lập phí hủy phòng</h6>
                
                @* ----- SET GIÁ TRỊ % PERCENT VÀ AMOUNT*@
                var pct = _isUpdate ? _updateModel.Percent : _createModel.Percent;
                var amt = _isUpdate ? _updateModel.Amount : _createModel.Amount;

                var currentDays = _isUpdate ? _updateModel.IntValue1 : _createModel.IntValue1;

                bool hasFine = pct > 0 || (amt > 0);
                bool isPercentType = pct > 0 || (amt <= 0 || amt == null);
                bool isAnytime = currentDays <= 0;


                <div class="row g-3">
                @* --- 1. BẬT/TẮT CÓ PHÍ PHẠT --- *@
                <div class="col-12 mt-2">
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between shadow-sm">
                        <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                            <i class="fa-solid fa-hand-holding-dollar me-2 text-danger"></i>Có áp dụng phí phạt?
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" 
                            checked="@hasFine" 
                            @onchange="@(e => HandleToggleFine((bool)e.Value!))"
                            style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>
                </div>

                @if (hasFine)
                {
                    @* --- 2. CHỌN LOẠI VÀ NHẬP MỨC PHÍ --- *@
                    <div class="col-12 animate__animated animate__fadeIn animate__faster">
                        <div class="btn-group w-100 mb-2 shadow-sm" role="group">
                            <button type="button" class="btn btn-sm @(isPercentType ? "btn-danger" : "btn-outline-danger") fw-bold" 
                                    @onclick="@(() => ChangeFineType(true))">Phần trăm (%)</button>
                            <button type="button" class="btn btn-sm @(!isPercentType ? "btn-success" : "btn-outline-success") fw-bold" 
                                    @onclick="@(() => ChangeFineType(false))">Số tiền (VNĐ)</button>
                        </div>

                        @if (isPercentType)
                        {
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-danger text-white" style="width: 45px;"><i class="fa-solid fa-percent"></i></span>
                                <input type="number" class="form-control text-danger fw-bold text-center" placeholder="Nhập % phạt..."
                                    value="@pct" @oninput="@(e => HandleFineInput(e.Value?.ToString(), "percent"))" />
                            </div>
                            @* ----- VALIDATION MESSAGE -----*@
                            @RenderVal("Percent")
                        }
                        else
                        {
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-success text-white" style="width: 45px;"><i class="fa-solid fa-money-bill-1"></i></span>
                                <input type="text" class="form-control text-success fw-bold text-end" placeholder="Nhập số tiền..."
                                    inputmode="numeric"
                                    value="@((amt ?? 0).ToString("N0"))" @oninput="@(e => HandleFineInput(e.Value?.ToString(), "amount"))" />
                                <span class="input-group-text bg-light small fw-bold">VNĐ</span>
                            </div>
                            @* ----- VALIDATION MESSAGE -----*@
                            @RenderVal("Amount")
                        }
                    </div>

                    @* --- 3. THỜI HẠN PHẠT --- *@
                    <div class="col-12 mt-2 animate__animated animate__fadeIn">
                        <div class="p-2 border rounded bg-white shadow-sm">
                            <div class="form-check form-switch custom-switch p-0 d-flex align-items-center justify-content-between">
                                <label class="small fw-bold @(isAnytime ? "text-danger" : "text-primary") mb-0">
                                    <i class="@(isAnytime ? "fa-solid fa-bolt" : "fa-solid fa-clock") me-1"></i>
                                    @(isAnytime ? "Áp dụng ngay khi đặt" : "Báo trước theo ngày")
                                </label>
                                <input class="form-check-input ms-0" type="checkbox" role="switch"
                                    checked="@isAnytime" @onchange="@(e => SetIntValue((bool)e.Value! ? 0 : 1))"
                                    style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                            </div>

                            @if (!isAnytime)
                            {
                                <div class="mt-2 animate__animated animate__slideInDown animate__faster">
                                    <div class="input-group shadow-sm">
                                        <input type="number" class="form-control text-center fw-bold text-primary" 
                                            value="@currentDays"
                                            @oninput="@(e => HandleIntValueInput(e.Value?.ToString()))" />
                                        <span class="input-group-text bg-primary text-white fw-bold">ngày</span>
                                    </div>
                                    @* ----- VALIDATION MESSAGE -----*@
                                    @RenderVal("IntValue1")
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @* HIỂN THỊ KHI MIỄN PHÍ *@
                    <div class="col-12 mt-2">
                        <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0">
                            <i class="fa-solid fa-circle-check me-2 fs-5"></i>
                            <div class="extra-small fst-italic">Chính sách linh hoạt: Đang miễn phí hủy hoàn toàn.</div>
                        </div>
                    </div>
                }

                @* --- 4. DIỄN GIẢI CHÍNH SÁCH --- *@
                <div class="col-12 mt-1">
                    <div class="p-3 rounded bg-light border-start border-4 @(hasFine ? "border-danger" : "border-success") shadow-sm">
                        <div class="small fw-bold text-uppercase mb-1 text-muted">Diễn giải chính sách:</div>
                        <div class="small fst-italic">
                            @if (!hasFine) { <span>Khách được hủy phòng <strong class="text-success">MIỄN PHÍ</strong> vào mọi thời điểm.</span> }
                            else if (isAnytime) { <span>Khách bị phạt <strong class="text-danger">@(pct > 0 ? pct + "%" : amt?.ToString("N0") + "đ")</strong> ngay khi hủy.</span> }
                            else {
                                <span>Nếu hủy <strong class="text-danger">trong vòng @currentDays ngày</strong>: Phạt <strong>@(pct > 0 ? pct + "%" : amt?.ToString("N0") + "đ")</strong>.</span>
                                <br /><span>Nếu hủy trước đó: <strong class="text-success">MIỄN PHÍ</strong>.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            }

            @* --- CASE 1004: INFANT, CHILD & EXTRA BED --- *@
            @if (TypeId == 1004)
            {
                // Lấy giá trị strong type để hiển thị
                int ageFrom = _isUpdate ? _updateModel.IntValue1 ?? 0 : _createModel.IntValue1 ?? 0;
                int ageTo = _isUpdate ? _updateModel.IntValue2 ?? 0 : _createModel.IntValue2 ?? 0;
                decimal surcharge = _isUpdate ? _updateModel.Amount ?? 0 : _createModel.Amount ?? 0;
                
                bool isInvalidRange = ageFrom > ageTo; // Logic kiểm tra độ tuổi
                bool hasSurcharge = surcharge > 0;

                <h6 class="text-success fw-bold mb-3"><i class="fa-solid fa-child-reaching me-2"></i>Chính sách độ tuổi & Giường phụ</h6>
                <div class="row g-3">
                @* 1. THIẾT LẬP ĐỘ TUỔI *@
                <div class="col-6">
                    <label class="small text-muted fw-bold">Độ tuổi tối thiểu (Từ)</label>
                    <input type="number" class="form-control fw-bold shadow-sm" 
                        value="@ageFrom" 
                        @oninput="@(e => HandleAgeInput(e.Value?.ToString(), "from"))" />
                    
                    @* ----- VALIDATION MESSAGE -----*@
                    @RenderVal("IntValue1")
                </div>

                <div class="col-6">
                    <label class="small text-muted fw-bold">Độ tuổi tối đa (Đến)</label>
                    <input type="number" class="form-control fw-bold shadow-sm" 
                        value="@ageTo" 
                        @oninput="@(e => HandleAgeInput(e.Value?.ToString(), "to"))" />
                    
                    @* ----- VALIDATION MESSAGE -----*@
                    @RenderVal("IntValue2")
                </div>

                @* HIỂN THỊ LỖI LOGIC NGAY LẬP TỨC *@
                @if (isInvalidRange)
                {
                    <div class="col-12 animate__animated animate__shakeX">
                        <div class="alert alert-danger py-2 px-3 small fw-bold mb-0 shadow-sm" style="border:none; border-left: 4px solid darkred;">
                            <i class="fa-solid fa-circle-exclamation me-2"></i>Lỗi: Độ tuổi "Tối thiểu" không được lớn hơn "Tối đa".
                        </div>
                    </div>
                }

                @* 2. NÚT GẠT PHỤ THU *@
                <div class="col-12 mt-3">
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between shadow-sm">
                        <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                            <i class="fa-solid fa-circle-dollar-to-slot me-2 text-success"></i>Có phụ thu phí ?
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" 
                            checked="@hasSurcharge" 
                            @onchange="@(e => HandleToggleSurcharge((bool)e.Value!))"
                            style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>
                </div>

                @* 3. Ô NHẬP TIỀN (CHỈ HIỆN KHI BẬT PHỤ THU) *@
                @if (hasSurcharge)
                {
                    <div class="col-12 animate__animated animate__fadeInDown animate__faster">
                        <label class="form-label fw-bold small text-muted text-uppercase">Số tiền phụ thu / Phí dịch vụ</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-success">
                                <i class="fa-solid fa-money-bill-wave"></i>
                            </span>
                            <input type="number" class="form-control text-end fw-bold text-success" 
                                value="@surcharge.ToString("N0")" 
                                @oninput="@(e => HandleAmountInput(e.Value?.ToString()))" 
                                placeholder="Nhập số tiền..." />
                            <span class="input-group-text bg-light fw-bold">VNĐ</span>
                        </div>
                        @* ----- VALIDATION MESSAGE -----*@
                        @RenderVal("Amount")
                        
                        <div class="form-text extra-small mt-1">Số tiền này sẽ là gợi ý mặc định cho các khách sạn.</div>
                    </div>
                }
                else
                {
                    <div class="col-12 animate__animated animate__fadeIn">
                        <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0">
                            <i class="fa-solid fa-face-laugh-beam me-2 fs-5"></i>
                            <div class="extra-small"><b>Miễn phí:</b> Trẻ em trong độ tuổi này sẽ không bị tính thêm phí.</div>
                        </div>
                    </div>
                }
            </div>
            }

            @* --- CASE 2002: PETS / OTHER POLICIES --- *@
            @if (TypeId == 2002)
            {
                bool isAllowed = _isUpdate ? (_updateModel.BoolValue == true) : (_createModel.BoolValue == true);
                decimal petFee = _isUpdate ? (_updateModel.Amount ?? 0) : (_createModel.Amount ?? 0);

                bool isPaid = petFee > 0;

                <h6 class="text-warning fw-bold mb-3"><i class="fa-solid fa-paw me-2"></i>Quy định về vật nuôi / Khác</h6>

                @* --- BƯỚC 1: CẦN GẠT CHO PHÉP --- *@
                <div class="mb-3">
                    <div class="form-check form-switch custom-switch p-2 rounded border bg-light d-flex align-items-center justify-content-between shadow-sm">
                        <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                            <i class="fa-solid fa-dog me-2 @(isAllowed ? "text-warning" : "text-secondary")"></i>
                            @(isAllowed ? "ĐƯỢC PHÉP MANG THEO" : "KHÔNG TIẾP NHẬN")
                        </label>
                        <input class="form-check-input" type="checkbox" role="switch" 
                            checked="@isAllowed" 
                            @onchange="@(e => HandlePetToggle((bool)e.Value!))"
                            style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                    </div>
                </div>

                <div class="mb-3">
                    @* --- BƯỚC 2: NẾU CHO PHÉP -> HIỆN TIẾP CẦN GẠT PHÍ --- *@
                    @if (isAllowed)
                    {
                        <div class="animate__animated animate__fadeIn">
                            @* --- CẦN GẠT MIỄN PHÍ / TÍNH PHÍ --- *@
                            <div class="form-check form-switch custom-switch p-2 rounded border bg-white d-flex align-items-center justify-content-between mb-3 shadow-sm" style="border-style: dashed !important;">
                                <label class="small fw-bold text-muted text-uppercase mb-0 ms-1">
                                    <i class="fa-solid fa-hand-holding-dollar me-2 @(isPaid ? "text-success" : "text-secondary")"></i>
                                    @(isPaid ? "TÍNH PHÍ DỊCH VỤ" : "MIỄN PHÍ HOÀN TOÀN")
                                </label>
                                <input class="form-check-input" type="checkbox" role="switch" 
                                    checked="@isPaid" 
                                    @onchange="@(e => HandlePetFeeToggle((bool)e.Value!))"
                                    style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                            </div>

                            @* --- HIỂN THỊ Ô NHẬP TIỀN NẾU CHỌN TÍNH PHÍ --- *@
                            @if (isPaid)
                            {
                                <div class="mb-3 animate__animated animate__fadeInDown animate__faster">
                                    <label class="form-label fw-bold extra-small text-muted text-uppercase">Phí vệ sinh vật nuôi mẫu</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-white text-success"><i class="fa-solid fa-money-bill-wave"></i></span>
                                        <input type="number" class="form-control text-end fw-bold text-success" 
                                            value="@petFee.ToString("N0")" 
                                            @oninput="@(e => HandleAmountInput(e.Value?.ToString()))" />
                                        <span class="input-group-text bg-light fw-bold">VNĐ</span>
                                    </div>
                                    @RenderVal("Amount")
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-success border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0">
                                    <i class="fa-solid fa-face-smile-beam me-2 fs-5"></i>
                                    <div class="extra-small fst-italic"><b>Free:</b> Vật nuôi được ở cùng chủ miễn phí.</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary border-0 py-2 px-3 d-flex align-items-center shadow-sm mb-0 animate__animated animate__fadeIn">
                            <i class="fa-solid fa-ban me-2 fs-5"></i>
                            <div class="extra-small fst-italic">Chính sách mặc định là không tiếp nhận vật nuôi.</div>
                        </div>
                    }
                </div>
            }

            <div class="alert alert-info border-0 shadow-sm mt-3 py-2 small">
                <i class="fa-solid fa-circle-exclamation me-1"></i>
                <strong>Lưu ý:</strong> Đây là các giá trị mặc định. Chủ khách sạn có thể thay đổi lại khi áp dụng cho khách
                sạn của họ.
            </div>
        </FormContent>

        @* --- C. CẤU HÌNH BẢNG (TABLE) --- *@
        <TableHeader>
            <th class="text-center align-middle" style="width: 50px;">Id</th>
            <th class="text-center align-middle" style="width: 350px;">Tên chính sách</th>
            <th class="text-center align-middle" style="width: 100px;">Thông số cấu hình</th>
            <th class="text-center align-middle">Mô tả chi tiết</th> @* Cột mô tả sẽ linh hoạt *@
        </TableHeader>

        <RowTemplate Context="row">
            @* 1. ID *@
            <td class="text-center text-muted small">@row.Id</td>

            @* 2. Tên chính sách*@
            <td class="text-center align-middle">
                <div class="fw-bold text-dark">@row.Name</div>
            </td>

            @* 3. THÔNG SỐ CẤU HÌNH *@
            <td class="text-center align-middle">
                <div class="d-flex justify-content-center align-items-center">
                    @if (row.TypeId == 1002) @* CASE: GIỜ GIẤC (CHECK-IN/OUT) *@
                    {
                        <div class="badge bg-primary bg-opacity-10 text-primary border border-primary d-flex flex-column justify-content-center py-1"
                            style="min-width: 160px; height: 42px;">
                            <div class="small" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2" style="font-size: 0.65rem;">
                                    <i class="fa-regular fa-clock me-1"></i>
                                    @row.TimeFrom?.ToString(@"hh\:mm") - @row.TimeTo?.ToString(@"hh\:mm")
                                </span>
                            </div>
                            <div class="fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                                @if (row.Amount > 0)
                                {
                                    <span class="opacity-75">+@row.Amount?.ToString("N0")đ</span>
                                }
                                else if (row.Name.Contains("Standard"))
                                {
                                    <span class="opacity-75">Standard</span>
                                }
                                else
                                {

                                    <span class="opacity-75">Miễn Phí</span>
                                }
                            </div>
                        </div>
                    }
                    else if (row.TypeId == 1003)
                    @* CASE: HỦY PHÒNG (CANCELLATION) *@
                    {
                        @* Xác định xem đây là chính sách Miễn phí hay Có phí để chọn màu Badge *@
                        bool isFree = (row.Percent <= 0 && (row.Amount <= 0 || row.Amount == null));
                        string badgeClass = isFree ? "bg-success bg-opacity-10 text-success border-success"
                        : "bg-danger bg-opacity-10 text-danger border-danger";
                        string iconClass = isFree ? "fa-solid fa-check-circle" : "fa-solid fa-ban";

                        <div class="badge bg-danger bg-opacity-10 text-danger border border-danger d-flex flex-column justify-content-center py-1"
                            style="min-width: 160px; height: 42px;">

                            @* Dòng 1: Điều kiện thời gian - Hiển thị dạng Chip/Badge nhỏ *@
                            <div class="mb-1">
                                @if (row.IntValue1 <= 0)
                                {
                                    @* Trạng thái Non-Refundable hoặc Hủy mọi lúc *@
                                    <span
                                        class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2"
                                        style="font-size: 0.65rem; letter-spacing: 0.5px;">
                                        <i class="fa-solid fa-infinity me-1"></i>Mọi thời điểm
                                    </span>
                                }
                                else
                                {
                                    @* Trạng thái có thời hạn *@
                                    <span
                                        class="badge rounded-pill bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2"
                                        style="font-size: 0.65rem; letter-spacing: 0.5px;">
                                        <i class="fa-solid fa-clock-rotate-left me-1"></i>Trước @row.IntValue1 ngày
                                    </span>
                                }
                            </div>

                            @* Dòng 2: Nội dung chính (Nút hành động giả hoặc text nổi bật) *@
                            <div class="fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                                @if (row.Percent > 0)
                                {
                                    <span>Phạt @(row.Percent == 100 ? "100%" : row.Percent + "%")</span>
                                }
                                else if (row.Amount > 0)
                                {
                                    <span>Phí @row.Amount?.ToString("N0")đ</span>
                                }
                                else
                                {
                                    <span>Miễn phí hủy</span>
                                }
                            </div>
                        </div>
                    }
                    else if (row.TypeId == 1004)
                    @* CASE: TRẺ EM & GIƯỜNG PHỤ *@
                    {

                        <div class="badge bg-success bg-opacity-10 text-success border border-success d-flex flex-column justify-content-center py-1"
                            style="min-width: 160px; height: 42px;">
                            <div class="small" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-info border border-info border-opacity-25 px-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                                    <i class="fa-solid fa-child-reaching me-1"></i>
                                
                                    @if (row.IntValue2 >= 99)
                                    {
                                        <span>Từ @row.IntValue1 tuổi +</span>
                                    }
                                    else
                                    {

                                        <span>@row.IntValue1 - @row.IntValue2 tuổi</span>
                                    }
                                </span>
                            </div>
                            <div class="fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                                @(row.Amount > 0 ? "+" + row.Amount?.ToString("N0") + "đ" : "Miễn phí")
                            </div>
                        </div>
                    }
                    else if (row.TypeId == 2002)
                    @* CASE: VẬT NUÔI (PETS) *@
                    {
                        bool allowed = row.BoolValue == true;

                        <div class="badge @(allowed ? "bg-warning text-warning border-warning" : "bg-secondary text-secondary border-secondary") bg-opacity-10 border d-flex flex-column justify-content-center py-1"
                            style="min-width: 160px; height: 42px;">
                            <div class="small" style="font-size: 0.7rem;">
                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info border border-secondary border-opacity-25 px-2" style="font-size: 0.65rem;">
                                    <i class="fa-solid fa-paw me-1"></i>
                                    @(allowed ? "Cho phép mang theo" : "Không cho phép")
                                </span>
                            </div>
                            <div class="fw-bold mt-1" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                @if(allowed) { <div class="fw-bold">@(row.Amount > 0 ? "+" + row.Amount?.ToString("N0") + "đ" : "Miễn phí")</div> }
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted opacity-50 fw-bold" style="min-width: 160px;">---</span>
                    }
                </div>
            </td>

            @* 4. MÔ TẢ *@
            <td class="text-center align-middle">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 350px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}


@code {
    // --- PARAMETERS TỪ URL ---
    // Tự động nhận giá trị từ URL /admin/manage/policy/{TypeId}
    [Parameter] public int? TypeId { get; set; }

    // --- STATE ---
    private List<PolicyVM>? items;

    // Dùng 2 model riêng biệt
    private PolicyCreateVM _createModel = new PolicyCreateVM();
    private PolicyUpdateVM _updateModel = new PolicyUpdateVM();
    private int _currentEditingId = 0;
    private bool _isUpdate = false;

    // --- QUẢN LÝ PHÂN TRANG ---
    // Khởi tạo request: Trang 1, Size 10
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int totalPages = 0;
    private int totalCount = 0;

    // Biến kiểm soát vòng đời & Re-render
    private int? _previousTypeId = -999;
    private BaseCreateOrUpdateAdminVM GetModel() => _isUpdate ? _updateModel : _createModel;

    private MasterDetailLayout<PolicyVM, BaseCreateOrUpdateAdminVM>? _layoutRef;

    // --- LOGIC GỢI Ý MẶC ĐỊNH (TRIGGERED FROM LAYOUT) ---
    private void SuggestDefaultValues()
    {
        if (_isUpdate) PolicyHelper.ApplyDefaultValues(_updateModel, TypeId ?? 1002);
        else PolicyHelper.ApplyDefaultValues(_createModel, TypeId ?? 1002);

        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    // --- CÁC HÀM XỬ LÝ STRONG TYPE ---
    private void HandleAmountInput(string? val)
    {
        decimal.TryParse(val, out var amount);
        if (_isUpdate) _updateModel.Amount = amount; else _createModel.Amount = amount;
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleIntValueInput(string? val)
    {
        int.TryParse(val, out var v);
        if (_isUpdate) _updateModel.IntValue1 = v; else _createModel.IntValue1 = v;
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void SetIntValue(int value)
    {
        if (_isUpdate) _updateModel.IntValue1 = value; else _createModel.IntValue1 = value;
        StateHasChanged();
    }

    private void HandleFineInput(string? val, string type)
    {
        double.TryParse(val, out var pVal);
        decimal.TryParse(val, out var aVal);
        if (_isUpdate) {
            if (type == "percent") { _updateModel.Percent = pVal; _updateModel.Amount = 0; }
            else { _updateModel.Amount = aVal; _updateModel.Percent = 0; }
        } else {
            if (type == "percent") { _createModel.Percent = pVal; _createModel.Amount = 0; }
            else { _createModel.Amount = aVal; _createModel.Percent = 0; }
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleToggleFine(bool isEnabled)
    {
        if (_isUpdate) {
            _updateModel.Percent = isEnabled ? 10 : 0;
            _updateModel.Amount = 0;
            _updateModel.IntValue1 = 0;
        } else {
            _createModel.Percent = isEnabled ? 10 : 0;
            _createModel.Amount = 0;
            _createModel.IntValue1 = 0;
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void ChangeFineType(bool isPercent)
    {
        if (_isUpdate) {
            if (isPercent) { _updateModel.Percent = 10; _updateModel.Amount = 0; }
            else { _updateModel.Amount = 100000; _updateModel.Percent = 0; }
        } else {
            if (isPercent) { _createModel.Percent = 10; _createModel.Amount = 0; }
            else { _createModel.Amount = 100000; _createModel.Percent = 0; }
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleAgeInput(string? val, string field)
    {
        int.TryParse(val, out var age);
        if (_isUpdate) {
            if (field == "from") _updateModel.IntValue1 = age; else _updateModel.IntValue2 = age;
        } else {
            if (field == "from") _createModel.IntValue1 = age; else _createModel.IntValue2 = age;
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    private void HandleToggleSurcharge(bool isEnabled)
    {
        decimal val = isEnabled ? 150000 : 0;
        if (_isUpdate) _updateModel.Amount = val; else _createModel.Amount = val;
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    

    // ----- 2002: PETS ----- //
    // 1. Xử lý gạt switch Cho phép / Không cho phép
    private void HandlePetToggle(bool isAllowed)
    {
        if (_isUpdate) {
            _updateModel.BoolValue = isAllowed;
            if (!isAllowed) _updateModel.Amount = 0; // Nếu cấm thì xóa luôn phí
        } else {
            _createModel.BoolValue = isAllowed;
            if (!isAllowed) _createModel.Amount = 0;
        }
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    // 2. Xử lý gạt switch Miễn phí / Tính phí (Chỉ dành cho vật nuôi)
    private void HandlePetFeeToggle(bool isPaid)
    {
        decimal defaultPetFee = isPaid ? 200000 : 0; // Gợi ý 200k nếu tính phí
        
        if (_isUpdate) _updateModel.Amount = defaultPetFee;
        else _createModel.Amount = defaultPetFee;
        
        StateHasChanged();
        _layoutRef?.TriggerValidate();
    }

    // --- LIFECYCLE ---

    // --- 1. LOAD DATA (Override từ Cha) ---
    protected override async Task LoadDataAsync()
    {
        // Ngăn chặn gọi API nếu Component đã bị hủy (tránh ObjectDisposedException)
        if (Disposed) return;

        // Reset UI Loading
        items = null;
        StateHasChanged();

        try
        {
            // Gọi API bằng Property 'Service' từ AdminPageBase
            var res = await Service.GetPoliciesByType(TypeId, _paging);

            if (!Disposed) // Check cờ Disposed từ Cha
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    items = res.Content.Items;
                    totalPages = res.Content.TotalPages;
                    totalCount = res.Content.TotalCount;
                }
                else
                {
                    items = new List<PolicyVM>();

                    // Nếu lỗi 404 từ Server, trả về danh sách rỗng thay vì để items = null
                    if (res.StatusCode != StatusCodeResponse.Success)
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                }
            }
        }
        catch (Exception ex)
        {
            // Log lỗi ra console để debug xem lỗi gì
            Console.WriteLine($"[Policy Load Error]: {ex.Message}");

            Logger.LogError(ex, "Lỗi load data policy");
            items = new List<PolicyVM>();
        }
        finally
        {
            if (!Disposed) StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        // Ép Model đúng kiểu ngay khi component vừa được tạo ra
        ResetForm();
    }

    // --- 2. XỬ LÝ PARAMETERS (Thay thế OnInitialized và OnAfterRender cũ) ---
    protected override async Task OnParametersSetAsync()
    {
        var effectiveTypeId = TypeId ?? 1002;

        // Kiểm tra xem TypeId có thực sự đổi không
        if (effectiveTypeId != _previousTypeId)
        {
            _previousTypeId = effectiveTypeId;
            TypeId = effectiveTypeId;
            _paging.PageIndex = 1;
            ResetForm();

            if (IsJsReady)
            {
                await LoadDataAsync();
            }
        }
    }

    // --- HÀM XỬ LÝ KHI BẤM CHUYỂN TRANG ---
    private async Task HandlePageChanged(int newPage)
    {
        // Cập nhật số trang mới vào Request
        _paging.PageIndex = newPage;
        // Gọi lại API
        await LoadDataAsync();
    }


    // --- CRUD METHODS ---
    private void OnEditItem(PolicyVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        _updateModel = new PolicyUpdateVM
        {
            Name = item.Name,
            Description = item.Description,

            // QUAN TRỌNG: Phải copy hết các field này thì form mới hiện số
            TimeFrom = item.TimeFrom,
            TimeTo = item.TimeTo,
            IntValue1 = item.IntValue1,
            IntValue2 = item.IntValue2,
            Amount = item.Amount,
            Percent = item.Percent,
            BoolValue = item.BoolValue
        };
    }

    private async Task HandleDelete(PolicyVM item)
    {
        // Gọi API xóa thực tế
        var res = await Service.DeletePolicy(item.Id);

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            // Xóa thành công thì load lại bảng
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        // 1. Xác định TypeId chuẩn ngay từ đầu (Nếu null lấy 1002 - Check-in/out)
        int currentTypeId = TypeId ?? 1002;

        // 2. Khởi tạo CreateVM
        _createModel = new PolicyCreateVM
        {
            Name = "",        // Đảm bảo không null để tránh lỗi UI
            Description = "",  // Đảm bảo không null
            TypeId = currentTypeId
        };

        // 3. Khởi tạo UpdateVM (Dummy để tránh lỗi null ở EditForm)
        _updateModel = new PolicyUpdateVM();

        // 4. Gọi Helper để điền các giá trị mặc định (Giờ giấc, số tiền...)
        // Helper này giờ đã hỗ trợ nhận vào PolicyCreateVM nhờ overload chúng ta vừa viết
        PolicyHelper.ApplyDefaultValues(_createModel, currentTypeId);

        // 5. [QUAN TRỌNG] Xóa các thông báo lỗi đỏ từ phiên làm việc trước
        _layoutRef?.TriggerValidate();

        // 6. Báo cho giao diện vẽ lại
        StateHasChanged();
    }

    private async Task SaveData()
    {
        // 1. Kiểm tra logic giờ giấc (TypeId = 1002)
        if (TypeId == 1002)
        {
            var mFrom = _isUpdate ? _updateModel.TimeFrom : _createModel.TimeFrom;
            var mTo = _isUpdate ? _updateModel.TimeTo : _createModel.TimeTo;

            if (mFrom.HasValue && mTo.HasValue)
            {
                // Tính số giờ giữa 2 mốc
                var diff = (mTo.Value - mFrom.Value).TotalHours;
                
                // Nếu số giờ <= 0 (VD: 12h - 14h = -2h), nghĩa là khách ở xuyên đêm sang hôm sau
                if (diff <= 0) diff += 24;

                // CHẶN 1: Không được ở quá lâu (phải để thời gian dọn phòng)
                if (diff > 23) 
                {
                    _snackbar.Add(MessageResponse.AdminManagement.Policy.MAX_DIFF_TIME, Severity.Error);
                    return;
                }

                // CHẶN 2: Không được ở quá ngắn (VD: Check-in 14:00, Check-out 14:15 là vô lý)
                if (diff < 1) 
                {
                    _snackbar.Add(MessageResponse.AdminManagement.Policy.INVALID_DIFF_TIME, Severity.Warning);
                    return;
                }
            }
        }

        // 2. Làm sạch dữ liệu cho Chính sách hủy (TypeId = 1003)
        if (TypeId == 1003)
        {
            // Đảm bảo nếu Admin vô tình để số ngày âm hoặc rác khi dùng Switch
            if (_isUpdate && _updateModel.IntValue1 < 0) _updateModel.IntValue1 = 0;
            if (!_isUpdate && _createModel.IntValue1 < 0) _createModel.IntValue1 = 0;
        }

        if (TypeId == 1004)
        {
            int f = _isUpdate ? (_updateModel.IntValue1 ?? 0) : (_createModel.IntValue1 ?? 0);
            int t = _isUpdate ? (_updateModel.IntValue2 ?? 0) : (_createModel.IntValue2 ?? 0);

            if (f > t)
            {
                _snackbar.Add(MessageResponse.AdminManagement.Policy.INVALID_AGE_RANGE, Severity.Error);
                return; // Chặn không cho gọi API
            }
        }
        
        ApiResponse<PolicyVM> res;
        if (_isUpdate)
        {
            // Update: Gửi UpdateVM + ID
            res = await Service.UpdatePolicy(_currentEditingId, _updateModel);
        }
        else
        {
            // Create: Gửi CreateVM (Đã có TypeId)
            _createModel.TypeId = TypeId ?? 1002;
            res = await Service.CreatePolicy(_createModel);
        }

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
            ResetForm();
        }
    }
}
@using HotelBooking.webapp.Pages.Admin.Base
@inherits AdminPageBase
@attribute [Authorize(Roles = "Admin")]

@* --- 1. ĐỊNH NGHĨA ROUTING --- *@
@page "/admin/manage/roomquality"
@page "/admin/manage/roomquality/{TypeId:int}"

@* --- 2. SỬ DỤNG LAYOUT ADMIN CHUNG --- *@
@layout AdminLayout
@inject ILogger<RoomQualityManager> Logger
@inject ISnackbar _snackbar

@* --- 3. UI LOADING (Kiểm soát bởi Class Cha) --- *@
@if (!ShouldRenderUI())
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2"></div>
        <span>Đang tải dữ liệu...</span>
    </div>
}
else
{
    <MasterDetailLayout TItem="RoomQualityVM" TModel="BaseCreateOrUpdateAdminVM" Items="_items" Model="@(_isUpdate ? (BaseCreateOrUpdateAdminVM)_updateModel : (BaseCreateOrUpdateAdminVM)_createModel)" PageIndex="_paging.PageIndex ?? 1"
        TotalPages="_totalPages" TotalCount="_totalCount" OnPageChanged="HandlePageChanged" OnSubmit="SaveData"
        OnEdit="OnEditItem" OnDelete="HandleDelete" OnCancel="ResetForm">

        @* --- A. CẤU HÌNH MENU BÊN TRÁI (THÔNG QUA RENDER FRAGMENT) --- *@
        <SidebarTopContent>
            @* NHÚNG COMPONENT MENU THÔNG MINH VÀO ĐÂY *@
            @* Nó tự biết đường vẽ ra Dropdown *@
            <GlobalNavMenu CurrentModule="RoomQuality" CurrentTypeId="TypeId" />
        </SidebarTopContent>

        @* --- B. CẤU HÌNH FORM (Nâng cấp trực quan) --- *@
        <FormContent>
            @* 1. TÊN CHẤT LƯỢNG *@
            <div class="mb-4">
                <label class="form-label fw-bold small text-muted text-uppercase">Tên mức chất lượng</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="fa-solid fa-award text-warning"></i></span>
                    @if (_isUpdate)
                    {
                        <InputText class="form-control" @bind-Value="_updateModel.Name" placeholder="VD: Premium, Budget..." />
                    }
                    else
                    {
                        <InputText class="form-control" @bind-Value="_createModel.Name" placeholder="VD: Premium, Budget..." />
                    }
                </div>
                @if (_isUpdate) { <ValidationMessage For="() => _updateModel.Name" /> }
                else { <ValidationMessage For="() => _createModel.Name" /> }
            </div>

            @* 2. MÔ TẢ *@
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">
                    <i class="fa-solid fa-quote-left me-1"></i> Mô tả dịch vụ
                </label>
                @if (_isUpdate)
                {
                    <InputTextArea class="form-control shadow-sm" rows="3" @bind-Value="_updateModel.Description" placeholder="Mô tả..." />
                    <ValidationMessage For="() => _updateModel.Description" />
                }
                else
                {
                    <InputTextArea class="form-control shadow-sm" rows="3" @bind-Value="_createModel.Description" placeholder="Mô tả..." />
                    <ValidationMessage For="() => _createModel.Description" />
                }
                <div class="form-text small mt-1">Dùng để giải thích quy trình hoặc lưu ý đặc biệt.</div>
            </div>

            @* 3. THỨ TỰ ƯU TIÊN (SORT ORDER) *@
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Thứ tự ưu tiên</label>
                <div class="input-group" style="max-width: 150px;">
                    <span class="input-group-text bg-white"><i class="fa-solid fa-sort-numeric-down text-muted"></i></span>
                    @if (_isUpdate)
                    {
                        <InputNumber class="form-control text-center" @bind-Value="_updateModel.SortOrder" />
                    }
                    else
                    {
                        <InputNumber class="form-control text-center" @bind-Value="_createModel.SortOrder" />
                    }
                </div>
                <div class="form-text small mt-2">
                    <i class="fa-solid fa-circle-info me-1"></i>
                    Số càng lớn, mức chất lượng này càng được ưu tiên hiển thị trước.
                </div>
            </div>
        </FormContent>

        @* --- C. CẤU HÌNH BẢNG (TABLE) --- *@
        <TableHeader>
            <th class="text-center" style="width: 50px;">Id</th>
            <th class="text-center" style="width: 400px;">Tên mức chất lượng</th>
            <th class="text-center" style="width: 100px;"></th> @* Cột Badge không tiêu đề *@
            <th class="text-center">Mô tả / Ghi chú</th> @* Cột mô tả sẽ linh hoạt *@
            <th class="text-center" style="width: 150px;">Thứ tự sắp xếp</th>
        </TableHeader>

        <RowTemplate Context="row">
            @* 1. ID *@
            <td class="text-center text-muted small">@row.Id</td>

            @* 2. Tên mức chất lượng - Căn trái vùng giữa *@
            <td class="text-center align-middle">
                
                    <span class="@(row.SortOrder >= 5 ? "text-primary" : "text-dark")">
                        @row.Name
                    </span>
                
            </td>

            @* 3. Badge Ưu tiên (Cột mới) *@
            <td class="text-center align-middle">
                @if (row.SortOrder >= 5)
                {
                    <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-3 py-2 animate__animated animate__fadeIn"
                          style="font-size: 0.65rem; letter-spacing: 0.5px; text-transform: uppercase;">
                        <i class="fa-solid fa-star me-1"></i>High Priority
                    </span>
                }
            </td>

            @* 4. Mô tả *@
            <td class="text-center align-middle">
                @if (string.IsNullOrWhiteSpace(row.Description))
                {
                    <span class="text-muted opacity-50">---</span>
                }
                else
                {
                    <div class="text-muted small text-truncate mx-auto" style="max-width: 250px;" title="@row.Description">
                        @row.Description
                    </div>
                }
            </td>

            @* 5. Thứ tự sắp xếp *@
            <td class="text-center">
                <div class="d-inline-flex align-items-center justify-content-center bg-light border rounded-circle fw-bold text-secondary shadow-sm"
                    style="width: 32px; height: 32px; font-size: 0.85rem;">
                    @row.SortOrder
                </div>
            </td>
        </RowTemplate>

    </MasterDetailLayout>
}

@code {
    // --- PARAMETERS TỪ URL ---
    // Tự động nhận giá trị từ URL /admin/manage/roomquality/{TypeId}
    [Parameter] public int? TypeId { get; set; }

    // --- STATE ---
    private List<RoomQualityVM>? _items;

    // Tách 2 Model riêng biệt
    private RoomQualityCreateVM _createModel = new RoomQualityCreateVM();
    private RoomQualityUpdateVM _updateModel = new RoomQualityUpdateVM();

    private int _currentEditingId = 0;
    private bool _isUpdate = false;


    // --- QUẢN LÝ PHÂN TRANG ---
    // Khởi tạo request: Trang 1, Size 10
    private PagingRequest _paging = new() { PageIndex = 1, PageSize = 10 };
    private int _totalPages = 0;
    private int _totalCount = 0;


    // Biến kiểm soát vòng đời & Re-render
    private int? _previousTypeId = -999;

    // --- LIFECYCLE ---
    // --- 1. LOAD DATA (Override từ Cha) ---
    protected override async Task LoadDataAsync()
    {
        // Reset UI Loading
        _items = null!;
        StateHasChanged();

        try
        {
            // Gọi API (Dùng 'Service' của Cha)
            var res = await Service.GetRoomQualitiesByType(TypeId, _paging);

            if (!Disposed) // Check cờ Disposed từ Cha
            {
                if (res.StatusCode == StatusCodeResponse.Success && res.Content != null)
                {
                    _items = res.Content.Items;
                    _totalPages = res.Content.TotalPages;
                    _totalCount = res.Content.TotalCount;
                }
                else
                {
                    _items = new List<RoomQualityVM>();
                    if (res.StatusCode != StatusCodeResponse.Success)
                    {
                        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi load data roomquality");
            _items = new List<RoomQualityVM>();
        }
    }

    protected override void OnInitialized()
    {
        // Ép Model đúng kiểu ngay khi component vừa được tạo ra
        ResetForm();
    }

    // --- 2. XỬ LÝ CHUYỂN TAB ---
    protected override async Task OnParametersSetAsync()
    {

        if (TypeId == null) TypeId = 1;

        if (TypeId != _previousTypeId)
        {
            _previousTypeId = TypeId;
            ResetForm();

            if (IsJsReady) 
            {
                _paging.PageIndex = 1;
                await LoadDataAsync();
            }
        }
    }

    // --- HÀM XỬ LÝ KHI BẤM CHUYỂN TRANG ---
    private async Task HandlePageChanged(int newPage)
    {
        // Cập nhật số trang mới vào Request
        _paging.PageIndex = newPage;
        // Gọi lại API
        await LoadDataAsync();
    }

    // --- CRUD METHODS ---
    private void OnEditItem(RoomQualityVM item)
    {
        _isUpdate = true;
        _currentEditingId = item.Id;

        // Map sang UpdateVM (Không cần TypeId)
        _updateModel = new RoomQualityUpdateVM
        {
            Name = item.Name,
            Description = item.Description,
            SortOrder = item.SortOrder
        };
    }

    private async Task HandleDelete(RoomQualityVM item)
    {
        // Gọi API xóa thực tế
        var res = await Service.DeleteRoomQuality(item.Id);

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            // Xóa thành công thì load lại bảng
            await LoadDataAsync();
        }
    }

    private void ResetForm()
    {
        _isUpdate = false;
        _currentEditingId = 0;

        // Reset CreateVM với TypeId hiện tại
        _createModel = new RoomQualityCreateVM 
        { 
            TypeId = TypeId ?? 0,
            SortOrder = 0 
        };
        _updateModel = new RoomQualityUpdateVM();

        StateHasChanged();
    }

    private async Task SaveData()
    {

        ApiResponse<RoomQualityVM> res;

        if (_isUpdate)
        {
            // Update: Gửi UpdateVM + ID
            res = await Service.UpdateRoomQuality(_currentEditingId, _updateModel);
        }
        else
        {
            // Create: Gửi CreateVM (Đã có TypeId)
            _createModel.TypeId = TypeId ?? 0;
            res = await Service.CreateRoomQuality(_createModel);
        }

        // Hiển thị thông báo
        SnackbarHelper.Show(_snackbar, res.StatusCode!, res.Message!);

        if (res.StatusCode == StatusCodeResponse.Success)
        {
            await LoadDataAsync();
            ResetForm();
        }
    }
}
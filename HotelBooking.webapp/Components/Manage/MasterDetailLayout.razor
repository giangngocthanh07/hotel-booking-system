@typeparam TItem
@using System.ComponentModel.DataAnnotations

<div class="container p-0 ">
    @* [UPDATE 1] Thêm align-items-stretch để 2 cột cao bằng nhau *@
    <div class="row g-4 align-items-stretch">

        @* --- LEFT SIDEBAR (FORM) --- *@
        @* [UPDATE 2] d-flex flex-column để cột này thành flex container *@
        <div class="col-12 col-lg-3 d-flex flex-column">
            @* [UPDATE 3] h-100 để card cao full cột *@
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body bg-light rounded d-flex flex-column">

                    @* HEADER SIDEBAR *@
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-uppercase text-muted mb-0">
                            <i class="bi bi-sliders me-1"></i> Bộ lọc & Cấu hình
                        </h6>
                        @if (_isEditMode)
                        {
                            <span class="badge bg-warning text-dark">Editing mode</span>
                        }
                    </div>

                    @* DROPDOWN CONTENT *@
                    <div class="mb-3">
                        @if (SidebarTopContent != null)
                        {
                            @SidebarTopContent
                        }
                    </div>

                    <hr class="my-2" />

                    @* TITLE FORM *@
                    <h5 class="@(_isEditMode ? "text-warning" : "text-success") fw-bold my-3">
                        @(_isEditMode ? "CẬP NHẬT" : "THÊM MỚI")
                    </h5>

                    @* FORM INPUT *@
                    @* flex-grow-1 để đẩy nút bấm xuống dưới nếu muốn, hoặc để form giãn ra *@
                    <div class="flex-grow-1">
                        <EditForm Model="Model" OnValidSubmit="HandleSubmit">
                            <DataAnnotationsValidator />

                            @if (FormContent != null)
                            {
                                @FormContent(Model)
                            }

                            @* BUTTON ACTION *@
                            <div class="mt-4 d-grid gap-2">
                                <button type="submit"
                                    class="btn @(_isEditMode ? "btn-warning text-white" : "btn-success") shadow-sm fw-bold">
                                    <i class="fa-solid @(_isEditMode ? "fa-save" : "fa-plus") me-2"></i>
                                    @(_isEditMode ? "LƯU THAY ĐỔI" : "TẠO MỚI")
                                </button>

                                @if (_isEditMode)
                                {
                                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">
                                        <i class="fa-solid fa-xmark me-2"></i> HỦY BỎ
                                    </button>
                                }
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>

        @* --- RIGHT CONTENT (TABLE LIST) --- *@
        @* [UPDATE 4] d-flex flex-column *@
        <div class="col-12 col-lg-9 d-flex flex-column">
            @* [UPDATE 5] h-100 và d-flex flex-column *@
            <div class="card shadow-sm border-0 h-100 d-flex flex-column overflow-hidden">

                @* HEADER CARD *@
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">Data List</h5>
                    <div>
                        <span class="badge bg-light text-dark border me-2">Page: @PageIndex / @(TotalPages == 0 ? 1 :
                                                        TotalPages)</span>
                        <span class="badge bg-primary rounded-pill">Total: @TotalCount</span>
                    </div>
                </div>

                @* CARD BODY: Chứa Table + Empty State *@
                @* [UPDATE 6] flex-grow-1 và overflow-hidden để scroll nội bộ *@
                <div class="card-body p-0 d-flex flex-column flex-grow-1 overflow-hidden position-relative">

                    @if (Items == null)
                    {
                        @* LOADING STATE *@
                        <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1">
                            <div class="spinner-border text-primary mb-2" role="status"></div>
                            <div class="text-muted small">Đang tải dữ liệu...</div>
                        </div>
                    }
                    else if (!Items.Any())
                    {
                        @* EMPTY STATE *@
                        <div
                            class="d-flex flex-column align-items-center justify-content-center flex-grow-1 text-muted bg-light bg-opacity-25">
                            <i class="fa-solid fa-inbox fa-3x mb-3 opacity-25"></i>
                            <p class="mb-0 fw-bold">Chưa có dữ liệu nào</p>
                        </div>
                    }
                    else
                    {
                        @* TABLE DATA CONTAINER *@
                        @* [UPDATE 7] overflow-y-auto để cuộn dọc bảng, flex-grow-1 để chiếm hết chỗ trống *@
                        <div class="table-responsive flex-grow-1" style="overflow-y: auto;">
                            <table class="table table-hover align-middle mb-0">
                                @* Sticky Header: Dính đầu bảng khi cuộn *@
                                <thead class="table-light text-secondary text-uppercase small fw-bold"
                                    style="position: sticky; top: 0; z-index: 10;">
                                    <tr>
                                        @TableHeader
                                        <th class="text-center text-nowrap bg-light"
                                            style="width: 100px; position: sticky; right: 0;">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="border-top-0">
                                    @foreach (var item in Items)
                                    {
                                        <tr>
                                            @RowTemplate(item)
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-link text-warning p-0 me-2"
                                                    @onclick="() => EditItem(item)" title="Edit">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </button>
                                                <button class="btn btn-sm btn-link text-danger p-0"
                                                    @onclick="() => RequestDelete(item)" title="Delete">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @* PAGINATION FOOTER *@
                @* [UPDATE 8] Footer nằm ngoài vùng scroll của table, luôn dính đáy card *@
                @if (TotalPages > 1)
                {
                    <div class="card-footer bg-white border-top py-3 mt-auto">
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center mb-0">
                                @* Previous *@
                                <li class="page-item @(PageIndex <= 1 ? "disabled" : "")">
                                    <button class="page-link border-0" @onclick="() => HandlePageChange(PageIndex - 1)">
                                        <i class="fa-solid fa-chevron-left"></i>
                                    </button>
                                </li>

                                @* Page Numbers logic (rút gọn nếu quá nhiều trang) *@
                                @for (int i = 1; i <= TotalPages; i++)
                                {
                                    var p = i;
                                    <li class="page-item @(PageIndex == p ? "active" : "")">
                                        <button
                                            class="page-link border-0 rounded-circle mx-1 @(PageIndex == p ? "shadow-sm" : "")"
                                            style="@(PageIndex == p ? "background-color: var(--bs-primary);" : "color: #555;")"
                                            @onclick="() => HandlePageChange(p)">
                                            @p
                                        </button>
                                    </li>
                                }

                                @* Next *@
                                <li class="page-item @(PageIndex >= TotalPages ? "disabled" : "")">
                                    <button class="page-link border-0" @onclick="() => HandlePageChange(PageIndex + 1)">
                                        <i class="fa-solid fa-chevron-right"></i>
                                    </button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* --- CHÈN CSS TRỰC TIẾP TẠI ĐÂY --- *@
<style>
    /* 1. Tùy chỉnh thanh cuộn cho bảng (nhỏ gọn, đẹp hơn) */
    .table-responsive::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }

    /* Màu nền của đường ray cuộn */
    .table-responsive::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
    }

    /* Màu của thanh trượt */
    .table-responsive::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }

    /* Màu khi di chuột vào thanh trượt */
    .table-responsive::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    /* 2. Hiệu ứng hover cho nút phân trang */
    .page-link {
        transition: transform 0.1s ease-in-out, background-color 0.2s;
    }

    .page-link:active {
        transform: scale(0.95);
        /* Nhấn xuống nhẹ khi click */
    }
</style>

<ConfirmModal @ref="_confirmModal" Title="Xóa dữ liệu?" Message="Bạn có thực sự muốn xóa dòng dữ liệu này không?"
    OnConfirm="ConfirmDelete" />

@code {
    // --- DATA ---
    [Parameter] public List<TItem> Items { get; set; }
    [Parameter] public TItem Model { get; set; }

    // --- UI FRAGMENTS ---
    [Parameter] public RenderFragment SidebarTopContent { get; set; } // Chứa Dropdown Module/Type
    [Parameter] public RenderFragment<TItem> FormContent { get; set; }
    [Parameter] public RenderFragment TableHeader { get; set; }
    [Parameter] public RenderFragment<TItem> RowTemplate { get; set; }

    // --- PAGINATION PARAMETERS ---
    // Nhận trạng thái từ Component Cha (Manager)
    [Parameter] public int PageIndex { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; } = 0;
    [Parameter] public int TotalCount { get; set; } = 0;

    // Sự kiện bắn ra ngoài khi user bấm chuyển trang
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    // --- EVENTS ---
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<TItem> OnEdit { get; set; }
    [Parameter] public EventCallback<TItem> OnDelete { get; set; }

    // --- LOGIC ---
    private bool _isEditMode = false;

    // Logic cho Modal Xóa
    // 1. Biến tham chiếu đến Component con (để gọi hàm Show)
    private ConfirmModal _confirmModal;
    // 2. Biến lưu tạm item đang muốn xóa
    private TItem _itemToDelete;

    // [NEW] Xử lý chuyển trang
    private async Task HandlePageChange(int newPage)
    {
        // Guard clause: Chặn click bậy
        if (newPage < 1 || newPage > TotalPages || newPage == PageIndex) return;

        // Bắn sự kiện ra ngoài cho Manager gọi API
        await OnPageChanged.InvokeAsync(newPage);
    }

    private async Task EditItem(TItem item)
    {
        _isEditMode = true;
        await OnEdit.InvokeAsync(item);
    }
    private async Task CancelEdit()
    {
        _isEditMode = false;
        await OnCancel.InvokeAsync();
    }

    // 1. Khi bấm nút thùng rác -> Hiện Modal
    private void RequestDelete(TItem item)
    {
        _itemToDelete = item;
        _confirmModal.Show();
    }

    // 2. Khi bấm nút "Yes, Delete" trong Modal
    private async Task ConfirmDelete()
    {
        // Gọi Event Delete ra ngoài cho Manager xử lý (API)
        await OnDelete.InvokeAsync(_itemToDelete); // Gọi sự kiện xóa

        // Nếu đang sửa đúng thằng bị xóa thì reset form
        if (_isEditMode && Model.Equals(_itemToDelete))
        {
            await CancelEdit();
        }
        // Không cần gọi _confirmModal.Hide() vì nó tự đóng rồi
        _itemToDelete = default;
    }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync();
        if (_isEditMode) _isEditMode = false;
    }
}